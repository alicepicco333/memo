    rdfs:range memo:MemeConcept ;
    owl:inverseOf memo:hasOriginBook .

memo:isOriginComicOf a owl:ObjectProperty ;
    rdfs:label "is Origin Comic Of" ;
    rdfs:domain memo:OriginComic ;
    rdfs:range memo:MemeConcept ;
    owl:inverseOf memo:hasOriginComic .

memo:isOriginFilmOf a owl:ObjectProperty ;
    rdfs:label "is Origin Film Of" ;
    rdfs:domain memo:OriginFilm ;
    rdfs:range memo:MemeConcept ;
    owl:inverseOf memo:hasOriginFilm .

memo:isOriginMusicOf a owl:ObjectProperty ;
    rdfs:label "is Origin Music Of" ;
    rdfs:domain memo:OriginMusic ;
    rdfs:range memo:MemeConcept ;
    owl:inverseOf memo:hasOriginMusic .

memo:isOriginPersonOf a owl:ObjectProperty ;
    rdfs:label "is Origin Person Of" ;
    rdfs:domain memo:OriginPerson ;
    rdfs:range memo:MemeConcept ;
    owl:inverseOf memo:hasOriginPerson .

memo:isOriginPlatformOf a owl:ObjectProperty ;
    rdfs:label "is Origin Platform Of" ;
    rdfs:domain memo:OriginPlatform ;
    rdfs:range memo:MemeConcept ;
    owl:inverseOf memo:hasOriginPlatform .

memo:isOriginTVShowOf a owl:ObjectProperty ;
    rdfs:label "is Origin TV Show Of" ;
    rdfs:domain memo:OriginTVShow ;
    rdfs:range memo:MemeConcept ;
    owl:inverseOf memo:hasOriginTVShow .

memo:isOriginVideoGameOf a owl:ObjectProperty ;
    rdfs:label "is Origin Video Game Of" ;
    rdfs:domain memo:OriginVideoGame ;
    rdfs:range memo:MemeConcept ;
    owl:inverseOf memo:hasOriginVideoGame .

memo:isOriginWorkOf a owl:ObjectProperty ;
    rdfs:label "is Origin Work Of" ;
    rdfs:domain memo:OriginWork ;
    rdfs:range memo:MemeConcept ;
    owl:inverseOf memo:hasOriginWork .

memo:isReferencedIn a owl:ObjectProperty ;
    rdfs:label "is Referenced In" ;
    rdfs:domain memo:CulturalReference ;
    rdfs:range memo:MemeConcept ;
    owl:inverseOf memo:hasReference .

memo:isRegionOf a owl:ObjectProperty ;
    rdfs:label "is Region Of" ;
    rdfs:domain memo:GeographicRegion ;
    rdfs:range memo:MemeConcept ;
    owl:inverseOf memo:hasRegion .

memo:isSubjectMatterOf a owl:ObjectProperty ;
    rdfs:label "is Subject Matter Of" ;
    rdfs:domain memo:SubjectMatter ;
