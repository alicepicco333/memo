    rdfs:range memo:MemeConcept ;
    owl:inverseOf memo:hasFormat .

memo:isImageTypeOf a owl:ObjectProperty ;
    rdfs:label "isImageTypeOf" ;
    rdfs:domain memo:ImageType ;
    rdfs:range memo:VariantInstance ;
    owl:inverseOf memo:hasImageType .

