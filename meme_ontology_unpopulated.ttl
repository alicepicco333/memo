    rdfs:label "variantImageURL" ;
    rdfs:domain memo:VariantInstance ;
    rdfs:range xsd:string .

memo:variantIndex a owl:DatatypeProperty ;
    rdfs:label "variantIndex" ;
    rdfs:domain memo:VariantInstance ;
