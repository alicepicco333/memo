memo:AnimationStatus a owl:Class ;
    rdfs:label "AnimationStatus"@en ;
    memo:documentaryLevel "true" ;
    memo:frbrLevel "Item" ;
    rdfs:comment """Whether a meme image is static or animated\r\r\r\r\r\r
(GIF/video)."""@en ;
    rdfs:subClassOf owl:Thing .

memo:CulturalReference a owl:Class ;
    rdfs:label "CulturalReference"@en ;
    memo:frbrLevel "Expression Manifestation",
        "Expression, Manifestation" ;
    memo:semanticLevel "Iconological" ;
    rdfs:comment """A cultural entity referenced by a meme — a historical\r\r\r\r\r\r
event, media property, political event, public figure, social phenomenon, or web\r\r\r\r\r\r
culture artefact. Subclasses: HistoricalEvent, MediaProperty, PoliticalEvent,\r\r\r\r\r\r
PublicFigure, SocialPhenomenon, WebCulture."""@en ;
    rdfs:subClassOf owl:Thing .

memo:OriginBoard a owl:Class ;
    rdfs:label "OriginBoard" ;
    rdfs:subClassOf memo:OriginWork .

memo:OriginBook a owl:Class ;
    rdfs:label "OriginBook" ;
    rdfs:subClassOf memo:OriginWork .

memo:OriginComic a owl:Class ;
    rdfs:label "OriginComic" ;
    rdfs:subClassOf memo:OriginWork .

memo:OriginFilm a owl:Class ;
    rdfs:label "OriginFilm" ;
    rdfs:subClassOf memo:OriginWork .

memo:OriginMusic a owl:Class ;
    rdfs:label "OriginMusic" ;
    rdfs:subClassOf memo:OriginWork .

memo:OriginPerson a owl:Class ;
    rdfs:label "OriginPerson" ;
    rdfs:subClassOf memo:OriginWork .

memo:OriginTVShow a owl:Class ;
    rdfs:label "OriginTVShow" ;
    rdfs:subClassOf memo:OriginWork .

memo:OriginVideoGame a owl:Class ;
    rdfs:label "OriginVideoGame" ;
    rdfs:subClassOf memo:OriginWork .

memo:TransformationDimension a owl:Class ;
    rdfs:label "TransformationDimension"@en ;
    memo:documentaryLevel "true" ;
    memo:frbrLevel "Manifestation" ;
    rdfs:comment """The axis along which a variant transforms the\r\r\r\r\r\r
canonical template: CaptionChange, VisualSubstrate, MediumShift, StyleShift,\r\r\r\r\r\r
CompositionShift, CrossoverMerge, LanguageShift, Localization."""@en ;
    rdfs:subClassOf owl:Thing .

memo:MemeIdea a owl:Class ;
    rdfs:label "MemeIdea"@en ;
    memo:frbrLevel "Work" ;
    rdfs:comment """The abstract Work-level idea underlying a memo:\r\r\r\r\r\r
its core narrative, emotional register, rhetorical function or cultural role,\r\r\r\r\r\r
independent of any specific image or format. 50 enriched individuals from the\r\r\r\r\r\r
D0 sample, with descriptions and cultural reference annotations."""@en ;
    rdfs:subClassOf owl:Thing .

memo:TransformationExtent a owl:Class ;
    rdfs:label "TransformationExtent"@en ;
    memo:documentaryLevel "true" ;
    memo:frbrLevel "Manifestation" ;
    rdfs:comment """The degree to which a variant departs from the\r\r\r\r\r\r
canonical template: Minimal (close copy), Moderate, Substantial, or Parody\r\r\r\r\r\r
(radical departure)."""@en ;
    rdfs:subClassOf owl:Thing .

memo:FileFormat a owl:Class ;
    rdfs:label "FileFormat"@en ;
    memo:documentaryLevel "true" ;
    memo:frbrLevel "Item" ;
    rdfs:comment """The digital file format of the meme image (JPEG,\r\r\r\r\r\r
PNG, GIF, WebP, BMP)."""@en ;
    rdfs:subClassOf owl:Thing .

memo:TimePeriod a owl:Class ;
    rdfs:label "TimePeriod"@en ;
    memo:documentaryLevel "true" ;
    memo:frbrLevel "Expression" ;
    rdfs:comment """The era in which a meme originated or peaked\r\r\r\r\r\r
(Pre2010, Period2010to2015, Period2016to2020, Period2021toPresent)."""@en ;
    rdfs:subClassOf owl:Thing .

memo:ColorMode a owl:Class ;
    rdfs:label "ColorMode" ;
    memo:frbrLevel "Manifestation" ;
    memo:semanticLevel "PreIconographical" ;
    rdfs:subClassOf owl:Thing .

memo:TextPresence a owl:Class ;
    rdfs:label "TextPresence" ;
    memo:frbrLevel "Manifestation" ;
    memo:semanticLevel "PreIconographical" ;
    rdfs:subClassOf owl:Thing .

memo:SubjectMatter a owl:Class ;
    rdfs:label "SubjectMatter" ;
    memo:frbrLevel "Manifestation" ;
    memo:semanticLevel "PreIconographical" ;
    rdfs:subClassOf owl:Thing .

memo:ImageType a owl:Class ;
    rdfs:label "ImageType"@en ;
    memo:frbrLevel "Manifestation" ;
    memo:semanticLevel "PreIconographical" ;
    rdfs:comment """The visual medium type of an individual variant\r\r\r\r\r\r
image. Uses the same controlled vocabulary as CanonicalImageType but applied at\r\r\r\r\r\r
the Item (VariantInstance) level."""@en ;
    rdfs:subClassOf owl:Thing .

memo:OriginWork a owl:Class ;
    rdfs:label "OriginWork"@en ;
    memo:documentaryLevel "true" ;
    memo:frbrLevel "Expression" ;
    rdfs:comment """The original cultural work (film, TV show, video\r\r\r\r\r\r
game, book, song, etc.) from which a meme derives its source material."""@en ;
    rdfs:subClassOf owl:Thing .

memo:OriginPlatform a owl:Class ;
    rdfs:label "OriginPlatform"@en ;
    memo:documentaryLevel "true" ;
    memo:frbrLevel "Expression" ;
    rdfs:comment """The online platform where a meme first appeared\r\r\r\r\r\r
or gained traction (e.g. Reddit, Twitter/X, 4chan, TikTok). Classified at the\r\r\r\r\r\r
Expression level with Documentary provenance."""@en ;
    rdfs:subClassOf owl:Thing .

memo:VariantInstance a owl:Class ;
    rdfs:label "VariantInstance"@en ;
    memo:frbrLevel "Manifestation" ;
    rdfs:comment """A single scraped variant image — an Item-level\r\r\r\r\r\r
exemplar of a MemeConcept. 391 named individuals with transformation extent and\r\r\r\r\r\r
dimension annotations for 5 fully annotated meme templates."""@en ;
    rdfs:subClassOf owl:Thing .

memo:MemeFormat a owl:Class ;
    rdfs:label "MemeFormat"@en ;
    memo:frbrLevel "Expression" ;
    memo:semanticLevel "Iconographical" ;
    rdfs:comment """The rhetorical or structural format of a meme\r\r\r\r\r\r
(e.g. ImageMacro, Catchphrase, Exploitable, Reaction, ViralVideo). Classifies\r\r\r\r\r\r
memes at the Expression level with Iconographical analysis."""@en ;
    rdfs:subClassOf owl:Thing .

memo:MemeConcept a memo:MemeFormat,
        owl:NamedIndividual ;
    rdfs:label "MemeConcept"@en ;
    memo:frbrLevel "Expression" ;
    rdfs:comment """A canonical internet meme template as indexed\r\r\r\r\r\r
on Know Your Meme. Represents the stable, Expression-level identity of a meme\r\r\r\r\r\r
across all its variants. 5,000 named individuals are included, classified by\r\r\r\r\r\r
image type, format, platform, region and time period."""@en .

memo:GeographicRegion a owl:Class ;
    rdfs:label "GeographicRegion"@en ;
    memo:documentaryLevel "true" ;
    memo:frbrLevel "Expression" ;
    rdfs:comment """The country or geographic region of a meme's\r\r\r\r\r\r
origin."""@en ;
    rdfs:subClassOf owl:Thing .

