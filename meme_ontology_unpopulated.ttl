memo:documentaryLevel a owl:AnnotationProperty ;
    rdfs:label "documentary level"@en ;
    rdfs:comment """Associates a class or property with the\r\r\r\r\r\r
documentary analysis dimension (provenance, platform, geographic and temporal\r\r\r\r\r\r
context)."""@en .

memo:frbrLevel a owl:AnnotationProperty ;
    rdfs:label "FRBR level"@en ;
    rdfs:comment """Associates a class or property with its\r\r\r\r\r\r
position in the FRBR abstraction hierarchy: Work, Expression, Manifestation, or\r\r\r\r\r\r
Item."""@en .

