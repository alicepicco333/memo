memo:captionText a owl:DatatypeProperty ;
    rdfs:label "captionText" ;
    rdfs:domain memo:VariantInstance ;
    rdfs:range xsd:string .

memo:conceptDescription a owl:DatatypeProperty ;
    rdfs:label "conceptDescription" ;
    rdfs:domain memo:MemeIdea ;
    rdfs:range xsd:string .

memo:description a owl:DatatypeProperty ;
    rdfs:label "description" ;
    rdfs:domain memo:MemeConcept ;
    rdfs:range xsd:string .

memo:hasId a owl:DatatypeProperty ;
    rdfs:label "has ID"@en ;
    rdfs:comment """Numeric identifier matching the meme's position\r\r\r\r\r\r
in the scraped dataset (1–5000)."""@en ;
    rdfs:domain memo:MemeConcept ;
    rdfs:range xsd:integer ;
    owl:deprecated true .

memo:hasVariantSubjectMatter a owl:ObjectProperty ;
    rdfs:label "Has Variant Subject Matter" ;
    rdfs:comment "What a specific user added or changed when they created their individual variation (Manifestation/Item level)." ;
    rdfs:domain memo:VariantInstance ;
    rdfs:range memo:SubjectMatter .

