memo:Colombia a memo:GeographicRegion,
        owl:NamedIndividual ;
    rdfs:label "Colombia" ;
    rdfs:seeAlso <https://www.wikidata.org/wiki/Q739> .

memo:Color a memo:ColorMode,
        owl:NamedIndividual ;
    rdfs:label "Color" .

memo:ConspiracyTheory a memo:MemeFormat,
        owl:NamedIndividual ;
    rdfs:label "ConspiracyTheory" ;
