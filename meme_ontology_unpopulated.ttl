@prefix dc: <http://purl.org/dc/elements/1.1/> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix memo: <http://www.semanticweb.org/meme-ontology#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

memo: a owl:Ontology ;
    rdfs:label "Meme Ontology (MEMO)"@en ;
    dc:creator "Meme Ontology Project" ;
    dc:description "The Meme Ontology (MEMO) is an OWL 2 DL ontology for the formal description of internet memes. It models meme templates (MemeConcept), their underlying creative ideas (MemeIdea), and scraped variant images (VariantInstance) using a FRBR-aligned four-level abstraction hierarchy and Panofsky's three levels of semantic analysis. Value classes provide controlled vocabularies for format, platform, image type, transformation extent and dimension, and other classifiers. 5,000 meme concepts, 50 enriched meme ideas and 391 variant instances are included as named individuals."@en ;
    dc:rights """Released for academic research. Data sourced from
Know Your Meme under fair use."""@en ;
    dc:title "Meme Ontology (MEMO)"@en ;
    dcterms:abstract "The Meme Ontology (MEMO) is a comprehensive OWL 2 DL ontology for the formal description and analysis of internet memes. It models the FRBR-aligned four-level abstraction hierarchy: meme templates (MemeConcept), creative instantiations (MemeIdea), variant manifestations (VariantInstance), and individual images (Item). Using Panofsky's three-level semantic analysis framework (PreIconographical, Iconographical, Iconological), the ontology provides controlled vocabularies for format classification, platform origin, image characteristics, transformation patterns, and cultural context. The schema encompasses 5,000 meme concepts, 50 enriched ideas, and 391 variant instances from Know Your Meme, enabling computational analysis of meme evolution, cultural adoption patterns, and creative transformation strategies in digital culture."@en ;
    dcterms:created "2024"^^xsd:gYear ;
    dcterms:title "Meme Ontology (MEMO)"@en ;
    rdfs:seeAlso <https://github.com/meme-ontology/meme-ontology> ;
    owl:name "Meme Ontology (MEMO)" ;
    owl:versionInfo "1.0" .

memo:AnimationStatus a owl:Class ;
    rdfs:label "AnimationStatus" ;
    memo:frbrLevel "Item" ;
    rdfs:comment """Whether a meme image is static or animated
(GIF/video)."""@en ;
    rdfs:subClassOf owl:Thing .

memo:ColorMode a owl:Class ;
    rdfs:label "ColorMode" ;
    memo:frbrLevel "Manifestation" ;
    memo:semanticLevel "PreIconographical" ;
    rdfs:subClassOf owl:Thing .

memo:CulturalReference a owl:Class ;
    rdfs:label "CulturalReference" ;
    memo:frbrLevel "Expression Manifestation",
        "Expression, Manifestation" ;
    memo:semanticLevel "Iconological" ;
    rdfs:comment """A cultural entity referenced by a meme — a historical
event, media property, political event, public figure, social phenomenon, or web
culture artefact. Subclasses: HistoricalEvent, MediaProperty, PoliticalEvent,
PublicFigure, SocialPhenomenon, WebCulture."""@en ;
    rdfs:subClassOf owl:Thing .

memo:FileFormat a owl:Class ;
    rdfs:label "FileFormat" ;
    memo:frbrLevel "Item" ;
    rdfs:comment """The digital file format of the meme image (JPEG,
PNG, GIF, WebP, BMP)."""@en ;
    rdfs:subClassOf owl:Thing .

memo:GeographicRegion a owl:Class ;
    rdfs:label "GeographicRegion" ;
    memo:frbrLevel "Expression" ;
    rdfs:comment """The country or geographic region of a meme's
origin."""@en ;
    rdfs:subClassOf owl:Thing .

memo:ImageType a owl:Class ;
    rdfs:label "ImageType" ;
    memo:frbrLevel "Manifestation" ;
    memo:semanticLevel "PreIconographical" ;
    rdfs:comment """The visual medium type of an individual variant
image. Uses the same controlled vocabulary as CanonicalImageType but applied at
the Item (VariantInstance) level."""@en ;
    rdfs:subClassOf owl:Thing .

memo:MemeFormat a owl:Class ;
    rdfs:label "MemeFormat" ;
    memo:frbrLevel "Expression" ;
    memo:semanticLevel "Iconographical" ;
    rdfs:comment """The rhetorical or structural format of a meme
(e.g. ImageMacro, Catchphrase, Exploitable, Reaction, ViralVideo). Classifies
memes at the Expression level with Iconographical analysis."""@en ;
    rdfs:subClassOf owl:Thing .

memo:MemeIdea a owl:Class ;
    rdfs:label "MemeIdea" ;
    memo:frbrLevel "Work" ;
    rdfs:comment """The abstract Work-level idea underlying a memo:
its core narrative, emotional register, rhetorical function or cultural role,
independent of any specific image or format. 50 enriched individuals from the
D0 sample, with descriptions and cultural reference annotations."""@en ;
    rdfs:subClassOf owl:Thing .

memo:OriginPlatform a owl:Class ;
    rdfs:label "OriginPlatform" ;
    memo:frbrLevel "Expression" ;
    rdfs:comment """The online platform where a meme first appeared
or gained traction (e.g. Reddit, Twitter/X, 4chan, TikTok). Classified at the
Expression level with Documentary provenance."""@en ;
    rdfs:subClassOf owl:Thing .

memo:OriginWork a owl:Class ;
    rdfs:label "OriginWork" ;
    memo:frbrLevel "Expression" ;
    rdfs:comment """The original cultural work (film, TV show, video
game, book, song, etc.) from which a meme derives its source material."""@en ;
    rdfs:subClassOf owl:Thing .

memo:SubjectMatter a owl:Class ;
    rdfs:label "SubjectMatter" ;
    memo:frbrLevel "Manifestation" ;
    memo:semanticLevel "PreIconographical" ;
    rdfs:subClassOf owl:Thing .

memo:TextPresence a owl:Class ;
    rdfs:label "TextPresence" ;
    memo:frbrLevel "Manifestation" ;
    memo:semanticLevel "PreIconographical" ;
    rdfs:subClassOf owl:Thing .

memo:TimePeriod a owl:Class ;
    rdfs:label "TimePeriod" ;
    memo:frbrLevel "Expression" ;
    rdfs:comment """The era in which a meme originated or peaked
(Pre2010, Period2010to2015, Period2016to2020, Period2021toPresent)."""@en ;
    rdfs:subClassOf owl:Thing .

memo:TransformationDimension a owl:Class ;
    rdfs:label "TransformationDimension" ;
    memo:frbrLevel "Manifestation" ;
    rdfs:comment """The axis along which a variant transforms the
canonical template: CaptionChange, VisualSubstrate, MediumShift, StyleShift,
CompositionShift, CrossoverMerge, LanguageShift, Localization."""@en ;
    rdfs:subClassOf owl:Thing .

memo:TransformationExtent a owl:Class ;
    rdfs:label "TransformationExtent" ;
    memo:frbrLevel "Manifestation" ;
    rdfs:comment """The degree to which a variant departs from the
canonical template: Minimal (close copy), Moderate, Substantial, or Parody
(radical departure)."""@en ;
    rdfs:subClassOf owl:Thing .

memo:VariantInstance a owl:Class ;
    rdfs:label "VariantInstance" ;
    memo:frbrLevel "Manifestation" ;
    rdfs:comment """A single scraped variant image — an Item-level
exemplar of a MemeConcept. 391 named individuals with transformation extent and
dimension annotations for 5 fully annotated meme templates."""@en ;
    rdfs:subClassOf owl:Thing .

memo:conceptualizes a owl:ObjectProperty ;
    rdfs:label "conceptualizes" ;
    rdfs:domain memo:MemeConcept ;
    rdfs:range memo:MemeIdea ;
    owl:inverseOf memo:isConceptualizedAs .

memo:hasAnimationStatus a owl:ObjectProperty ;
    rdfs:label "hasAnimationStatus" ;
    memo:frbrLevel "Item" ;
    rdfs:domain memo:MemeConcept ;
    rdfs:range memo:AnimationStatus ;
    owl:inverseOf memo:isAnimationStatusOf .

memo:hasCanonicalColorMode a owl:ObjectProperty ;
    rdfs:label "hasCanonicalColorMode" ;
    memo:frbrLevel "Expression" ;
    rdfs:domain memo:MemeConcept ;
    rdfs:range memo:ColorMode ;
    owl:inverseOf memo:isCanonicalColorModeOf .

memo:hasCanonicalImageType a owl:ObjectProperty ;
    rdfs:label "hasCanonicalImageType" ;
    memo:frbrLevel "Expression" ;
    rdfs:comment """The visual medium of the canonical meme image,
assigned by CLIP-based classification."""@en ;
    rdfs:domain memo:MemeConcept ;
    rdfs:range memo:ImageType ;
    owl:inverseOf memo:isCanonicalImageTypeOf .

memo:hasCanonicalSubjectMatter a owl:ObjectProperty ;
    rdfs:label "hasCanonicalSubjectMatter" ;
    memo:frbrLevel "Expression" ;
    rdfs:comment "What is inherently built into the base meme template (Expression level)." ;
    rdfs:domain memo:MemeConcept ;
    rdfs:range memo:SubjectMatter ;
    owl:inverseOf memo:isCanonicalSubjectMatterOf .

memo:hasCanonicalTextPresence a owl:ObjectProperty ;
    rdfs:label "hasCanonicalTextPresence" ;
    memo:frbrLevel "Expression" ;
    rdfs:domain memo:MemeConcept ;
    rdfs:range memo:TextPresence ;
    owl:inverseOf memo:isCanonicalTextPresenceOf .

memo:hasFormat a owl:ObjectProperty ;
    rdfs:label "hasFormat" ;
    memo:frbrLevel "Expression" ;
    memo:semanticLevel "Iconographical" ;
    rdfs:comment """Links a MemeConcept to one or more MemeFormat
values describing its rhetorical structure."""@en ;
    rdfs:domain memo:MemeConcept ;
    rdfs:range memo:MemeFormat ;
    owl:inverseOf memo:isFormatOf .

memo:hasOriginPlatform a owl:ObjectProperty ;
    rdfs:label "hasOriginPlatform" ;
    rdfs:domain memo:MemeConcept ;
    rdfs:range memo:OriginPlatform ;
    owl:inverseOf memo:isOriginPlatformOf .

memo:hasOriginWork a owl:ObjectProperty ;
    rdfs:label "hasOriginWork" ;
    memo:frbrLevel "Expression" ;
    rdfs:comment """Links a MemeConcept to the cultural Work it
derives from or references."""@en ;
    rdfs:domain memo:MemeConcept ;
    rdfs:range memo:OriginWork ;
    owl:inverseOf memo:isOriginWorkOf .

memo:hasReference a owl:ObjectProperty ;
    rdfs:label "hasReference" ;
    rdfs:domain memo:MemeConcept ;
    rdfs:range memo:CulturalReference ;
    owl:inverseOf memo:isReferencedIn .

memo:hasRegion a owl:ObjectProperty ;
    rdfs:label "hasRegion" ;
    rdfs:comment """The geographic region of a meme's origin or
primary circulation."""@en ;
    rdfs:domain memo:MemeConcept ;
    rdfs:range memo:GeographicRegion ;
    owl:inverseOf memo:isRegionOf .

memo:hasTimePeriod a owl:ObjectProperty ;
    rdfs:label "hasTimePeriod" ;
    rdfs:domain memo:MemeConcept ;
    rdfs:range memo:TimePeriod ;
    owl:inverseOf memo:isTimePeriodOf .

memo:hasTransformationDimension a owl:ObjectProperty ;
    rdfs:label "hasTransformationDimension" ;
    rdfs:domain memo:VariantInstance ;
    rdfs:range memo:TransformationDimension ;
    owl:inverseOf memo:isTransformationDimensionOf .

memo:hasTransformationExtent a owl:ObjectProperty ;
    rdfs:label "hasTransformationExtent" ;
    rdfs:domain memo:VariantInstance ;
    rdfs:range memo:TransformationExtent ;
    owl:inverseOf memo:isTransformationExtentOf .

memo:hasVariant a owl:ObjectProperty ;
    rdfs:label "hasVariant" ;
    rdfs:domain memo:MemeConcept ;
    rdfs:range memo:VariantInstance ;
    owl:inverseOf memo:isVariantOf .

memo:hasVariantColorMode a owl:ObjectProperty ;
    rdfs:label "hasVariantColorMode" ;
    rdfs:comment "The specific color profile applied to a user-created variant." ;
    rdfs:domain memo:VariantInstance ;
    rdfs:range memo:ColorMode ;
    owl:inverseOf memo:isVariantColorModeOf .

memo:hasVariantImageType a owl:ObjectProperty ;
    rdfs:label "hasVariantImageType" ;
    rdfs:comment "The specific image type of a user-created variant." ;
    rdfs:domain memo:VariantInstance ;
    rdfs:range memo:ImageType ;
    owl:inverseOf memo:isVariantImageTypeOf .

memo:hasVariantSubjectMatter a owl:ObjectProperty ;
    rdfs:label "hasVariantSubjectMatter" ;
    rdfs:comment "What a specific user added or changed when they created their individual variation (Manifestation/Item level)." ;
    rdfs:domain memo:VariantInstance ;
    rdfs:range memo:SubjectMatter ;
    owl:inverseOf memo:isVariantSubjectMatterOf .

memo:hasVariantTextPresence a owl:ObjectProperty ;
    rdfs:label "hasVariantTextPresence" ;
    rdfs:comment "Whether a user-created variant includes text or not." ;
    rdfs:domain memo:VariantInstance ;
    rdfs:range memo:TextPresence ;
    owl:inverseOf memo:isVariantTextPresenceOf .

memo:isAnimationStatusOf a owl:ObjectProperty ;
    rdfs:label "isAnimationStatusOf" ;
    rdfs:domain memo:AnimationStatus ;
    rdfs:range memo:MemeConcept ;
    owl:inverseOf memo:hasAnimationStatus .

memo:isCanonicalColorModeOf a owl:ObjectProperty ;
    rdfs:label "isCanonicalColorModeOf" ;
    rdfs:domain memo:ColorMode ;
    rdfs:range memo:MemeConcept ;
    owl:inverseOf memo:hasCanonicalColorMode .

memo:isCanonicalImageTypeOf a owl:ObjectProperty ;
    rdfs:label "isCanonicalImageTypeOf" ;
    rdfs:domain memo:ImageType ;
    rdfs:range memo:MemeConcept ;
    owl:inverseOf memo:hasCanonicalImageType .

memo:isCanonicalSubjectMatterOf a owl:ObjectProperty ;
    rdfs:label "isCanonicalSubjectMatterOf" ;
    rdfs:domain memo:SubjectMatter ;
    rdfs:range memo:MemeConcept ;
    owl:inverseOf memo:hasCanonicalSubjectMatter .

memo:isCanonicalTextPresenceOf a owl:ObjectProperty ;
    rdfs:label "isCanonicalTextPresenceOf" ;
    rdfs:domain memo:TextPresence ;
    rdfs:range memo:MemeConcept ;
    owl:inverseOf memo:hasCanonicalTextPresence .

memo:isConceptualizedAs a owl:ObjectProperty ;
    rdfs:label "isConceptualizedAs" ;
    rdfs:domain memo:MemeIdea ;
    rdfs:range memo:MemeConcept ;
    owl:inverseOf memo:conceptualizes .

memo:isFormatOf a owl:ObjectProperty ;
    rdfs:label "isFormatOf" ;
    rdfs:domain memo:MemeFormat ;
    rdfs:range memo:MemeConcept ;
    owl:inverseOf memo:hasFormat .

memo:isOriginPlatformOf a owl:ObjectProperty ;
    rdfs:label "isOriginPlatformOf" ;
    rdfs:domain memo:OriginPlatform ;
    rdfs:range memo:MemeConcept ;
    owl:inverseOf memo:hasOriginPlatform .

memo:isOriginWorkOf a owl:ObjectProperty ;
    rdfs:label "isOriginWorkOf" ;
    rdfs:domain memo:OriginWork ;
    rdfs:range memo:MemeConcept ;
    owl:inverseOf memo:hasOriginWork .

memo:isReferencedIn a owl:ObjectProperty ;
    rdfs:label "isReferencedIn" ;
    rdfs:domain memo:CulturalReference ;
    rdfs:range memo:MemeConcept ;
    owl:inverseOf memo:hasReference .

memo:isRegionOf a owl:ObjectProperty ;
    rdfs:label "isRegionOf" ;
    rdfs:domain memo:GeographicRegion ;
    rdfs:range memo:MemeConcept ;
    owl:inverseOf memo:hasRegion .

memo:isTimePeriodOf a owl:ObjectProperty ;
    rdfs:label "isTimePeriodOf" ;
    rdfs:domain memo:TimePeriod ;
    rdfs:range memo:MemeConcept ;
    owl:inverseOf memo:hasTimePeriod .

memo:isTransformationDimensionOf a owl:ObjectProperty ;
    rdfs:label "isTransformationDimensionOf" ;
    rdfs:domain memo:TransformationDimension ;
    rdfs:range memo:VariantInstance ;
    owl:inverseOf memo:hasTransformationDimension .

memo:isTransformationExtentOf a owl:ObjectProperty ;
    rdfs:label "isTransformationExtentOf" ;
    rdfs:domain memo:TransformationExtent ;
    rdfs:range memo:VariantInstance ;
    owl:inverseOf memo:hasTransformationExtent .

memo:isVariantColorModeOf a owl:ObjectProperty ;
    rdfs:label "isVariantColorModeOf" ;
    rdfs:domain memo:ColorMode ;
    rdfs:range memo:VariantInstance ;
    owl:inverseOf memo:hasVariantColorMode .

memo:isVariantImageTypeOf a owl:ObjectProperty ;
    rdfs:label "isVariantImageTypeOf" ;
    rdfs:domain memo:ImageType ;
    rdfs:range memo:VariantInstance ;
    owl:inverseOf memo:hasVariantImageType .

memo:isVariantOf a owl:ObjectProperty ;
    rdfs:label "isVariantOf" ;
    rdfs:domain memo:VariantInstance ;
    rdfs:range memo:MemeConcept ;
    owl:inverseOf memo:hasVariant .

memo:isVariantSubjectMatterOf a owl:ObjectProperty ;
    rdfs:label "isVariantSubjectMatterOf" ;
    rdfs:domain memo:SubjectMatter ;
    rdfs:range memo:VariantInstance ;
    owl:inverseOf memo:hasVariantSubjectMatter .

memo:isVariantTextPresenceOf a owl:ObjectProperty ;
    rdfs:label "isVariantTextPresenceOf" ;
    rdfs:domain memo:TextPresence ;
    rdfs:range memo:VariantInstance ;
    owl:inverseOf memo:hasVariantTextPresence .

memo:captionText a owl:DatatypeProperty ;
    rdfs:label "captionText" ;
    rdfs:domain memo:VariantInstance ;
    rdfs:range xsd:string .

memo:conceptDescription a owl:DatatypeProperty ;
    rdfs:label "conceptDescription" ;
    rdfs:domain memo:MemeIdea ;
    rdfs:range xsd:string .

memo:hasId a owl:DatatypeProperty ;
    rdfs:label "hasId" ;
    rdfs:comment """Numeric identifier matching the meme's position
in the scraped dataset (1–5000)."""@en ;
    rdfs:domain memo:MemeConcept ;
    rdfs:range xsd:integer ;
    owl:deprecated true .

memo:imageFilePath a owl:DatatypeProperty ;
    rdfs:label "imageFilePath" ;
    rdfs:domain memo:MemeConcept ;
    rdfs:range xsd:string .

memo:photoURL a owl:DatatypeProperty ;
    rdfs:label "photoURL" ;
    rdfs:domain memo:VariantInstance ;
    rdfs:range xsd:string .

memo:variantFilename a owl:DatatypeProperty ;
    rdfs:label "variantFilename" ;
    rdfs:domain memo:VariantInstance ;
    rdfs:range xsd:string .

memo:variantImageURL a owl:DatatypeProperty ;
    rdfs:label "variantImageURL" ;
    rdfs:domain memo:VariantInstance ;
    rdfs:range xsd:string .

memo:variantIndex a owl:DatatypeProperty ;
    rdfs:label "variantIndex" ;
    rdfs:domain memo:VariantInstance ;
    rdfs:range xsd:integer .

memo:variantTitle a owl:DatatypeProperty ;
    rdfs:label "variantTitle" ;
    rdfs:domain memo:VariantInstance ;
    rdfs:range xsd:string .

memo:variantUploader a owl:DatatypeProperty ;
    rdfs:label "variantUploader" ;
    rdfs:domain memo:VariantInstance ;
    rdfs:range xsd:string .

memo:views a owl:DatatypeProperty ;
    rdfs:label "views" ;
    rdfs:domain memo:MemeConcept ;
    rdfs:range xsd:integer .

