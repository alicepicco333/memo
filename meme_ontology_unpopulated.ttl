@prefix dc: <http://purl.org/dc/elements/1.1/> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix frbrer: <http://iflastandards.info/ns/fr/frbr/frbrer/> .
@prefix memo: <https://purl.org/memo#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix schema: <https://schema.org/> .
@prefix wd: <http://www.wikidata.org/entity/> .
@prefix wdp: <http://www.wikidata.org/prop/direct/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

dcterms:created a owl:AnnotationProperty ;
    rdfs:label "created"@en ;
    rdfs:domain memo:MemeConcept ;
    rdfs:range xsd:integer .

dcterms:description a owl:AnnotationProperty ;
    rdfs:label "description"@en ;
    rdfs:domain memo:MemeConcept ;
    rdfs:range xsd:string .

dcterms:format a owl:ObjectProperty ;
    rdfs:label "format"@en ;
    rdfs:comment "File format of the meme image (JPEG, PNG, GIF, etc.), linked to a FileFormat individual. Uses dcterms:format to align with Dublin Core usage." ;
    rdfs:domain memo:MemeConcept ;
    rdfs:range wd:Q235557 .

dcterms:modified a owl:AnnotationProperty ;
    rdfs:label "modified"@en ;
    rdfs:domain memo:MemeConcept ;
    rdfs:range xsd:string .

<https://purl.org/memo> a owl:Ontology ;
    dc:creator "Alice Picco" ;
    dcterms:license <https://creativecommons.org/licenses/by/4.0/> ;
    dcterms:title "The Meme Ontology (MEMO)"@en ;
    owl:versionInfo "1.0" .

memo:AudioFormat a owl:Class ;
    rdfs:label "AudioFormat" ;
    rdfs:comment "MemeFormat subclass grouping audio-primary formats: Song, SoundEffect."@en ;
    rdfs:subClassOf memo:MemeFormat .

memo:HistoricalEvent a owl:Class ;
    rdfs:label "HistoricalEvent" ;
    rdfs:comment "A historical event, period, or crisis referenced by a meme."@en ;
    rdfs:subClassOf wd:Q96622155 .

memo:ImageManipulationFormat a owl:Class ;
    rdfs:label "ImageManipulationFormat" ;
    rdfs:comment "MemeFormat subclass grouping image manipulation formats: Exploitable, ImageMacro, Photoshop, Remix."@en ;
    rdfs:subClassOf memo:MemeFormat .

memo:MediaProperty a owl:Class ;
    rdfs:label "MediaProperty" ;
    rdfs:comment "A media franchise, film, TV series, game, or other creative property referenced by a meme."@en ;
    rdfs:subClassOf wd:Q96622155 .

memo:NarrativeFormat a owl:Class ;
    rdfs:label "NarrativeFormat" ;
    rdfs:comment "MemeFormat subclass grouping character- and narrative-based formats: Character, FanArt, Parody, PopCultureReference, Reaction."@en ;
    rdfs:subClassOf memo:MemeFormat .

memo:ParticipatoryFormat a owl:Class ;
    rdfs:label "ParticipatoryFormat" ;
    rdfs:comment "MemeFormat subclass grouping participatory formats: ParticipatoryMedia, Dance, SocialGame."@en ;
    rdfs:subClassOf memo:MemeFormat .

memo:PoliticalEvent a owl:Class ;
    rdfs:label "PoliticalEvent" ;
    rdfs:comment "A political event, controversy, or campaign that a meme iconologically references."@en ;
    rdfs:subClassOf wd:Q96622155 .

memo:PublicFigure a owl:Class ;
    rdfs:label "PublicFigure" ;
    rdfs:comment "A public figure, celebrity, politician, or historical person referenced by a meme."@en ;
    rdfs:subClassOf wd:Q96622155 .

memo:SocialPhenomenon a owl:Class ;
    rdfs:label "SocialPhenomenon" ;
    rdfs:comment "A social movement, behavioural trend, or cultural practice referenced by a meme."@en ;
    rdfs:subClassOf wd:Q96622155 .

memo:TextFormat a owl:Class ;
    rdfs:label "TextFormat" ;
    rdfs:comment "MemeFormat subclass grouping text-based formats: Catchphrase, Copypasta, Slang, Snowclone, Hashtag."@en ;
    rdfs:subClassOf memo:MemeFormat .

memo:VideoFormat a owl:Class ;
    rdfs:label "VideoFormat" ;
    rdfs:comment "MemeFormat subclass grouping video-based formats: ViralVideo, ViralDebate, LipDub."@en ;
    rdfs:subClassOf memo:MemeFormat .

memo:WebCulture a owl:Class ;
    rdfs:label "WebCulture" ;
    rdfs:comment "A web-native cultural phenomenon, community, or trend referenced by a meme."@en ;
    rdfs:subClassOf wd:Q96622155 .

memo:captionText a owl:DatatypeProperty ;
    rdfs:label "captionText" ;
    rdfs:domain memo:VariantInstance ;
    rdfs:range xsd:string .

memo:conceptDescription a owl:DatatypeProperty ;
    rdfs:label "conceptDescription" ;
    rdfs:domain memo:MemeIdea ;
    rdfs:range xsd:string .

memo:frbrLevel a owl:AnnotationProperty ;
    rdfs:label "frbrLevel" .

memo:hasId a owl:DatatypeProperty ;
    rdfs:label "hasId" ;
    rdfs:domain memo:MemeConcept ;
    rdfs:range xsd:integer .

memo:hasTextPresence a owl:DatatypeProperty ;
    rdfs:label "hasTextPresence" ;
    rdfs:domain memo:MemeConcept ;
    rdfs:range xsd:boolean .

memo:imageFilePath a owl:DatatypeProperty ;
    rdfs:label "imageFilePath" ;
    rdfs:domain memo:MemeConcept ;
    rdfs:range xsd:string .

memo:imageFilename a owl:DatatypeProperty ;
    rdfs:label "imageFilename" ;
    rdfs:domain memo:MemeConcept ;
    rdfs:range xsd:string .

memo:isColor a owl:DatatypeProperty ;
    rdfs:label "isColor" ;
    rdfs:domain memo:MemeConcept ;
    rdfs:range xsd:boolean .

memo:photoURL a owl:DatatypeProperty ;
    rdfs:label "photoURL" ;
    rdfs:domain memo:VariantInstance ;
    rdfs:range xsd:string .

memo:semanticLevel a owl:AnnotationProperty ;
    rdfs:label "semanticLevel" .

memo:variantFilename a owl:DatatypeProperty ;
    rdfs:label "variantFilename" ;
    rdfs:domain memo:VariantInstance ;
    rdfs:range xsd:string .

memo:variantImageURL a owl:DatatypeProperty ;
    rdfs:label "variantImageURL" ;
    rdfs:domain memo:VariantInstance ;
    rdfs:range xsd:string .

memo:variantIndex a owl:DatatypeProperty ;
    rdfs:label "variantIndex" ;
    rdfs:domain memo:VariantInstance ;
    rdfs:range xsd:integer .

memo:variantTitle a owl:DatatypeProperty ;
    rdfs:label "variantTitle" ;
    rdfs:domain memo:VariantInstance ;
    rdfs:range xsd:string .

memo:variantUploader a owl:DatatypeProperty ;
    rdfs:label "variantUploader" ;
    rdfs:domain memo:VariantInstance ;
    rdfs:range xsd:string .

memo:views a owl:DatatypeProperty ;
    rdfs:label "views" ;
    rdfs:domain memo:MemeConcept ;
    rdfs:range xsd:integer .

schema:Book a owl:Class ;
    rdfs:label "Book" ;
    rdfs:comment "Book, novel or short story from which the meme derives; subclass of wd:Q386724."@en ;
    rdfs:seeAlso <https://www.wikidata.org/wiki/Q571> ;
    rdfs:subClassOf wd:Q386724 .

schema:ComicSeries a owl:Class ;
    rdfs:label "ComicBook" ;
    rdfs:comment "Comic strip, webcomic or graphic novel from which the meme derives; subclass of wd:Q386724."@en ;
    rdfs:seeAlso <https://www.wikidata.org/wiki/Q25379> ;
    rdfs:subClassOf wd:Q386724 .

schema:Movie a owl:Class ;
    rdfs:label "Movie" ;
    rdfs:comment "Film from which the meme derives; subclass of wd:Q386724."@en ;
    rdfs:seeAlso <https://www.wikidata.org/wiki/Q11424> ;
    rdfs:subClassOf wd:Q386724 .

schema:MusicAlbum a owl:Class ;
    rdfs:label "MusicAlbum" ;
    rdfs:comment "Song, album or music video from which the meme derives; subclass of wd:Q386724."@en ;
    rdfs:seeAlso <https://www.wikidata.org/wiki/Q482994> ;
    rdfs:subClassOf wd:Q386724 .

schema:TVSeries a owl:Class ;
    rdfs:label "TvSeries" ;
    rdfs:comment "Television or web series from which the meme derives; subclass of wd:Q386724."@en ;
    rdfs:seeAlso <https://www.wikidata.org/wiki/Q5398426> ;
    rdfs:subClassOf wd:Q386724 .

schema:VideoGame a owl:Class ;
    rdfs:label "VideoGame" ;
    rdfs:comment "Video game from which the meme derives; subclass of wd:Q386724."@en ;
    rdfs:seeAlso <https://www.wikidata.org/wiki/Q7889> ;
    rdfs:subClassOf wd:Q386724 .

schema:image a owl:AnnotationProperty ;
    rdfs:label "image" ;
    rdfs:domain memo:MemeConcept ;
    rdfs:range xsd:string .

schema:keywords a owl:AnnotationProperty ;
    rdfs:label "keywords" ;
    rdfs:domain memo:MemeConcept ;
    rdfs:range xsd:string .

schema:url a owl:AnnotationProperty ;
    rdfs:label "url" ;
    rdfs:domain memo:MemeConcept ;
    rdfs:range xsd:string .

frbrer:C1002 rdfs:label "Work (FRBRer)"@en .

frbrer:C1003 rdfs:label "Expression (FRBRer)"@en .

frbrer:C1004 rdfs:label "Manifestation (FRBRer)"@en .

prov:wasDerivedFrom a owl:ObjectProperty ;
    rdfs:label "wasDerivedFrom" ;
    rdfs:comment "Superproperty of memo:hasOriginWork. Not directly asserted in MEMO — memo:hasOriginWork is used throughout, from which reasoners infer prov:wasDerivedFrom."@en ;
    rdfs:domain memo:MemeConcept ;
    rdfs:range wd:Q386724 .

wd:Q235557 a owl:Class ;
    rdfs:label "FileFormat"@en ;
    rdfs:comment "Digital file format of the meme image resource; aligned with Wikidata Q235557."@en ;
    rdfs:seeAlso <https://www.wikidata.org/wiki/Q235557> .

wdp:P123 a owl:ObjectProperty ;
    rdfs:label "hasOriginPlatform" ;
    rdfs:domain memo:MemeConcept ;
    rdfs:range wd:Q3220391 ;
    owl:inverseOf memo:isOriginPlatformOf .

wdp:P2283 a owl:ObjectProperty ;
    rdfs:label "hasFormat" ;
    rdfs:domain memo:MemeConcept ;
    rdfs:range memo:MemeFormat ;
    owl:inverseOf memo:isFormatOf .

wdp:P2408 a owl:ObjectProperty ;
    rdfs:label "hasTimePeriod" ;
    rdfs:domain memo:MemeConcept ;
    rdfs:range wd:Q11471 ;
    owl:inverseOf memo:isTimePeriodOf .

wdp:P361 a owl:ObjectProperty ;
    rdfs:label "isVariantOf" ;
    rdfs:domain memo:VariantInstance ;
    rdfs:range memo:MemeConcept ;
    owl:inverseOf wdp:P527 .

wdp:P495 a owl:ObjectProperty ;
    rdfs:label "hasRegion" ;
    rdfs:domain memo:MemeConcept ;
    rdfs:range wd:Q82794 ;
    owl:inverseOf memo:isRegionOf .

wdp:P527 a owl:ObjectProperty ;
    rdfs:label "hasVariant" ;
    rdfs:domain memo:MemeConcept ;
    rdfs:range memo:VariantInstance ;
    owl:inverseOf wdp:P361 .

memo:conceptualizes a owl:ObjectProperty ;
    rdfs:label "conceptualizes" ;
    rdfs:domain memo:MemeConcept ;
    rdfs:range memo:MemeIdea ;
    owl:inverseOf memo:isConceptualizedAs .

memo:hasAnimationStatus a owl:ObjectProperty ;
    rdfs:label "hasAnimationStatus" ;
    rdfs:domain memo:MemeConcept ;
    rdfs:range memo:AnimationStatus ;
    owl:inverseOf memo:isAnimationStatusOf .

memo:hasImageType a owl:ObjectProperty ;
    rdfs:label "hasImageType" ;
    rdfs:domain [ a owl:Class ;
            owl:unionOf ( memo:MemeConcept memo:VariantInstance ) ] ;
    rdfs:range memo:ImageType ;
    owl:inverseOf memo:isImageTypeOf .

memo:hasOriginWork a owl:ObjectProperty ;
    rdfs:label "hasOriginWork" ;
    rdfs:domain memo:MemeConcept ;
    rdfs:range wd:Q386724 ;
    rdfs:subPropertyOf prov:wasDerivedFrom ;
    owl:inverseOf memo:isOriginWorkOf .

memo:hasReference a owl:ObjectProperty ;
    rdfs:label "hasReference" ;
    rdfs:domain memo:MemeConcept ;
    rdfs:range wd:Q96622155 ;
    owl:inverseOf memo:isReferencedIn .

memo:hasSubjectMatter a owl:ObjectProperty ;
    rdfs:label "hasSubjectMatter" ;
    rdfs:domain [ a owl:Class ;
            owl:unionOf ( memo:MemeConcept memo:VariantInstance ) ] ;
    rdfs:range memo:SubjectMatter ;
    owl:inverseOf memo:isSubjectMatterOf .

memo:hasTransformationDimension a owl:ObjectProperty ;
    rdfs:label "hasTransformationDimension" ;
    rdfs:domain memo:VariantInstance ;
    rdfs:range memo:TransformationDimension ;
    owl:inverseOf memo:isTransformationDimensionOf .

memo:hasTransformationExtent a owl:ObjectProperty ;
    rdfs:label "hasTransformationExtent" ;
    rdfs:domain memo:VariantInstance ;
    rdfs:range memo:TransformationExtent ;
    owl:inverseOf memo:isTransformationExtentOf .

memo:isAnimationStatusOf a owl:ObjectProperty ;
    rdfs:label "isAnimationStatusOf" ;
    rdfs:domain memo:AnimationStatus ;
    rdfs:range memo:MemeConcept ;
    owl:inverseOf memo:hasAnimationStatus .

memo:isConceptualizedAs a owl:ObjectProperty ;
    rdfs:label "isConceptualizedAs" ;
    rdfs:domain memo:MemeIdea ;
    rdfs:range memo:MemeConcept ;
    owl:inverseOf memo:conceptualizes .

memo:isFormatOf a owl:ObjectProperty ;
    rdfs:label "isFormatOf" ;
    rdfs:domain memo:MemeFormat ;
    rdfs:range memo:MemeConcept ;
    owl:inverseOf wdp:P2283 .

memo:isImageTypeOf a owl:ObjectProperty ;
    rdfs:label "isImageTypeOf" ;
    rdfs:domain memo:ImageType ;
    rdfs:range [ a owl:Class ;
            owl:unionOf ( memo:MemeConcept memo:VariantInstance ) ] ;
    owl:inverseOf memo:hasImageType .

memo:isOriginPlatformOf a owl:ObjectProperty ;
    rdfs:label "isOriginPlatformOf" ;
    rdfs:domain wd:Q3220391 ;
    rdfs:range memo:MemeConcept ;
    owl:inverseOf wdp:P123 .

memo:isOriginWorkOf a owl:ObjectProperty ;
    rdfs:label "isOriginWorkOf" ;
    rdfs:domain wd:Q386724 ;
    rdfs:range memo:MemeConcept ;
    owl:inverseOf memo:hasOriginWork .

memo:isReferencedIn a owl:ObjectProperty ;
    rdfs:label "isReferencedIn" ;
    rdfs:domain wd:Q96622155 ;
    rdfs:range memo:MemeConcept ;
    owl:inverseOf memo:hasReference .

memo:isRegionOf a owl:ObjectProperty ;
    rdfs:label "isRegionOf" ;
    rdfs:domain wd:Q82794 ;
    rdfs:range memo:MemeConcept ;
    owl:inverseOf wdp:P495 .

memo:isSubjectMatterOf a owl:ObjectProperty ;
    rdfs:label "isSubjectMatterOf" ;
    rdfs:domain memo:SubjectMatter ;
    rdfs:range [ a owl:Class ;
            owl:unionOf ( memo:MemeConcept memo:VariantInstance ) ] ;
    owl:inverseOf memo:hasSubjectMatter .

memo:isTimePeriodOf a owl:ObjectProperty ;
    rdfs:label "isTimePeriodOf" ;
    rdfs:domain wd:Q11471 ;
    rdfs:range memo:MemeConcept ;
    owl:inverseOf wdp:P2408 .

memo:isTransformationDimensionOf a owl:ObjectProperty ;
    rdfs:label "isTransformationDimensionOf" ;
    rdfs:domain memo:TransformationDimension ;
    rdfs:range memo:VariantInstance ;
    owl:inverseOf memo:hasTransformationDimension .

memo:isTransformationExtentOf a owl:ObjectProperty ;
    rdfs:label "isTransformationExtentOf" ;
    rdfs:domain memo:TransformationExtent ;
    rdfs:range memo:VariantInstance ;
    owl:inverseOf memo:hasTransformationExtent .

wd:Q11471 a owl:Class ;
    rdfs:label "TimePeriod"@en ;
    rdfs:comment "Chronological period in which the meme originated or peaked; aligned with Wikidata Q11471."@en ;
    rdfs:seeAlso <https://www.wikidata.org/wiki/Q11471> .

wd:Q3220391 a owl:Class ;
    rdfs:label "OriginPlatform"@en ;
    rdfs:comment "Online platform or service where the meme was first published; aligned with Wikidata Q3220391."@en ;
    rdfs:seeAlso <https://www.wikidata.org/wiki/Q3220391> .

wd:Q82794 a owl:Class ;
    rdfs:label "GeographicRegion"@en ;
    rdfs:comment "Geographic region or country of meme origin; aligned with Wikidata Q82794."@en ;
    rdfs:seeAlso <https://www.wikidata.org/wiki/Q82794> .

memo:AnimationStatus a owl:Class ;
    rdfs:label "AnimationStatus" ;
    rdfs:comment "Whether a meme image is animated (Animated, i.e. a GIF) or static (Static). Derived from file extension."@en ;
    memo:semanticLevel "PreIconographical" .

memo:ImageType a owl:Class ;
    rdfs:label "ImageType" ;
    rdfs:comment "The visual medium or rendering technique of a meme image (e.g. Photograph, Drawing, Cartoon). Corresponds to Panofsky's pre-iconographic description."@en ;
    memo:semanticLevel "PreIconographical" .

memo:SubjectMatter a owl:Class ;
    rdfs:label "SubjectMatter" ;
    rdfs:comment "The primary visual subject category depicted in a meme image (e.g. PersonPresent, AnimalPresent, ObjectOnly). Corresponds to Panofsky's pre-iconographic description level."@en ;
    memo:semanticLevel "PreIconographical" .

memo:TransformationDimension a owl:Class ;
    rdfs:label "TransformationDimension" ;
    rdfs:comment "The primary dimension along which a VariantInstance transforms the source template (e.g. textual, visual, contextual). Enables typological analysis of meme variation."@en .

memo:TransformationExtent a owl:Class ;
    rdfs:label "TransformationExtent" ;
    rdfs:comment "The degree to which a VariantInstance diverges from its source template (e.g. Minimal, Moderate, Major). Enables quantitative analysis of meme mutation."@en .

memo:MemeIdea a owl:Class ;
    rdfs:label "MemeIdea" ;
    rdfs:comment "The abstract creative idea underlying a meme template; the Work level of the FRBR hierarchy. Represents the core concept, emotional register, or rhetorical function of a meme, independent of any specific image or format."@en ;
    rdfs:subClassOf frbrer:C1002 ;
    memo:frbrLevel "Work" .

wd:Q96622155 a owl:Class ;
    rdfs:label "CulturalReference"@en ;
    rdfs:comment "Cultural artefact, event, or phenomenon that a meme iconologically references; aligned with Wikidata Q96622155."@en ;
    rdfs:seeAlso <https://www.wikidata.org/wiki/Q96622155> ;
    memo:semanticLevel "Iconological" .

memo:MemeFormat a owl:Class ;
    rdfs:label "MemeFormat" ;
    rdfs:comment "The genre or structural format of a meme (e.g. ImageMacro, Copypasta, ViralVideo). Drawn from Know Your Meme's type taxonomy."@en ;
    memo:semanticLevel "Iconographical" .

wd:Q386724 a owl:Class ;
    rdfs:label "OriginWork"@en ;
    rdfs:comment "Creative work (film, TV series, game, etc.) from which the meme derives; aligned with Wikidata Q386724."@en ;
    rdfs:seeAlso <https://www.wikidata.org/wiki/Q386724> .

memo:VariantInstance a owl:Class ;
    rdfs:label "VariantInstance" ;
    rdfs:comment "A specific image derived from a meme template; the Manifestation level of the FRBR hierarchy. Represents a single scraped or documented instantiation of a MemeConcept."@en ;
    rdfs:subClassOf frbrer:C1004 ;
    memo:frbrLevel "Manifestation" .

memo:MemeConcept a owl:Class ;
    rdfs:label "MemeConcept" ;
    rdfs:comment "A meme template or canonical format; the Expression level of the FRBR hierarchy. Represents the stable, recognisable form of a meme as documented on Know Your Meme."@en ;
    rdfs:subClassOf frbrer:C1003 ;
    memo:frbrLevel "Expression" .

