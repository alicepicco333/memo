dc:creator a owl:AnnotationProperty .

dc:description a owl:AnnotationProperty .

dc:rights a owl:AnnotationProperty .

dcterms:created a owl:AnnotationProperty .

<http://www.semanticweb.org/meme-ontology> a owl:Ontology ;
    rdfs:label "Meme Ontology (MEMO)"@en ;
    dc:creator "Meme Ontology Project" ;
    dc:description """The Meme Ontology (MEMO) is an ontology for the formal description of internet memes. It models meme templates\r
(MemeConcept), their underlying creative ideas (MemeIdea), and scraped variant\r
images (VariantInstance) using a FRBR-aligned four-level abstraction hierarchy\r
and Panofsky's three levels of semantic analysis. Value classes provide\r
controlled vocabularies for format, platform, image type, transformation extent\r
and dimension, and other classifiers. 5,000 meme concepts, 50 enriched meme\r
ideas and 391 variant instances are included as named individuals."""@en ;
    dc:rights """Released for academic research. Data sourced from\r
Know Your Meme under fair use."""@en ;
    dcterms:created "2024"^^xsd:gYear ;
    rdfs:comment "Patch v2: adds frbrLevel/semanticLevel/documentaryLevel annotations to all classes, fixes naming inconsistencies (Conspiracy_Theory, Fan_Labor, Lip_Dub, hasId, photoId, imageFilename), and adds renamed property declarations with deprecation notices on old names." ;
    rdfs:seeAlso <https://github.com/meme-ontology/meme-ontology> ;
    owl:versionInfo "1.0" .

