memo:hasFormat a owl:ObjectProperty ;
    rdfs:label "hasFormat" ;
    memo:frbrLevel "Expression" ;
    memo:semanticLevel "Iconographical" ;
    rdfs:comment """Links a MemeConcept to one or more MemeFormat\r\r\r\r\r\r
values describing its rhetorical structure."""@en ;
    rdfs:domain memo:MemeConcept ;
    rdfs:range memo:MemeFormat .

memo:hasId a owl:DatatypeProperty ;
    rdfs:label "has ID"@en ;
    rdfs:comment """Numeric identifier matching the meme's position\r\r\r\r\r\r
in the scraped dataset (1–5000)."""@en ;
    rdfs:domain memo:MemeConcept ;
    rdfs:range xsd:integer ;
    owl:deprecated true .

memo:hasImageType a owl:ObjectProperty ;
    rdfs:label "hasImageType" ;
    rdfs:domain memo:VariantInstance ;
    rdfs:range memo:ImageType .

memo:hasOriginBoard a owl:ObjectProperty ;
    rdfs:label "hasOriginBoard" ;
    memo:documentaryLevel "true" ;
    memo:frbrLevel "Expression" ;
    rdfs:comment """Links a MemeConcept to the specific imageboard\r\r\r\r\r\r
or forum thread where it originated."""@en ;
    rdfs:domain memo:MemeConcept ;
    rdfs:range memo:OriginBoard .

