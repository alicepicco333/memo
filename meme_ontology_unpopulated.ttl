memo:captionText a owl:DatatypeProperty ;
    rdfs:label "captionText" ;
    rdfs:domain memo:VariantInstance ;
    rdfs:range xsd:string .

memo:conceptDescription a owl:DatatypeProperty ;
    rdfs:label "conceptDescription" ;
    rdfs:domain memo:MemeIdea ;
    rdfs:range xsd:string .

memo:description a owl:DatatypeProperty ;
    rdfs:label "description" ;
    rdfs:domain memo:MemeConcept ;
    rdfs:range xsd:string .

memo:hasId a owl:DatatypeProperty ;
    rdfs:label "hasId"@en ;
    rdfs:comment """Numeric identifier matching the meme's position\r\r\r\r\r\r
in the scraped dataset (1–5000)."""@en ;
    rdfs:domain memo:MemeConcept ;
    rdfs:range xsd:integer ;
    owl:deprecated true .

memo:hasVariantColorMode a owl:ObjectProperty ;
    rdfs:label "hasVariantColorMode" ;
    rdfs:comment "The specific color profile applied to a user-created variant." ;
    rdfs:domain memo:VariantInstance ;
    rdfs:range memo:ColorMode ;
    owl:inverseOf memo:isVariantColorModeOf .

memo:hasVariantImageType a owl:ObjectProperty ;
    rdfs:label "hasVariantImageType" ;
    rdfs:comment "The specific image type of a user-created variant." ;
    rdfs:domain memo:VariantInstance ;
    rdfs:range memo:ImageType ;
    owl:inverseOf memo:isVariantImageTypeOf .

memo:hasVariantSubjectMatter a owl:ObjectProperty ;
    rdfs:label "hasVariantSubjectMatter" ;
    rdfs:comment "What a specific user added or changed when they created their individual variation (Manifestation/Item level)." ;
    rdfs:domain memo:VariantInstance ;
    rdfs:range memo:SubjectMatter .

memo:hasVariantTextPresence a owl:ObjectProperty ;
    rdfs:label "hasVariantTextPresence" ;
    rdfs:comment "Whether a user-created variant includes text or not." ;
    rdfs:domain memo:VariantInstance ;
    rdfs:range memo:TextPresence ;
    owl:inverseOf memo:isVariantTextPresenceOf .

