    rdfs:label "OriginFilm" ;
    rdfs:subClassOf memo:OriginWork .

memo:OriginMusic a owl:Class ;
    rdfs:label "OriginMusic" ;
    rdfs:subClassOf memo:OriginWork .

memo:OriginPerson a owl:Class ;
    rdfs:label "OriginPerson" ;
    rdfs:subClassOf memo:OriginWork .

memo:OriginTVShow a owl:Class ;
    rdfs:label "OriginTVShow" ;
    rdfs:subClassOf memo:OriginWork .

memo:OriginVideoGame a owl:Class ;
    rdfs:label "OriginVideoGame" ;
    rdfs:subClassOf memo:OriginWork .

memo:Static a owl:Class ;
    rdfs:label "Static" ;
    rdfs:subClassOf memo:AnimationStatus .

memo:Iconographical rdfs:label "Iconographical" .

memo:Iconological rdfs:label "Iconological" .

memo:MemeIdea a owl:Class ;
    rdfs:label "Meme Idea",
        "Meme Idea"@en ;
    memo:frbrLevel "Work" ;
    rdfs:comment "The abstract cultural concept underlying a named meme template. Work-level class. Populated manually for D0 subset via conceptDescription data property. Has no visual properties — only the pure abstract idea.",
        """The abstract Work-level idea underlying a memo:\r\r
its core narrative, emotional register, rhetorical function or cultural role,\r\r
independent of any specific image or format. 50 enriched individuals from the\r\r
D0 sample, with descriptions and cultural reference annotations."""@en ;
    rdfs:subClassOf owl:Thing .

memo:PreIconographical rdfs:label "Pre Iconographical" .

memo:AnimationStatus a owl:Class ;
    rdfs:label "Animation Status",
        "AnimationStatus",
        "Animation Status"@en ;
    memo:documentaryLevel "true" ;
    memo:frbrLevel "Item" ;
    rdfs:comment """Whether a meme image is static or animated\r\r
(GIF/video)."""@en ;
    rdfs:subClassOf owl:Thing .

memo:CanonicalColorMode a owl:Class ;
    rdfs:label "Canonical Color Mode",
        "CanonicalColorMode",
        "Canonical Color Mode"@en ;
    memo:frbrLevel "Expression" ;
    memo:semanticLevel "PreIconographical" ;
    rdfs:comment """Whether the canonical meme image is in colour or\r\r
monochrome."""@en ;
    rdfs:subClassOf owl:Thing .

memo:CanonicalTextPresence a owl:Class ;
    rdfs:label "Canonical Text Presence",
        "CanonicalTextPresence",
        "Canonical Text Presence"@en ;
    memo:frbrLevel "Expression" ;
    memo:semanticLevel "PreIconographical" ;
    rdfs:comment """Whether the canonical meme image contains\r\r
overlaid text."""@en ;
    rdfs:subClassOf owl:Thing .

memo:ColorMode a owl:Class ;
    rdfs:label "ColorMode" ;
    memo:frbrLevel "Manifestation" ;
    memo:semanticLevel "PreIconographical" ;
    rdfs:subClassOf owl:Thing .

memo:Expression rdfs:label "Expression" .

memo:GIF a owl:Class ;
    rdfs:label "GIF" ;
    rdfs:subClassOf memo:FileFormat .

memo:Item rdfs:label "Item" .

memo:JPEG a owl:Class ;
    rdfs:label "JPEG" ;
    rdfs:subClassOf memo:FileFormat .

memo:Manifestation rdfs:label "Manifestation" .

memo:Minimal a owl:Class ;
    rdfs:label "Minimal" ;
    rdfs:subClassOf memo:TransformationExtent .

memo:Moderate a owl:Class ;
    rdfs:label "Moderate" ;
    rdfs:subClassOf memo:TransformationExtent .

memo:PNG a owl:Class ;
    rdfs:label "PNG" ;
    rdfs:subClassOf memo:FileFormat .

memo:Parody a owl:Class ;
    rdfs:label "Parody" ;
    rdfs:subClassOf memo:TransformationExtent .

memo:Substantial a owl:Class ;
    rdfs:label "Substantial" ;
    rdfs:subClassOf memo:TransformationExtent .

memo:TextPresence a owl:Class ;
    rdfs:label "TextPresence" ;
    memo:frbrLevel "Manifestation" ;
    memo:semanticLevel "PreIconographical" ;
    rdfs:subClassOf owl:Thing .

memo:WebP a owl:Class ;
    rdfs:label "WebP" ;
    rdfs:subClassOf memo:FileFormat .

memo:Work rdfs:label "Work" .

memo:Cartoon a owl:Class ;
    rdfs:label "Cartoon" ;
    rdfs:subClassOf memo:ImageType .

memo:Drawing a owl:Class ;
    rdfs:label "Drawing" ;
    rdfs:subClassOf memo:ImageType .

memo:Illustration a owl:Class ;
    rdfs:label "Illustration" ;
    rdfs:subClassOf memo:ImageType .

memo:Painting a owl:Class ;
    rdfs:label "Painting" ;
    rdfs:subClassOf memo:ImageType .

memo:Photograph a owl:Class ;
    rdfs:label "Photograph" ;
    rdfs:subClassOf memo:ImageType .

memo:TransformationExtent a owl:Class ;
    rdfs:label "Transformation Extent",
        "TransformationExtent",
        "Transformation Extent"@en ;
    memo:documentaryLevel "true" ;
    memo:frbrLevel "Manifestation" ;
    rdfs:comment "The overall degree of transformation from the canonical Expression. Single-valued.",
        """The degree to which a variant departs from the\r\r
canonical template: Minimal (close copy), Moderate, Substantial, or Parody\r\r
(radical departure)."""@en ;
    rdfs:subClassOf owl:Thing .

memo:CanonicalImageType a owl:Class ;
    rdfs:label "Canonical Image Type",
        "CanonicalImageType",
        "Canonical Image Type"@en ;
    memo:frbrLevel "Expression" ;
    memo:semanticLevel "PreIconographical" ;
    rdfs:comment "The canonical visual medium of the named template as derived from the representative image via CLIP. Property of the Expression-level MemeConcept.",
        """The visual medium of the canonical meme image\r\r
(Photograph, Drawing, Cartoon, Illustration, Painting, etc.). Pre-iconographical\r\r
classification at the Manifestation level, assigned via CLIP-based scoring."""@en ;
    rdfs:subClassOf owl:Thing .

memo:FileFormat a owl:Class ;
    rdfs:label "File Format",
        "FileFormat",
        "File Format"@en ;
    memo:documentaryLevel "true" ;
    memo:frbrLevel "Item" ;
    rdfs:comment """The digital file format of the meme image (JPEG,\r\r
PNG, GIF, WebP, BMP)."""@en ;
    rdfs:subClassOf owl:Thing .

memo:ImageType a owl:Class ;
    rdfs:label "Image Type",
        "ImageType",
        "Image Type"@en ;
    memo:frbrLevel "Manifestation" ;
    memo:semanticLevel "PreIconographical" ;
    rdfs:comment "The visual medium of a specific variant image. Manifestation-level property on VariantInstance.",
        """The visual medium type of an individual variant\r\r
image. Uses the same controlled vocabulary as CanonicalImageType but applied at\r\r
the Item (VariantInstance) level."""@en ;
    rdfs:subClassOf owl:Thing .

memo:TimePeriod a owl:Class ;
    rdfs:label "Time Period",
        "TimePeriod",
        "Time Period"@en ;
    memo:documentaryLevel "true" ;
    memo:frbrLevel "Expression" ;
    rdfs:comment """The era in which a meme originated or peaked\r\r
(Pre2010, Period2010to2015, Period2016to2020, Period2021toPresent)."""@en ;
    rdfs:subClassOf owl:Thing .

memo:CulturalReference a owl:Class ;
    rdfs:label "Cultural Reference",
        "CulturalReference",
        "Cultural Reference"@en ;
    memo:frbrLevel "Expression Manifestation",
        "Expression, Manifestation" ;
    memo:semanticLevel "Iconological" ;
    rdfs:comment "The cultural phenomena encoded by a meme template. At Expression level: template-wide references. At Manifestation level: variant-specific references.",
        """A cultural entity referenced by a meme — a historical\r\r
event, media property, political event, public figure, social phenomenon, or web\r\r
culture artefact. Subclasses: HistoricalEvent, MediaProperty, PoliticalEvent,\r\r
PublicFigure, SocialPhenomenon, WebCulture."""@en ;
    rdfs:subClassOf owl:Thing .

memo:AnimalPresent a owl:Class ;
    rdfs:label "AnimalPresent" ;
    rdfs:subClassOf memo:SubjectMatter .

memo:CanonicalSubjectMatter a owl:Class ;
    rdfs:label "Canonical Subject Matter",
        "CanonicalSubjectMatter",
        "Canonical Subject Matter"@en ;
    memo:frbrLevel "Expression" ;
    memo:semanticLevel "PreIconographical" ;
    rdfs:comment """The category of subjects depicted in the\r\r
canonical image (PersonPresent, AnimalPresent, ObjectOnly, TextOnly,\r\r
MultipleSubjects, etc.)."""@en ;
    rdfs:subClassOf owl:Thing .

memo:CharacterPresent a owl:Class ;
    rdfs:label "CharacterPresent" ;
    rdfs:subClassOf memo:SubjectMatter .

memo:MultipleSubjects a owl:Class ;
    rdfs:label "MultipleSubjects" ;
    rdfs:subClassOf memo:SubjectMatter .

memo:NoPerson rdfs:label "No Person" .

memo:ObjectOnly a owl:Class ;
    rdfs:label "ObjectOnly" ;
    rdfs:subClassOf memo:SubjectMatter .

memo:PersonPresent a owl:Class ;
    rdfs:label "PersonPresent" ;
    rdfs:subClassOf memo:SubjectMatter .

memo:PublicFigure a owl:Class ;
    rdfs:label "PublicFigure" ;
    rdfs:subClassOf memo:CulturalReference .

memo:SubjectMatter a owl:Class ;
    rdfs:label "SubjectMatter" ;
    memo:frbrLevel "Manifestation" ;
    memo:semanticLevel "PreIconographical" ;
    rdfs:subClassOf owl:Thing .

memo:TextOnly a owl:Class ;
    rdfs:label "TextOnly" ;
    rdfs:comment "SubjectMatter: TextOnly — image whose primary visible content is text with no person, character or animal present. Distinct from CaptionChange TransformationDimension." ;
    rdfs:subClassOf memo:SubjectMatter .

memo:UnknownPerson rdfs:label "Unknown Person" .

memo:OriginWork a owl:Class ;
    rdfs:label "Origin Work",
        "OriginWork",
        "Origin Work"@en ;
    memo:documentaryLevel "true" ;
    memo:frbrLevel "Expression" ;
    rdfs:comment "A cultural text (film, game, TV show etc.) that is the origin of the meme template. Documentary fact.",
        """The original cultural work (film, TV show, video\r\r
game, book, song, etc.) from which a meme derives its source material."""@en ;
    rdfs:subClassOf owl:Thing .

memo:TransformationDimension a owl:Class ;
    rdfs:label "Transformation Dimension",
        "TransformationDimension",
        "Transformation Dimension"@en ;
    memo:documentaryLevel "true" ;
    memo:frbrLevel "Manifestation" ;
    rdfs:comment "The specific aspect of the canonical template that changes in a variant. Multi-valued.",
        """The axis along which a variant transforms the\r\r
canonical template: CaptionChange, VisualSubstrate, MediumShift, StyleShift,\r\r
CompositionShift, CrossoverMerge, LanguageShift, Localization."""@en ;
    rdfs:subClassOf owl:Thing .

memo:GeographicRegion a owl:Class ;
    rdfs:label "Geographic Region",
        "GeographicRegion",
        "Geographic Region"@en ;
    memo:documentaryLevel "true" ;
    memo:frbrLevel "Expression" ;
    rdfs:comment """The country or geographic region of a meme's\r\r
origin."""@en ;
    rdfs:subClassOf owl:Thing .

memo:VariantInstance a owl:Class ;
    rdfs:label "Variant Instance",
        "Variant Instance"@en ;
    memo:frbrLevel "Manifestation" ;
    rdfs:comment "A specific physical variant realization of a named meme template. Manifestation-level class. 391 individuals populated from D0 variant scraping.",
        """A single scraped variant image — an Item-level\r\r
exemplar of a MemeConcept. 391 named individuals with transformation extent and\r\r
dimension annotations for 5 fully annotated meme templates."""@en ;
    rdfs:subClassOf owl:Thing .

memo:OriginPlatform a owl:Class ;
    rdfs:label "Origin Platform",
        "Origin Platform"@en ;
    memo:documentaryLevel "true" ;
    memo:frbrLevel "Expression" ;
    rdfs:comment "The social platform where the meme template first emerged. Documentary fact scraped from KnowYourMeme origin field.",
        """The online platform where a meme first appeared\r\r
or gained traction (e.g. Reddit, Twitter/X, 4chan, TikTok). Classified at the\r\r
Expression level with Documentary provenance."""@en ;
    rdfs:subClassOf owl:Thing .

memo:MemeFormat a owl:Class ;
    rdfs:label "Meme Format",
        "MemeFormat",
        "Meme Format"@en ;
    memo:frbrLevel "Expression" ;
    memo:semanticLevel "Iconographical" ;
    rdfs:comment "The cultural format type of the meme template. Controlled vocabulary derived from KnowYourMeme type field.",
        """The rhetorical or structural format of a meme\r\r
(e.g. ImageMacro, Catchphrase, Exploitable, Reaction, ViralVideo). Classifies\r\r
memes at the Expression level with Iconographical analysis."""@en ;
    rdfs:subClassOf owl:Thing .

memo:MemeConcept a owl:Class ;
    rdfs:label "Meme Concept",
        "Meme Template",
        "Meme Concept"@en ;
    memo:frbrLevel "Expression" ;
    rdfs:comment "The named and documented meme template as recognized by the KnowYourMeme community. Primary individual class of the ontology. 5000 individuals populated from KnowYourMeme entries.",
        """A canonical internet meme template as indexed\r\r
on Know Your Meme. Represents the stable, Expression-level identity of a meme\r\r
across all its variants. 5,000 named individuals are included, classified by\r\r
image type, format, platform, region and time period."""@en ;
    rdfs:subClassOf owl:Thing .

