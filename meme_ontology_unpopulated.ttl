@prefix dc: <http://purl.org/dc/elements/1.1/> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

dcterms:created a owl:AnnotationProperty ;
    rdfs:label "created" ;
    rdfs:domain <https://purl.org/memo#MemeConcept> ;
    rdfs:range xsd:integer .

dcterms:description a owl:AnnotationProperty ;
    rdfs:label "description" ;
    rdfs:domain <https://purl.org/memo#MemeConcept> ;
    rdfs:range xsd:string .

dcterms:format a owl:ObjectProperty ;
    rdfs:label "format" ;
    rdfs:domain <https://purl.org/memo#MemeConcept> ;
    rdfs:range <http://www.wikidata.org/entity/Q235557> .

dcterms:modified a owl:AnnotationProperty ;
    rdfs:label "modified" ;
    rdfs:domain <https://purl.org/memo#MemeConcept> ;
    rdfs:range xsd:string .

<http://schema.org/image> a owl:AnnotationProperty ;
    rdfs:label "image" ;
    rdfs:domain <https://purl.org/memo#MemeConcept> ;
    rdfs:range xsd:string .

<http://schema.org/keywords> a owl:AnnotationProperty ;
    rdfs:label "keywords" ;
    rdfs:domain <https://purl.org/memo#MemeConcept> ;
    rdfs:range xsd:string .

<http://schema.org/url> a owl:AnnotationProperty ;
    rdfs:label "url" ;
    rdfs:domain <https://purl.org/memo#MemeConcept> ;
    rdfs:range xsd:string .

<https://purl.org/memo> a owl:Ontology ;
    dc:creator "Alice Picco" ;
    dcterms:license <https://creativecommons.org/licenses/by/4.0/> ;
    dcterms:title "The Meme Ontology (MEMO)"@en ;
    owl:versionInfo "1.0" .

<https://purl.org/memo#HistoricalEvent> a owl:Class ;
    rdfs:label "HistoricalEvent" ;
    rdfs:comment "A historical event, period, or crisis referenced by a meme."@en ;
    rdfs:subClassOf <http://www.wikidata.org/entity/Q96622155> .

<https://purl.org/memo#MediaProperty> a owl:Class ;
    rdfs:label "MediaProperty" ;
    rdfs:comment "A media franchise, film, TV series, game, or other creative property referenced by a meme."@en ;
    rdfs:subClassOf <http://www.wikidata.org/entity/Q96622155> .

<https://purl.org/memo#PoliticalEvent> a owl:Class ;
    rdfs:label "PoliticalEvent" ;
    rdfs:comment "A political event, controversy, or campaign that a meme iconologically references."@en ;
    rdfs:subClassOf <http://www.wikidata.org/entity/Q96622155> .

<https://purl.org/memo#PublicFigure> a owl:Class ;
    rdfs:label "PublicFigure" ;
    rdfs:comment "A public figure, celebrity, politician, or historical person referenced by a meme."@en ;
    rdfs:subClassOf <http://www.wikidata.org/entity/Q96622155> .

<https://purl.org/memo#SocialPhenomenon> a owl:Class ;
    rdfs:label "SocialPhenomenon" ;
    rdfs:comment "A social movement, behavioural trend, or cultural practice referenced by a meme."@en ;
    rdfs:subClassOf <http://www.wikidata.org/entity/Q96622155> .

<https://purl.org/memo#WebCulture> a owl:Class ;
    rdfs:label "WebCulture" ;
    rdfs:comment "A web-native cultural phenomenon, community, or trend referenced by a meme."@en ;
    rdfs:subClassOf <http://www.wikidata.org/entity/Q96622155> .

<https://purl.org/memo#captionText> a owl:DatatypeProperty ;
    rdfs:label "captionText" ;
    rdfs:domain <https://purl.org/memo#VariantInstance> ;
    rdfs:range xsd:string .

<https://purl.org/memo#clipImageTypeScore> a owl:DatatypeProperty ;
    rdfs:label "clipImageTypeScore" ;
    rdfs:domain <https://purl.org/memo#MemeConcept> ;
    rdfs:range xsd:float .

<https://purl.org/memo#clipPublicFigureScore> a owl:DatatypeProperty ;
    rdfs:label "clipPublicFigureScore" ;
    rdfs:domain <https://purl.org/memo#MemeConcept> ;
    rdfs:range xsd:float .

<https://purl.org/memo#clipTextScore> a owl:DatatypeProperty ;
    rdfs:label "clipTextScore" ;
    rdfs:domain <https://purl.org/memo#MemeConcept> ;
    rdfs:range xsd:float .

<https://purl.org/memo#conceptDescription> a owl:DatatypeProperty ;
    rdfs:label "conceptDescription" ;
    rdfs:domain <http://www.wikidata.org/entity/Q3249551> ;
    rdfs:range xsd:string .

<https://purl.org/memo#hasId> a owl:DatatypeProperty ;
    rdfs:label "hasId" ;
    rdfs:domain <https://purl.org/memo#MemeConcept> ;
    rdfs:range xsd:integer .

<https://purl.org/memo#imageFilePath> a owl:DatatypeProperty ;
    rdfs:label "imageFilePath" ;
    rdfs:domain <https://purl.org/memo#MemeConcept> ;
    rdfs:range xsd:string .

<https://purl.org/memo#imageFilename> a owl:DatatypeProperty ;
    rdfs:label "imageFilename" ;
    rdfs:domain <https://purl.org/memo#MemeConcept> ;
    rdfs:range xsd:string .

<https://purl.org/memo#photoURL> a owl:DatatypeProperty ;
    rdfs:label "photoURL" ;
    rdfs:domain <https://purl.org/memo#VariantInstance> ;
    rdfs:range xsd:string .

<https://purl.org/memo#variantFilename> a owl:DatatypeProperty ;
    rdfs:label "variantFilename" ;
    rdfs:domain <https://purl.org/memo#VariantInstance> ;
    rdfs:range xsd:string .

<https://purl.org/memo#variantImageURL> a owl:DatatypeProperty ;
    rdfs:label "variantImageURL" ;
    rdfs:domain <https://purl.org/memo#VariantInstance> ;
    rdfs:range xsd:string .

<https://purl.org/memo#variantIndex> a owl:DatatypeProperty ;
    rdfs:label "variantIndex" ;
    rdfs:domain <https://purl.org/memo#VariantInstance> ;
    rdfs:range xsd:integer .

<https://purl.org/memo#variantTitle> a owl:DatatypeProperty ;
    rdfs:label "variantTitle" ;
    rdfs:domain <https://purl.org/memo#VariantInstance> ;
    rdfs:range xsd:string .

<https://purl.org/memo#variantUploader> a owl:DatatypeProperty ;
    rdfs:label "variantUploader" ;
    rdfs:domain <https://purl.org/memo#VariantInstance> ;
    rdfs:range xsd:string .

<https://purl.org/memo#views> a owl:DatatypeProperty ;
    rdfs:label "views" ;
    rdfs:domain <https://purl.org/memo#MemeConcept> ;
    rdfs:range xsd:integer .

prov:wasDerivedFrom a owl:ObjectProperty ;
    rdfs:label "wasDerivedFrom" ;
    rdfs:domain <https://purl.org/memo#MemeConcept> ;
    rdfs:range <http://www.wikidata.org/entity/Q386724> .

<http://www.wikidata.org/entity/Q235557> a owl:Class ;
    rdfs:label "FileFormat" ;
    rdfs:comment "Digital file format of the meme image resource, as defined by Wikidata Q235557."@en ;
    rdfs:seeAlso <https://www.wikidata.org/wiki/Q235557> .

<http://www.wikidata.org/prop/direct/P123> a owl:ObjectProperty ;
    rdfs:label "hasOriginPlatform" ;
    rdfs:domain <https://purl.org/memo#MemeConcept> ;
    rdfs:range <http://www.wikidata.org/entity/Q3220391> ;
    owl:inverseOf <https://purl.org/memo#isOriginPlatformOf> .

<http://www.wikidata.org/prop/direct/P2283> a owl:ObjectProperty ;
    rdfs:label "hasFormat" ;
    rdfs:domain <https://purl.org/memo#MemeConcept> ;
    rdfs:range <https://purl.org/memo#MemeFormat> ;
    owl:inverseOf <https://purl.org/memo#isFormatOf> .

<http://www.wikidata.org/prop/direct/P2408> a owl:ObjectProperty ;
    rdfs:label "hasTimePeriod" ;
    rdfs:domain <https://purl.org/memo#MemeConcept> ;
    rdfs:range <http://www.wikidata.org/entity/Q11471> ;
    owl:inverseOf <https://purl.org/memo#isTimePeriodOf> .

<http://www.wikidata.org/prop/direct/P361> a owl:ObjectProperty ;
    rdfs:label "isVariantOf" ;
    rdfs:domain <https://purl.org/memo#VariantInstance> ;
    rdfs:range <https://purl.org/memo#MemeConcept> ;
    owl:inverseOf <http://www.wikidata.org/prop/direct/P527> .

<http://www.wikidata.org/prop/direct/P495> a owl:ObjectProperty ;
    rdfs:label "hasRegion" ;
    rdfs:domain <https://purl.org/memo#MemeConcept> ;
    rdfs:range <http://www.wikidata.org/entity/Q82794> ;
    owl:inverseOf <https://purl.org/memo#isRegionOf> .

<http://www.wikidata.org/prop/direct/P527> a owl:ObjectProperty ;
    rdfs:label "hasVariant" ;
    rdfs:domain <https://purl.org/memo#MemeConcept> ;
    rdfs:range <https://purl.org/memo#VariantInstance> ;
    owl:inverseOf <http://www.wikidata.org/prop/direct/P361> .

<http://www.wikidata.org/prop/direct/P8371> a owl:ObjectProperty ;
    rdfs:label "hasReference" ;
    rdfs:domain <https://purl.org/memo#MemeConcept> ;
    rdfs:range <http://www.wikidata.org/entity/Q96622155> ;
    owl:inverseOf <https://purl.org/memo#isReferencedIn> .

<https://purl.org/memo#conceptualizes> a owl:ObjectProperty ;
    rdfs:label "conceptualizes" ;
    rdfs:domain <https://purl.org/memo#MemeConcept> ;
    rdfs:range <http://www.wikidata.org/entity/Q3249551> ;
    owl:inverseOf <https://purl.org/memo#isConceptualizedAs> .

<https://purl.org/memo#hasAnimationStatus> a owl:ObjectProperty ;
    rdfs:label "hasAnimationStatus" ;
    rdfs:domain <https://purl.org/memo#MemeConcept> ;
    rdfs:range <https://purl.org/memo#AnimationStatus> ;
    owl:inverseOf <https://purl.org/memo#isAnimationStatusOf> .

<https://purl.org/memo#hasColorMode> a owl:ObjectProperty ;
    rdfs:label "hasColorMode" ;
    rdfs:domain [ a owl:Class ;
            owl:unionOf ( <https://purl.org/memo#MemeConcept> <https://purl.org/memo#VariantInstance> ) ] ;
    rdfs:range <https://purl.org/memo#ColorMode> ;
    owl:inverseOf <https://purl.org/memo#isColorModeOf> .

<https://purl.org/memo#hasImageType> a owl:ObjectProperty ;
    rdfs:label "hasImageType" ;
    rdfs:domain [ a owl:Class ;
            owl:unionOf ( <https://purl.org/memo#MemeConcept> <https://purl.org/memo#VariantInstance> ) ] ;
    rdfs:range <https://purl.org/memo#ImageType> ;
    owl:inverseOf <https://purl.org/memo#isImageTypeOf> .

<https://purl.org/memo#hasOriginWork> a owl:ObjectProperty ;
    rdfs:label "hasOriginWork" ;
    rdfs:domain <https://purl.org/memo#MemeConcept> ;
    rdfs:range <http://www.wikidata.org/entity/Q386724> ;
    rdfs:subPropertyOf prov:wasDerivedFrom ;
    owl:inverseOf <https://purl.org/memo#isOriginWorkOf> .

<https://purl.org/memo#hasSubjectMatter> a owl:ObjectProperty ;
    rdfs:label "hasSubjectMatter" ;
    rdfs:domain [ a owl:Class ;
            owl:unionOf ( <https://purl.org/memo#MemeConcept> <https://purl.org/memo#VariantInstance> ) ] ;
    rdfs:range <http://www.wikidata.org/entity/Q16334295> ;
    owl:inverseOf <https://purl.org/memo#isSubjectMatterOf> .

<https://purl.org/memo#hasTextPresence> a owl:ObjectProperty ;
    rdfs:label "hasTextPresence" ;
    rdfs:domain [ a owl:Class ;
            owl:unionOf ( <https://purl.org/memo#MemeConcept> <https://purl.org/memo#VariantInstance> ) ] ;
    rdfs:range <https://purl.org/memo#TextPresence> ;
    owl:inverseOf <https://purl.org/memo#isTextPresenceOf> .

<https://purl.org/memo#hasTransformationDimension> a owl:ObjectProperty ;
    rdfs:label "hasTransformationDimension" ;
    rdfs:domain <https://purl.org/memo#VariantInstance> ;
    rdfs:range <https://purl.org/memo#TransformationDimension> ;
    owl:inverseOf <https://purl.org/memo#isTransformationDimensionOf> .

<https://purl.org/memo#hasTransformationExtent> a owl:ObjectProperty ;
    rdfs:label "hasTransformationExtent" ;
    rdfs:domain <https://purl.org/memo#VariantInstance> ;
    rdfs:range <https://purl.org/memo#TransformationExtent> ;
    owl:inverseOf <https://purl.org/memo#isTransformationExtentOf> .

<https://purl.org/memo#isAnimationStatusOf> a owl:ObjectProperty ;
    rdfs:label "isAnimationStatusOf" ;
    rdfs:domain <https://purl.org/memo#AnimationStatus> ;
    rdfs:range <https://purl.org/memo#MemeConcept> ;
    owl:inverseOf <https://purl.org/memo#hasAnimationStatus> .

<https://purl.org/memo#isColorModeOf> a owl:ObjectProperty ;
    rdfs:label "isColorModeOf" ;
    rdfs:domain <https://purl.org/memo#ColorMode> ;
    rdfs:range [ a owl:Class ;
            owl:unionOf ( <https://purl.org/memo#MemeConcept> <https://purl.org/memo#VariantInstance> ) ] ;
    owl:inverseOf <https://purl.org/memo#hasColorMode> .

<https://purl.org/memo#isConceptualizedAs> a owl:ObjectProperty ;
    rdfs:label "isConceptualizedAs" ;
    rdfs:domain <http://www.wikidata.org/entity/Q3249551> ;
    rdfs:range <https://purl.org/memo#MemeConcept> ;
    owl:inverseOf <https://purl.org/memo#conceptualizes> .

<https://purl.org/memo#isFormatOf> a owl:ObjectProperty ;
    rdfs:label "isFormatOf" ;
    rdfs:domain <https://purl.org/memo#MemeFormat> ;
    rdfs:range <https://purl.org/memo#MemeConcept> ;
    owl:inverseOf <http://www.wikidata.org/prop/direct/P2283> .

<https://purl.org/memo#isImageTypeOf> a owl:ObjectProperty ;
    rdfs:label "isImageTypeOf" ;
    rdfs:domain <https://purl.org/memo#ImageType> ;
    rdfs:range [ a owl:Class ;
            owl:unionOf ( <https://purl.org/memo#MemeConcept> <https://purl.org/memo#VariantInstance> ) ] ;
    owl:inverseOf <https://purl.org/memo#hasImageType> .

<https://purl.org/memo#isOriginPlatformOf> a owl:ObjectProperty ;
    rdfs:label "isOriginPlatformOf" ;
    rdfs:domain <http://www.wikidata.org/entity/Q3220391> ;
    rdfs:range <https://purl.org/memo#MemeConcept> ;
    owl:inverseOf <http://www.wikidata.org/prop/direct/P123> .

<https://purl.org/memo#isOriginWorkOf> a owl:ObjectProperty ;
    rdfs:label "isOriginWorkOf" ;
    rdfs:domain <http://www.wikidata.org/entity/Q386724> ;
    rdfs:range <https://purl.org/memo#MemeConcept> ;
    owl:inverseOf <https://purl.org/memo#hasOriginWork> .

<https://purl.org/memo#isReferencedIn> a owl:ObjectProperty ;
    rdfs:label "isReferencedIn" ;
    rdfs:domain <http://www.wikidata.org/entity/Q96622155> ;
    rdfs:range <https://purl.org/memo#MemeConcept> ;
    owl:inverseOf <http://www.wikidata.org/prop/direct/P8371> .

<https://purl.org/memo#isRegionOf> a owl:ObjectProperty ;
    rdfs:label "isRegionOf" ;
    rdfs:domain <http://www.wikidata.org/entity/Q82794> ;
    rdfs:range <https://purl.org/memo#MemeConcept> ;
    owl:inverseOf <http://www.wikidata.org/prop/direct/P495> .

<https://purl.org/memo#isSubjectMatterOf> a owl:ObjectProperty ;
    rdfs:label "isSubjectMatterOf" ;
    rdfs:domain <http://www.wikidata.org/entity/Q16334295> ;
    rdfs:range [ a owl:Class ;
            owl:unionOf ( <https://purl.org/memo#MemeConcept> <https://purl.org/memo#VariantInstance> ) ] ;
    owl:inverseOf <https://purl.org/memo#hasSubjectMatter> .

<https://purl.org/memo#isTextPresenceOf> a owl:ObjectProperty ;
    rdfs:label "isTextPresenceOf" ;
    rdfs:domain <https://purl.org/memo#TextPresence> ;
    rdfs:range [ a owl:Class ;
            owl:unionOf ( <https://purl.org/memo#MemeConcept> <https://purl.org/memo#VariantInstance> ) ] ;
    owl:inverseOf <https://purl.org/memo#hasTextPresence> .

<https://purl.org/memo#isTimePeriodOf> a owl:ObjectProperty ;
    rdfs:label "isTimePeriodOf" ;
    rdfs:domain <http://www.wikidata.org/entity/Q11471> ;
    rdfs:range <https://purl.org/memo#MemeConcept> ;
    owl:inverseOf <http://www.wikidata.org/prop/direct/P2408> .

<https://purl.org/memo#isTransformationDimensionOf> a owl:ObjectProperty ;
    rdfs:label "isTransformationDimensionOf" ;
    rdfs:domain <https://purl.org/memo#TransformationDimension> ;
    rdfs:range <https://purl.org/memo#VariantInstance> ;
    owl:inverseOf <https://purl.org/memo#hasTransformationDimension> .

<https://purl.org/memo#isTransformationExtentOf> a owl:ObjectProperty ;
    rdfs:label "isTransformationExtentOf" ;
    rdfs:domain <https://purl.org/memo#TransformationExtent> ;
    rdfs:range <https://purl.org/memo#VariantInstance> ;
    owl:inverseOf <https://purl.org/memo#hasTransformationExtent> .

<http://www.wikidata.org/entity/Q11471> a owl:Class ;
    rdfs:label "TimePeriod" ;
    rdfs:comment "Chronological period in which the meme originated or peaked, aligned with Wikidata Q11471."@en ;
    rdfs:seeAlso <https://www.wikidata.org/wiki/Q11471> .

<http://www.wikidata.org/entity/Q16334295> a owl:Class ;
    rdfs:label "SubjectMatter" ;
    rdfs:comment "Primary visual subject depicted in a meme image; corresponds to Panofsky's pre-iconographic level, aligned with Wikidata Q16334295."@en ;
    rdfs:seeAlso <https://www.wikidata.org/wiki/Q16334295> .

<http://www.wikidata.org/entity/Q3220391> a owl:Class ;
    rdfs:label "OriginPlatform" ;
    rdfs:comment "Online platform or service where the meme was first published, aligned with Wikidata Q3220391."@en ;
    rdfs:seeAlso <https://www.wikidata.org/wiki/Q3220391> .

<http://www.wikidata.org/entity/Q82794> a owl:Class ;
    rdfs:label "GeographicRegion" ;
    rdfs:comment "Geographic region or country of meme origin, as defined by Wikidata Q82794."@en ;
    rdfs:seeAlso <https://www.wikidata.org/wiki/Q82794> .

<https://purl.org/memo#AnimationStatus> a owl:Class ;
    rdfs:label "AnimationStatus" ;
    rdfs:comment "Whether a meme image is animated (Animated, i.e. a GIF) or static (Static). Derived from file extension."@en .

<https://purl.org/memo#ColorMode> a owl:Class ;
    rdfs:label "ColorMode" ;
    rdfs:comment "Whether a meme image uses colour or is monochromatic (Color or Monochrome). Determined by per-pixel colour range analysis."@en .

<https://purl.org/memo#ImageType> a owl:Class ;
    rdfs:label "ImageType" ;
    rdfs:comment "The visual medium or rendering technique of a meme image (e.g. Photograph, Drawing, Cartoon). Corresponds to Panofsky's pre-iconographic description."@en .

<https://purl.org/memo#MemeFormat> a owl:Class ;
    rdfs:label "MemeFormat" ;
    rdfs:comment "The genre or structural format of a meme (e.g. ImageMacro, Copypasta, ViralVideo). Drawn from Know Your Meme's type taxonomy."@en .

<https://purl.org/memo#TextPresence> a owl:Class ;
    rdfs:label "TextPresence" ;
    rdfs:comment "Whether visible text is present in a meme image (ContainsText or NoText). Detected automatically via CLIP and EasyOCR."@en .

<https://purl.org/memo#TransformationDimension> a owl:Class ;
    rdfs:label "TransformationDimension" ;
    rdfs:comment "The primary dimension along which a VariantInstance transforms the source template (e.g. textual, visual, contextual). Enables typological analysis of meme variation."@en .

<https://purl.org/memo#TransformationExtent> a owl:Class ;
    rdfs:label "TransformationExtent" ;
    rdfs:comment "The degree to which a VariantInstance diverges from its source template (e.g. Minimal, Moderate, Major). Enables quantitative analysis of meme mutation."@en .

<http://www.wikidata.org/entity/Q3249551> a owl:Class ;
    rdfs:label "MemeIdea" ;
    rdfs:comment "Abstract creative idea underlying a meme template; corresponds to the FRBR Work level, aligned with Wikidata Q3249551."@en ;
    rdfs:seeAlso <https://www.wikidata.org/wiki/Q3249551> .

<http://www.wikidata.org/entity/Q386724> a owl:Class ;
    rdfs:label "OriginWork" ;
    rdfs:comment "Creative work (film, TV series, game, etc.) from which the meme derives, aligned with Wikidata Q386724."@en ;
    rdfs:seeAlso <https://www.wikidata.org/wiki/Q386724> .

<http://www.wikidata.org/entity/Q96622155> a owl:Class ;
    rdfs:label "CulturalReference" ;
    rdfs:comment "Cultural artefact, event, or phenomenon that a meme iconologically references, aligned with Wikidata Q96622155."@en ;
    rdfs:seeAlso <https://www.wikidata.org/wiki/Q96622155> .

<https://purl.org/memo#VariantInstance> a owl:Class ;
    rdfs:label "VariantInstance" ;
    rdfs:comment "A specific image derived from a meme template; the Manifestation level of the FRBR hierarchy. Represents a single scraped or documented instantiation of a MemeConcept."@en .

<https://purl.org/memo#MemeConcept> a owl:Class ;
    rdfs:label "MemeConcept" ;
    rdfs:comment "A meme template or canonical format; the Expression level of the FRBR hierarchy. Represents the stable, recognisable form of a meme as documented on Know Your Meme."@en .

