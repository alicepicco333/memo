memo:views a owl:DatatypeProperty ;
    rdfs:label "views" ;
    rdfs:domain memo:MemeConcept ;
    rdfs:range xsd:integer .

memo:yearOfOrigin a owl:DatatypeProperty ;
    rdfs:label "yearOfOrigin" ;
    rdfs:domain memo:MemeConcept ;
    rdfs:range xsd:integer .

memo:conceptualizes a owl:ObjectProperty ;
    rdfs:label "conceptualizes" ;
    rdfs:domain memo:MemeConcept ;
    rdfs:range memo:MemeIdea ;
    owl:inverseOf memo:isConceptualizedAs .

memo:hasAnimationStatus a owl:ObjectProperty ;
    rdfs:label "hasAnimationStatus"@en ;
    memo:frbrLevel "Manifestation" ;
    memo:semanticLevel "PreIconographical" ;
    rdfs:domain memo:MemeConcept ;
    rdfs:range memo:AnimationStatus ;
    owl:inverseOf memo:isAnimationStatusOf .

memo:hasCanonicalColorMode a owl:ObjectProperty ;
    rdfs:label "hasCanonicalColorMode"@en ;
    memo:frbrLevel "Manifestation" ;
    memo:semanticLevel "PreIconographical" ;
    rdfs:domain memo:MemeConcept ;
    rdfs:range memo:ColorMode ;
    owl:inverseOf memo:isCanonicalColorModeOf .

memo:hasCanonicalImageType a owl:ObjectProperty ;
    rdfs:label "hasCanonicalImageType"@en ;
    memo:frbrLevel "Manifestation" ;
    memo:semanticLevel "PreIconographical" ;
    rdfs:comment """The visual medium of the canonical meme image,\r\r\r\r\r\r
assigned by CLIP-based classification."""@en ;
    rdfs:domain memo:MemeConcept ;
    rdfs:range memo:ImageType ;
    owl:inverseOf memo:isCanonicalImageTypeOf .

memo:hasCanonicalTextPresence a owl:ObjectProperty ;
    rdfs:label "hasCanonicalTextPresence"@en ;
    memo:frbrLevel "Manifestation" ;
    memo:semanticLevel "PreIconographical" ;
    rdfs:domain memo:MemeConcept ;
    rdfs:range memo:TextPresence ;
    owl:inverseOf memo:isCanonicalTextPresenceOf .

memo:hasColorMode a owl:ObjectProperty ;
    rdfs:label "hasColorMode" ;
    rdfs:domain memo:VariantInstance ;
    rdfs:range memo:ColorMode ;
    owl:inverseOf memo:isColorModeOf .

memo:hasFileFormat a owl:ObjectProperty ;
    rdfs:label "hasFileFormat"@en ;
    memo:frbrLevel "Manifestation" ;
    memo:semanticLevel "PreIconographical" ;
    rdfs:domain memo:MemeConcept ;
    rdfs:range memo:FileFormat ;
    owl:inverseOf memo:isFileFormatOf .

memo:hasFormat a owl:ObjectProperty ;
    rdfs:label "hasFormat"@en ;
    memo:frbrLevel "Expression" ;
    memo:semanticLevel "Iconographical" ;
    rdfs:comment """Links a MemeConcept to one or more MemeFormat\r\r\r\r\r\r
values describing its rhetorical structure."""@en ;
    rdfs:domain memo:MemeConcept ;
    rdfs:range memo:MemeFormat ;
    owl:inverseOf memo:isFormatOf .

memo:hasImageType a owl:ObjectProperty ;
    rdfs:label "hasImageType" ;
    rdfs:domain memo:VariantInstance ;
    rdfs:range memo:ImageType ;
    owl:inverseOf memo:isImageTypeOf .

memo:hasOriginBoard a owl:ObjectProperty ;
    rdfs:label "hasOriginBoard"@en ;
    memo:documentaryLevel "true" ;
    memo:frbrLevel "Expression" ;
    rdfs:comment """Links a MemeConcept to the specific imageboard\r\r\r\r\r\r
or forum thread where it originated."""@en ;
    rdfs:domain memo:MemeConcept ;
    rdfs:range memo:OriginBoard ;
    owl:inverseOf memo:isOriginBoardOf .

memo:hasOriginBook a owl:ObjectProperty ;
    rdfs:label "hasOriginBook" ;
    rdfs:domain memo:MemeConcept ;
    rdfs:range memo:OriginBook ;
    owl:inverseOf memo:isOriginBookOf .

memo:hasOriginComic a owl:ObjectProperty ;
    rdfs:label "hasOriginComic" ;
    rdfs:domain memo:MemeConcept ;
    rdfs:range memo:OriginComic ;
    owl:inverseOf memo:isOriginComicOf .

memo:hasOriginFilm a owl:ObjectProperty ;
    rdfs:label "hasOriginFilm" ;
    rdfs:domain memo:MemeConcept ;
    rdfs:range memo:OriginFilm ;
    owl:inverseOf memo:isOriginFilmOf .

memo:hasOriginMusic a owl:ObjectProperty ;
    rdfs:label "hasOriginMusic" ;
    rdfs:domain memo:MemeConcept ;
    rdfs:range memo:OriginMusic ;
    owl:inverseOf memo:isOriginMusicOf .

memo:hasOriginPerson a owl:ObjectProperty ;
    rdfs:label "hasOriginPerson" ;
    rdfs:domain memo:MemeConcept ;
    rdfs:range memo:OriginPerson ;
    owl:inverseOf memo:isOriginPersonOf .

memo:hasOriginPlatform a owl:ObjectProperty ;
    rdfs:label "hasOriginPlatform" ;
    rdfs:domain memo:MemeConcept ;
    rdfs:range memo:OriginPlatform ;
    owl:inverseOf memo:isOriginPlatformOf .

