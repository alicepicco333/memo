:documentaryLevel a owl:AnnotationProperty ;
    rdfs:label "Documentary Level",
        "documentary level"@en ;
    rdfs:comment "Marks this class as encoding factual provenance information recorded from external documentary sources rather than interpreted from content. Value: true.",
        "Marks this class as encoding factual provenance information recorded from external documentary sources. Value: true.",
        """Associates a class or property with the\r
documentary analysis dimension (provenance, platform, geographic and temporal\r
context)."""@en .

:frbrLevel a owl:AnnotationProperty ;
    rdfs:label "FRBR Level",
        "FRBR level"@en ;
    rdfs:comment "Records the FRBR bibliographic hierarchy level at which this class operates. Values: Work, Expression, Manifestation, Item.",
        """Associates a class or property with its\r
position in the FRBR abstraction hierarchy: Work, Expression, Manifestation, or\r
Item."""@en .

