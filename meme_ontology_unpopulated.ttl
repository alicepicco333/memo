memo:conceptualizes a owl:ObjectProperty ;
    rdfs:label "conceptualizes" ;
    rdfs:domain memo:MemeConcept ;
    rdfs:range memo:MemeIdea ;
    owl:inverseOf memo:isConceptualizedAs .

memo:hasAnimationStatus a owl:ObjectProperty ;
    rdfs:label "has animation status"@en ;
    memo:frbrLevel "Manifestation" ;
    memo:semanticLevel "PreIconographical" ;
    rdfs:domain memo:MemeConcept ;
    rdfs:range memo:AnimationStatus ;
    owl:inverseOf memo:isAnimationStatusOf .

memo:hasCanonicalColorMode a owl:ObjectProperty ;
    rdfs:label "has canonical color mode"@en ;
    memo:frbrLevel "Manifestation" ;
    memo:semanticLevel "PreIconographical" ;
    rdfs:domain memo:MemeConcept ;
    rdfs:range memo:CanonicalColorMode ;
    owl:inverseOf memo:isCanonicalColorModeOf .

memo:hasCanonicalImageType a owl:ObjectProperty ;
    rdfs:label "has canonical image type"@en ;
    memo:frbrLevel "Manifestation" ;
    memo:semanticLevel "PreIconographical" ;
    rdfs:comment """The visual medium of the canonical meme image,\r\r\r\r\r\r
assigned by CLIP-based classification."""@en ;
    rdfs:domain memo:MemeConcept ;
    rdfs:range memo:CanonicalImageType ;
    owl:inverseOf memo:isCanonicalImageTypeOf .

memo:hasCanonicalSubjectMatter a owl:ObjectProperty ;
    rdfs:label "Has Canonical Subject Matter",
        "has canonical subject matter"@en ;
    memo:frbrLevel "Manifestation" ;
    memo:semanticLevel "PreIconographical" ;
    rdfs:comment "What is inherently built into the base meme template (Expression level)." ;
    rdfs:domain memo:MemeConcept ;
    rdfs:range memo:SubjectMatter ;
    owl:inverseOf memo:isCanonicalSubjectMatterOf .

memo:hasCanonicalTextPresence a owl:ObjectProperty ;
    rdfs:label "has canonical text presence"@en ;
    memo:frbrLevel "Manifestation" ;
    memo:semanticLevel "PreIconographical" ;
    rdfs:domain memo:MemeConcept ;
    rdfs:range memo:CanonicalTextPresence ;
    owl:inverseOf memo:isCanonicalTextPresenceOf .

memo:hasColorMode a owl:ObjectProperty ;
    rdfs:label "hasColorMode" ;
    rdfs:domain memo:VariantInstance ;
    rdfs:range memo:ColorMode ;
    owl:inverseOf memo:isColorModeOf .

memo:hasFileFormat a owl:ObjectProperty ;
    rdfs:label "has file format"@en ;
    memo:frbrLevel "Manifestation" ;
    memo:semanticLevel "PreIconographical" ;
    rdfs:domain memo:MemeConcept ;
    rdfs:range memo:FileFormat ;
    owl:inverseOf memo:isFileFormatOf .

memo:hasFormat a owl:ObjectProperty ;
    rdfs:label "has format"@en ;
    memo:frbrLevel "Expression" ;
    memo:semanticLevel "Iconographical" ;
    rdfs:comment """Links a MemeConcept to one or more MemeFormat\r\r\r\r\r\r
values describing its rhetorical structure."""@en ;
    rdfs:domain memo:MemeConcept ;
    rdfs:range memo:MemeFormat ;
    owl:inverseOf memo:isFormatOf .

memo:hasImageType a owl:ObjectProperty ;
