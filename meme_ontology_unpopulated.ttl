<http://www.wikidata.org/entity/Q11471> a owl:Class ;
    rdfs:label "TimePeriod" ;
    rdfs:comment "Chronological period in which the meme originated or peaked, aligned with Wikidata Q11471."@en ;
    rdfs:seeAlso <https://www.wikidata.org/wiki/Q11471> .

<http://www.wikidata.org/entity/Q16334295> a owl:Class ;
    rdfs:label "SubjectMatter" ;
    rdfs:comment "Primary visual subject depicted in a meme image; corresponds to Panofsky's pre-iconographic level, aligned with Wikidata Q16334295."@en ;
    rdfs:seeAlso <https://www.wikidata.org/wiki/Q16334295> .

<https://purl.org/memo#AnimationStatus> a owl:Class ;
    rdfs:label "AnimationStatus" ;
    rdfs:comment "Whether a meme image is animated (Animated, i.e. a GIF) or static (Static). Derived from file extension."@en .

<https://purl.org/memo#ColorMode> a owl:Class ;
    rdfs:label "ColorMode" ;
    rdfs:comment "Whether a meme image uses colour or is monochromatic (Color or Monochrome). Determined by per-pixel colour range analysis."@en .

<https://purl.org/memo#ImageType> a owl:Class ;
    rdfs:label "ImageType" ;
    rdfs:comment "The visual medium or rendering technique of a meme image (e.g. Photograph, Drawing, Cartoon). Corresponds to Panofsky's pre-iconographic description."@en .

<https://purl.org/memo#MemeFormat> a owl:Class ;
    rdfs:label "MemeFormat" ;
    rdfs:comment "The genre or structural format of a meme (e.g. ImageMacro, Copypasta, ViralVideo). Drawn from Know Your Meme's type taxonomy."@en .

<https://purl.org/memo#TextPresence> a owl:Class ;
    rdfs:label "TextPresence" ;
    rdfs:comment "Whether visible text is present in a meme image (ContainsText or NoText). Detected automatically via CLIP and EasyOCR."@en .

<https://purl.org/memo#TransformationDimension> a owl:Class ;
    rdfs:label "TransformationDimension" ;
    rdfs:comment "The primary dimension along which a VariantInstance transforms the source template (e.g. textual, visual, contextual). Enables typological analysis of meme variation."@en .

<https://purl.org/memo#TransformationExtent> a owl:Class ;
    rdfs:label "TransformationExtent" ;
    rdfs:comment "The degree to which a VariantInstance diverges from its source template (e.g. Minimal, Moderate, Major). Enables quantitative analysis of meme mutation."@en .

<http://www.wikidata.org/entity/Q3249551> a owl:Class ;
    rdfs:label "MemeIdea" ;
    rdfs:comment "Abstract creative idea underlying a meme template; corresponds to the FRBR Work level, aligned with Wikidata Q3249551."@en ;
    rdfs:seeAlso <https://www.wikidata.org/wiki/Q3249551> .

<http://www.wikidata.org/entity/Q386724> a owl:Class ;
    rdfs:label "OriginWork" ;
    rdfs:comment "Creative work (film, TV series, game, etc.) from which the meme derives, aligned with Wikidata Q386724."@en ;
    rdfs:seeAlso <https://www.wikidata.org/wiki/Q386724> .

<http://www.wikidata.org/entity/Q96622155> a owl:Class ;
    rdfs:label "CulturalReference" ;
    rdfs:comment "Cultural artefact, event, or phenomenon that a meme iconologically references, aligned with Wikidata Q96622155."@en ;
    rdfs:seeAlso <https://www.wikidata.org/wiki/Q96622155> .

<https://purl.org/memo#VariantInstance> a owl:Class ;
    rdfs:label "VariantInstance" ;
    rdfs:comment "A specific image derived from a meme template; the Manifestation level of the FRBR hierarchy. Represents a single scraped or documented instantiation of a MemeConcept."@en .

<http://www.wikidata.org/entity/Q3220391> a owl:Class ;
    rdfs:label "OriginPlatform" ;
    rdfs:comment "Online platform or service where the meme was first published, aligned with Wikidata Q3220391."@en ;
    rdfs:seeAlso <https://www.wikidata.org/wiki/Q3220391> .

<https://purl.org/memo#MemeConcept> a owl:Class ;
    rdfs:label "MemeConcept" ;
    rdfs:comment "A meme template or canonical format; the Expression level of the FRBR hierarchy. Represents the stable, recognisable form of a meme as documented on Know Your Meme."@en .

<http://www.wikidata.org/entity/Q82794> a owl:Class ;
    rdfs:label "GeographicRegion" ;
    rdfs:comment "Geographic region or country of meme origin, as defined by Wikidata Q82794."@en ;
    rdfs:seeAlso <https://www.wikidata.org/wiki/Q82794> .

