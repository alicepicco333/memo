memo:OriginVideoGame a owl:Class ;
    rdfs:label "OriginVideoGame" ;
    rdfs:subClassOf memo:OriginWork .

memo:Static a owl:Class ;
    rdfs:label "Static" ;
    rdfs:subClassOf memo:AnimationStatus .

memo:hasManifestation a owl:ObjectProperty ;
    rdfs:label "has manifestation" ;
    rdfs:comment "Relates a Manifestation to the Expression it instantiates" ;
    rdfs:domain memo:Manifestation ;
    rdfs:range memo:Expression ;
    owl:inverseOf memo:isManifestedIn .

memo:isManifestedIn a owl:ObjectProperty ;
    rdfs:label "is manifested in" ;
    rdfs:comment "Relates an Expression (template concept) to its Manifestations (format-specific instances)" ;
    rdfs:domain memo:Expression ;
    rdfs:range memo:Manifestation ;
    owl:inverseOf memo:hasManifestation .

memo:Iconographical rdfs:label "Iconographical" .

memo:Iconological rdfs:label "Iconological" .

memo:MemeIdea a owl:Class ;
    rdfs:label "Meme Idea"@en ;
    memo:frbrLevel "Work" ;
    rdfs:comment """The abstract Work-level idea underlying a memo:\r\r\r\r\r\r
its core narrative, emotional register, rhetorical function or cultural role,\r\r\r\r\r\r
independent of any specific image or format. 50 enriched individuals from the\r\r\r\r\r\r
D0 sample, with descriptions and cultural reference annotations."""@en ;
    rdfs:subClassOf owl:Thing .

memo:PreIconographical rdfs:label "Pre Iconographical" .

memo:AnimationStatus a owl:Class ;
    rdfs:label "Animation Status"@en ;
    memo:documentaryLevel "true" ;
    memo:frbrLevel "Item" ;
    rdfs:comment """Whether a meme image is static or animated\r\r\r\r\r\r
(GIF/video)."""@en ;
    rdfs:subClassOf owl:Thing .

memo:CanonicalColorMode a owl:Class ;
    rdfs:label "Canonical Color Mode"@en ;
    memo:frbrLevel "Expression" ;
    memo:semanticLevel "PreIconographical" ;
    rdfs:comment """Whether the canonical meme image is in colour or\r\r\r\r\r\r
monochrome."""@en ;
    rdfs:subClassOf owl:Thing .

memo:CanonicalTextPresence a owl:Class ;
    rdfs:label "Canonical Text Presence"@en ;
    memo:frbrLevel "Expression" ;
    memo:semanticLevel "PreIconographical" ;
    rdfs:comment """Whether the canonical meme image contains\r\r\r\r\r\r
overlaid text."""@en ;
    rdfs:subClassOf owl:Thing .

memo:ColorMode a owl:Class ;
    rdfs:label "ColorMode" ;
    memo:frbrLevel "Manifestation" ;
    memo:semanticLevel "PreIconographical" ;
    rdfs:subClassOf owl:Thing .

memo:GIF a owl:Class ;
    rdfs:label "GIF" ;
    rdfs:subClassOf memo:FileFormat .

memo:Item rdfs:label "Item" .

memo:JPEG a owl:Class ;
    rdfs:label "JPEG" ;
    rdfs:subClassOf memo:FileFormat .

memo:Minimal a owl:Class ;
    rdfs:label "Minimal" ;
    rdfs:subClassOf memo:TransformationExtent .

memo:Moderate a owl:Class ;
    rdfs:label "Moderate" ;
    rdfs:subClassOf memo:TransformationExtent .

memo:PNG a owl:Class ;
    rdfs:label "PNG" ;
    rdfs:subClassOf memo:FileFormat .

memo:Parody a owl:Class ;
    rdfs:label "Parody" ;
    rdfs:subClassOf memo:TransformationExtent .

memo:Substantial a owl:Class ;
    rdfs:label "Substantial" ;
    rdfs:subClassOf memo:TransformationExtent .

memo:TextPresence a owl:Class ;
    rdfs:label "TextPresence" ;
    memo:frbrLevel "Manifestation" ;
    memo:semanticLevel "PreIconographical" ;
    rdfs:subClassOf owl:Thing .

memo:WebP a owl:Class ;
    rdfs:label "WebP" ;
    rdfs:subClassOf memo:FileFormat .

memo:Work rdfs:label "Work" .

memo:Cartoon a owl:Class ;
    rdfs:label "Cartoon" ;
    rdfs:subClassOf memo:ImageType .

memo:Drawing a owl:Class ;
    rdfs:label "Drawing" ;
    rdfs:subClassOf memo:ImageType .

memo:Illustration a owl:Class ;
    rdfs:label "Illustration" ;
    rdfs:subClassOf memo:ImageType .

memo:Painting a owl:Class ;
    rdfs:label "Painting" ;
    rdfs:subClassOf memo:ImageType .

memo:Photograph a owl:Class ;
    rdfs:label "Photograph" ;
    rdfs:subClassOf memo:ImageType .

memo:Expression rdfs:label "Expression" .

memo:Manifestation rdfs:label "Manifestation" .

memo:TransformationExtent a owl:Class ;
    rdfs:label "Transformation Extent"@en ;
    memo:documentaryLevel "true" ;
    memo:frbrLevel "Manifestation" ;
    rdfs:comment """The degree to which a variant departs from the\r\r\r\r\r\r
canonical template: Minimal (close copy), Moderate, Substantial, or Parody\r\r\r\r\r\r
(radical departure)."""@en ;
    rdfs:subClassOf owl:Thing .

memo:CanonicalImageType a owl:Class ;
    rdfs:label "Canonical Image Type"@en ;
    memo:frbrLevel "Expression" ;
    memo:semanticLevel "PreIconographical" ;
    rdfs:comment """The visual medium of the canonical meme image\r\r\r\r\r\r
(Photograph, Drawing, Cartoon, Illustration, Painting, etc.). Pre-iconographical\r\r\r\r\r\r
classification at the Manifestation level, assigned via CLIP-based scoring."""@en ;
    rdfs:subClassOf owl:Thing .

memo:FileFormat a owl:Class ;
    rdfs:label "File Format"@en ;
    memo:documentaryLevel "true" ;
    memo:frbrLevel "Item" ;
    rdfs:comment """The digital file format of the meme image (JPEG,\r\r\r\r\r\r
PNG, GIF, WebP, BMP)."""@en ;
    rdfs:subClassOf owl:Thing .

memo:ImageType a owl:Class ;
    rdfs:label "Image Type"@en ;
    memo:frbrLevel "Manifestation" ;
    memo:semanticLevel "PreIconographical" ;
    rdfs:comment """The visual medium type of an individual variant\r\r\r\r\r\r
image. Uses the same controlled vocabulary as CanonicalImageType but applied at\r\r\r\r\r\r
the Item (VariantInstance) level."""@en ;
    rdfs:subClassOf owl:Thing .

memo:TimePeriod a owl:Class ;
    rdfs:label "Time Period"@en ;
    memo:documentaryLevel "true" ;
    memo:frbrLevel "Expression" ;
    rdfs:comment """The era in which a meme originated or peaked\r\r\r\r\r\r
(Pre2010, Period2010to2015, Period2016to2020, Period2021toPresent)."""@en ;
    rdfs:subClassOf owl:Thing .

memo:CulturalReference a owl:Class ;
    rdfs:label "Cultural Reference"@en ;
    memo:frbrLevel "Expression Manifestation",
        "Expression, Manifestation" ;
    memo:semanticLevel "Iconological" ;
    rdfs:comment """A cultural entity referenced by a meme — a historical\r\r\r\r\r\r
event, media property, political event, public figure, social phenomenon, or web\r\r\r\r\r\r
culture artefact. Subclasses: HistoricalEvent, MediaProperty, PoliticalEvent,\r\r\r\r\r\r
PublicFigure, SocialPhenomenon, WebCulture."""@en ;
    rdfs:subClassOf owl:Thing .

memo:AnimalPresent a owl:Class ;
    rdfs:label "AnimalPresent" ;
    rdfs:subClassOf memo:SubjectMatter .

memo:CanonicalSubjectMatter a owl:Class ;
    rdfs:label "Canonical Subject Matter"@en ;
    memo:frbrLevel "Expression" ;
    memo:semanticLevel "PreIconographical" ;
    rdfs:comment """The category of subjects depicted in the\r\r\r\r\r\r
canonical image (PersonPresent, AnimalPresent, ObjectOnly, TextOnly,\r\r\r\r\r\r
MultipleSubjects, etc.)."""@en ;
    rdfs:subClassOf owl:Thing .

memo:CharacterPresent a owl:Class ;
    rdfs:label "CharacterPresent" ;
    rdfs:subClassOf memo:SubjectMatter .

memo:MultipleSubjects a owl:Class ;
    rdfs:label "MultipleSubjects" ;
    rdfs:subClassOf memo:SubjectMatter .

memo:NoPerson rdfs:label "No Person" .

memo:ObjectOnly a owl:Class ;
    rdfs:label "ObjectOnly" ;
    rdfs:subClassOf memo:SubjectMatter .

memo:PersonPresent a owl:Class ;
    rdfs:label "PersonPresent" ;
    rdfs:subClassOf memo:SubjectMatter .

memo:PublicFigure a owl:Class ;
    rdfs:label "PublicFigure" ;
    rdfs:subClassOf memo:CulturalReference .

memo:SubjectMatter a owl:Class ;
    rdfs:label "SubjectMatter" ;
    memo:frbrLevel "Manifestation" ;
    memo:semanticLevel "PreIconographical" ;
    rdfs:subClassOf owl:Thing .

memo:TextOnly a owl:Class ;
    rdfs:label "TextOnly" ;
    rdfs:comment "SubjectMatter: TextOnly — image whose primary visible content is text with no person, character or animal present. Distinct from CaptionChange TransformationDimension." ;
    rdfs:subClassOf memo:SubjectMatter .

memo:UnknownPerson rdfs:label "Unknown Person" .

memo:OriginWork a owl:Class ;
    rdfs:label "Origin Work"@en ;
    memo:documentaryLevel "true" ;
    memo:frbrLevel "Expression" ;
    rdfs:comment """The original cultural work (film, TV show, video\r\r\r\r\r\r
game, book, song, etc.) from which a meme derives its source material."""@en ;
    rdfs:subClassOf owl:Thing .

memo:TransformationDimension a owl:Class ;
    rdfs:label "Transformation Dimension"@en ;
    memo:documentaryLevel "true" ;
    memo:frbrLevel "Manifestation" ;
    rdfs:comment """The axis along which a variant transforms the\r\r\r\r\r\r
canonical template: CaptionChange, VisualSubstrate, MediumShift, StyleShift,\r\r\r\r\r\r
CompositionShift, CrossoverMerge, LanguageShift, Localization."""@en ;
    rdfs:subClassOf owl:Thing .

memo:GeographicRegion a owl:Class ;
    rdfs:label "Geographic Region"@en ;
    memo:documentaryLevel "true" ;
    memo:frbrLevel "Expression" ;
    rdfs:comment """The country or geographic region of a meme's\r\r\r\r\r\r
origin."""@en ;
    rdfs:subClassOf owl:Thing .

memo:VariantInstance a owl:Class ;
    rdfs:label "Variant Instance"@en ;
    memo:frbrLevel "Manifestation" ;
    rdfs:comment """A single scraped variant image — an Item-level\r\r\r\r\r\r
exemplar of a MemeConcept. 391 named individuals with transformation extent and\r\r\r\r\r\r
dimension annotations for 5 fully annotated meme templates."""@en ;
    rdfs:subClassOf owl:Thing .

memo:OriginPlatform a owl:Class ;
    rdfs:label "Origin Platform"@en ;
    memo:documentaryLevel "true" ;
    memo:frbrLevel "Expression" ;
    rdfs:comment """The online platform where a meme first appeared\r\r\r\r\r\r
or gained traction (e.g. Reddit, Twitter/X, 4chan, TikTok). Classified at the\r\r\r\r\r\r
Expression level with Documentary provenance."""@en ;
    rdfs:subClassOf owl:Thing .

memo:MemeFormat a owl:Class ;
    rdfs:label "Meme Format"@en ;
    memo:frbrLevel "Expression" ;
    memo:semanticLevel "Iconographical" ;
    rdfs:comment """The rhetorical or structural format of a meme\r\r\r\r\r\r
(e.g. ImageMacro, Catchphrase, Exploitable, Reaction, ViralVideo). Classifies\r\r\r\r\r\r
memes at the Expression level with Iconographical analysis."""@en ;
    rdfs:subClassOf owl:Thing .

memo:MemeConcept a owl:Class ;
    rdfs:label "Meme Concept"@en ;
    memo:frbrLevel "Expression" ;
    rdfs:comment """A canonical internet meme template as indexed\r\r\r\r\r\r
on Know Your Meme. Represents the stable, Expression-level identity of a meme\r\r\r\r\r\r
across all its variants. 5,000 named individuals are included, classified by\r\r\r\r\r\r
image type, format, platform, region and time period."""@en ;
    rdfs:subClassOf owl:Thing .

[] rdf:first memo:Photograph ;
    rdf:rest ( memo:Cartoon ) .

