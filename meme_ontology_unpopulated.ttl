:MemeIdea a owl:Class ;
    rdfs:label "Meme Idea",
        "Meme Idea"@en ;
    :frbrLevel "Work" ;
    rdfs:comment "The abstract cultural concept underlying a named meme template. Work-level class. Populated manually for D0 subset via conceptDescription data property. Has no visual properties — only the pure abstract idea.",
        """The abstract Work-level idea underlying a memo:\r
its core narrative, emotional register, rhetorical function or cultural role,\r
independent of any specific image or format. 50 enriched individuals from the\r
D0 sample, with descriptions and cultural reference annotations."""@en ;
    rdfs:subClassOf owl:Thing .

:AnimationStatus a owl:Class ;
    rdfs:label "Animation Status",
        "AnimationStatus",
        "Animation Status"@en ;
    :documentaryLevel "true" ;
    :frbrLevel "Item" ;
    rdfs:comment """Whether a meme image is static or animated\r
(GIF/video)."""@en ;
    rdfs:subClassOf owl:Thing .

:CanonicalColorMode a owl:Class ;
    rdfs:label "Canonical Color Mode",
        "CanonicalColorMode",
        "Canonical Color Mode"@en ;
    :frbrLevel "Expression" ;
    :semanticLevel "PreIconographical" ;
    rdfs:comment """Whether the canonical meme image is in colour or\r
monochrome."""@en ;
    rdfs:subClassOf owl:Thing .

:CanonicalTextPresence a owl:Class ;
    rdfs:label "Canonical Text Presence",
        "CanonicalTextPresence",
        "Canonical Text Presence"@en ;
    :frbrLevel "Expression" ;
    :semanticLevel "PreIconographical" ;
    rdfs:comment """Whether the canonical meme image contains\r
overlaid text."""@en ;
    rdfs:subClassOf owl:Thing .

:ColorMode a owl:Class ;
    rdfs:label "ColorMode" ;
    :frbrLevel "Manifestation" ;
    :semanticLevel "PreIconographical" ;
    rdfs:subClassOf owl:Thing .

:GIF a owl:Class ;
    rdfs:label "GIF" ;
    rdfs:subClassOf :FileFormat .

:JPEG a owl:Class ;
    rdfs:label "JPEG" ;
    rdfs:subClassOf :FileFormat .

:Minimal a owl:Class ;
    rdfs:label "Minimal" ;
    rdfs:subClassOf :TransformationExtent .

:Moderate a owl:Class ;
    rdfs:label "Moderate" ;
    rdfs:subClassOf :TransformationExtent .

:PNG a owl:Class ;
    rdfs:label "PNG" ;
    rdfs:subClassOf :FileFormat .

:Parody a owl:Class ;
    rdfs:label "Parody" ;
    rdfs:subClassOf :TransformationExtent .

:Substantial a owl:Class ;
    rdfs:label "Substantial" ;
    rdfs:subClassOf :TransformationExtent .

:TextPresence a owl:Class ;
    rdfs:label "TextPresence" ;
    :frbrLevel "Manifestation" ;
    :semanticLevel "PreIconographical" ;
    rdfs:subClassOf owl:Thing .

:WebP a owl:Class ;
    rdfs:label "WebP" ;
    rdfs:subClassOf :FileFormat .

:Cartoon a owl:Class ;
    rdfs:label "Cartoon" ;
    rdfs:subClassOf :ImageType .

:Drawing a owl:Class ;
    rdfs:label "Drawing" ;
    rdfs:subClassOf :ImageType .

:Illustration a owl:Class ;
    rdfs:label "Illustration" ;
    rdfs:subClassOf :ImageType .

:Painting a owl:Class ;
    rdfs:label "Painting" ;
    rdfs:subClassOf :ImageType .

:Photograph a owl:Class ;
    rdfs:label "Photograph" ;
    rdfs:subClassOf :ImageType .

:TransformationExtent a owl:Class ;
    rdfs:label "Transformation Extent",
        "TransformationExtent",
        "Transformation Extent"@en ;
    :documentaryLevel "true" ;
    :frbrLevel "Manifestation" ;
    rdfs:comment "The overall degree of transformation from the canonical Expression. Single-valued.",
        """The degree to which a variant departs from the\r
canonical template: Minimal (close copy), Moderate, Substantial, or Parody\r
(radical departure)."""@en ;
    rdfs:subClassOf owl:Thing .

:CanonicalImageType a owl:Class ;
    rdfs:label "Canonical Image Type",
        "CanonicalImageType",
        "Canonical Image Type"@en ;
    :frbrLevel "Expression" ;
    :semanticLevel "PreIconographical" ;
    rdfs:comment "The canonical visual medium of the named template as derived from the representative image via CLIP. Property of the Expression-level MemeConcept.",
        """The visual medium of the canonical meme image\r
(Photograph, Drawing, Cartoon, Illustration, Painting, etc.). Pre-iconographical\r
classification at the Manifestation level, assigned via CLIP-based scoring."""@en ;
    rdfs:subClassOf owl:Thing .

:FileFormat a owl:Class ;
    rdfs:label "File Format",
        "FileFormat",
        "File Format"@en ;
    :documentaryLevel "true" ;
    :frbrLevel "Item" ;
    rdfs:comment """The digital file format of the meme image (JPEG,\r
PNG, GIF, WebP, BMP)."""@en ;
    rdfs:subClassOf owl:Thing .

:ImageType a owl:Class ;
    rdfs:label "Image Type",
        "ImageType",
        "Image Type"@en ;
    :frbrLevel "Manifestation" ;
    :semanticLevel "PreIconographical" ;
    rdfs:comment "The visual medium of a specific variant image. Manifestation-level property on VariantInstance.",
        """The visual medium type of an individual variant\r
image. Uses the same controlled vocabulary as CanonicalImageType but applied at\r
the Item (VariantInstance) level."""@en ;
    rdfs:subClassOf owl:Thing .

:TimePeriod a owl:Class ;
    rdfs:label "Time Period",
        "TimePeriod",
        "Time Period"@en ;
    :documentaryLevel "true" ;
    :frbrLevel "Expression" ;
    rdfs:comment """The era in which a meme originated or peaked\r
(Pre2010, Period2010to2015, Period2016to2020, Period2021toPresent)."""@en ;
    rdfs:subClassOf owl:Thing .

:CulturalReference a owl:Class ;
    rdfs:label "Cultural Reference",
        "CulturalReference",
        "Cultural Reference"@en ;
    :frbrLevel "Expression Manifestation",
        "Expression, Manifestation" ;
    :semanticLevel "Iconological" ;
    rdfs:comment "The cultural phenomena encoded by a meme template. At Expression level: template-wide references. At Manifestation level: variant-specific references.",
        """A cultural entity referenced by a meme — a historical\r
event, media property, political event, public figure, social phenomenon, or web\r
culture artefact. Subclasses: HistoricalEvent, MediaProperty, PoliticalEvent,\r
PublicFigure, SocialPhenomenon, WebCulture."""@en ;
    rdfs:subClassOf owl:Thing .

:AnimalPresent a owl:Class ;
    rdfs:label "AnimalPresent" ;
    rdfs:subClassOf :SubjectMatter .

:CanonicalSubjectMatter a owl:Class ;
    rdfs:label "Canonical Subject Matter",
        "CanonicalSubjectMatter",
        "Canonical Subject Matter"@en ;
    :frbrLevel "Expression" ;
    :semanticLevel "PreIconographical" ;
    rdfs:comment """The category of subjects depicted in the\r
canonical image (PersonPresent, AnimalPresent, ObjectOnly, TextOnly,\r
MultipleSubjects, etc.)."""@en ;
    rdfs:subClassOf owl:Thing .

:CharacterPresent a owl:Class ;
    rdfs:label "CharacterPresent" ;
    rdfs:subClassOf :SubjectMatter .

:MultipleSubjects a owl:Class ;
    rdfs:label "MultipleSubjects" ;
    rdfs:subClassOf :SubjectMatter .

:ObjectOnly a owl:Class ;
    rdfs:label "ObjectOnly" ;
    rdfs:subClassOf :SubjectMatter .

:PersonPresent a owl:Class ;
    rdfs:label "PersonPresent" ;
    rdfs:subClassOf :SubjectMatter .

:PublicFigure a owl:Class ;
    rdfs:label "PublicFigure" ;
    rdfs:subClassOf :CulturalReference .

:SubjectMatter a owl:Class ;
    rdfs:label "SubjectMatter" ;
    :frbrLevel "Manifestation" ;
    :semanticLevel "PreIconographical" ;
    rdfs:subClassOf owl:Thing .

:TextOnly a owl:Class ;
    rdfs:label "TextOnly" ;
    rdfs:comment "SubjectMatter: TextOnly — image whose primary visible content is text with no person, character or animal present. Distinct from CaptionChange TransformationDimension." ;
    rdfs:subClassOf :SubjectMatter .

:OriginWork a owl:Class ;
    rdfs:label "Origin Work",
        "OriginWork",
        "Origin Work"@en ;
    :documentaryLevel "true" ;
    :frbrLevel "Expression" ;
    rdfs:comment "A cultural text (film, game, TV show etc.) that is the origin of the meme template. Documentary fact.",
        """The original cultural work (film, TV show, video\r
game, book, song, etc.) from which a meme derives its source material."""@en ;
    rdfs:subClassOf owl:Thing .

:TransformationDimension a owl:Class ;
    rdfs:label "Transformation Dimension",
        "TransformationDimension",
        "Transformation Dimension"@en ;
    :documentaryLevel "true" ;
    :frbrLevel "Manifestation" ;
    rdfs:comment "The specific aspect of the canonical template that changes in a variant. Multi-valued.",
        """The axis along which a variant transforms the\r
canonical template: CaptionChange, VisualSubstrate, MediumShift, StyleShift,\r
CompositionShift, CrossoverMerge, LanguageShift, Localization."""@en ;
    rdfs:subClassOf owl:Thing .

:GeographicRegion a owl:Class ;
    rdfs:label "Geographic Region",
        "GeographicRegion",
        "Geographic Region"@en ;
    :documentaryLevel "true" ;
    :frbrLevel "Expression" ;
    rdfs:comment """The country or geographic region of a meme's\r
origin."""@en ;
    rdfs:subClassOf owl:Thing .

:VariantInstance a owl:Class ;
    rdfs:label "Variant Instance",
        "Variant Instance"@en ;
    :frbrLevel "Manifestation" ;
    rdfs:comment "A specific physical variant realization of a named meme template. Manifestation-level class. 391 individuals populated from D0 variant scraping.",
        """A single scraped variant image — an Item-level\r
exemplar of a MemeConcept. 391 named individuals with transformation extent and\r
dimension annotations for 5 fully annotated meme templates."""@en ;
    rdfs:subClassOf owl:Thing .

:OriginPlatform a owl:Class ;
    rdfs:label "Origin Platform",
        "Origin Platform"@en ;
    :documentaryLevel "true" ;
    :frbrLevel "Expression" ;
    rdfs:comment "The social platform where the meme template first emerged. Documentary fact scraped from KnowYourMeme origin field.",
        """The online platform where a meme first appeared\r
or gained traction (e.g. Reddit, Twitter/X, 4chan, TikTok). Classified at the\r
Expression level with Documentary provenance."""@en ;
    rdfs:subClassOf owl:Thing .

:MemeFormat a owl:Class ;
    rdfs:label "Meme Format",
        "MemeFormat",
        "Meme Format"@en ;
    :frbrLevel "Expression" ;
    :semanticLevel "Iconographical" ;
    rdfs:comment "The cultural format type of the meme template. Controlled vocabulary derived from KnowYourMeme type field.",
        """The rhetorical or structural format of a meme\r
(e.g. ImageMacro, Catchphrase, Exploitable, Reaction, ViralVideo). Classifies\r
memes at the Expression level with Iconographical analysis."""@en ;
    rdfs:subClassOf owl:Thing .

:MemeConcept a owl:Class ;
    rdfs:label "Meme Concept",
        "Meme Template",
        "Meme Concept"@en ;
    :frbrLevel "Expression" ;
    rdfs:comment "The named and documented meme template as recognized by the KnowYourMeme community. Primary individual class of the ontology. 5000 individuals populated from KnowYourMeme entries.",
        """A canonical internet meme template as indexed\r
on Know Your Meme. Represents the stable, Expression-level identity of a meme\r
across all its variants. 5,000 named individuals are included, classified by\r
image type, format, platform, region and time period."""@en ;
    rdfs:subClassOf owl:Thing .

