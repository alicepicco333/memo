    rdfs:label "hasFormat" ;
    memo:frbrLevel "Expression" ;
    memo:semanticLevel "Iconographical" ;
    rdfs:comment """Links a MemeConcept to one or more MemeFormat\r\r
values describing its rhetorical structure."""@en ;
    rdfs:domain memo:MemeConcept ;
    rdfs:range memo:MemeFormat .

memo:hasId a owl:DatatypeProperty ;
    rdfs:label "hasId",
        "has ID"@en ;
    rdfs:comment "Deprecated. Use hasID instead.",
        """Numeric identifier matching the meme's position\r\r
in the scraped dataset (1–5000)."""@en ;
    rdfs:domain memo:MemeConcept ;
    rdfs:range xsd:integer ;
    owl:deprecated true .

