    rdfs:domain memo:CanonicalSubjectMatter ;
    rdfs:range memo:MemeConcept ;
    owl:inverseOf memo:hasCanonicalSubjectMatter .

memo:isCanonicalTextPresenceOf a owl:ObjectProperty ;
    rdfs:label "is Canonical Text Presence Of" ;
    rdfs:domain memo:CanonicalTextPresence ;
    rdfs:range memo:MemeConcept ;
    owl:inverseOf memo:hasCanonicalTextPresence .

memo:isColorModeOf a owl:ObjectProperty ;
    rdfs:label "is Color Mode Of" ;
    rdfs:domain memo:ColorMode ;
    rdfs:range memo:VariantInstance ;
    owl:inverseOf memo:hasColorMode .

memo:isConceptualizedAs a owl:ObjectProperty ;
    rdfs:label "isConceptualizedAs" ;
    rdfs:domain memo:MemeIdea ;
    rdfs:range memo:MemeConcept ;
    owl:inverseOf memo:conceptualizes .

memo:isFileFormatOf a owl:ObjectProperty ;
    rdfs:label "is File Format Of" ;
    rdfs:domain memo:FileFormat ;
    rdfs:range memo:MemeConcept ;
    owl:inverseOf memo:hasFileFormat .

memo:isFormatOf a owl:ObjectProperty ;
    rdfs:label "is Format Of" ;
    rdfs:domain memo:MemeFormat ;
    rdfs:range memo:MemeConcept ;
    owl:inverseOf memo:hasFormat .

memo:isImageTypeOf a owl:ObjectProperty ;
    rdfs:label "is Image Type Of" ;
    rdfs:domain memo:ImageType ;
    rdfs:range memo:VariantInstance ;
    owl:inverseOf memo:hasImageType .

memo:isManifestedIn a owl:ObjectProperty ;
    rdfs:label "is manifested in" ;
    rdfs:comment "Relates an Expression (template concept) to its Manifestations (format-specific instances)" ;
    rdfs:domain memo:Expression ;
    rdfs:range memo:Manifestation ;
    owl:inverseOf memo:hasManifestation .

memo:isOriginBoardOf a owl:ObjectProperty ;
    rdfs:label "is Origin Board Of" ;
    rdfs:domain memo:OriginBoard ;
    rdfs:range memo:MemeConcept ;
    owl:inverseOf memo:hasOriginBoard .

memo:isOriginBookOf a owl:ObjectProperty ;
