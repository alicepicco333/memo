    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdfs:label>Indonesia</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.semanticweb.org/meme-ontology#isOriginMusicOf">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:label>is Origin Music Of</rdfs:label>
    <rdfs:domain rdf:resource="http://www.semanticweb.org/meme-ontology#OriginMusic"/>
    <rdfs:range rdf:resource="http://www.semanticweb.org/meme-ontology#MemeConcept"/>
    <owl:inverseOf rdf:resource="http://www.semanticweb.org/meme-ontology#hasOriginMusic"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.semanticweb.org/meme-ontology#CanonicalImageType">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="en">Canonical Image Type</rdfs:label>
    <memo:frbrLevel>Expression</memo:frbrLevel>
    <memo:semanticLevel>PreIconographical</memo:semanticLevel>
    <rdfs:comment xml:lang="en">The visual medium of the canonical meme image&#13;&#13;&#13;&#13;&#13;&#13;
(Photograph, Drawing, Cartoon, Illustration, Painting, etc.). Pre-iconographical&#13;&#13;&#13;&#13;&#13;&#13;
classification at the Manifestation level, assigned via CLIP-based scoring.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.semanticweb.org/meme-ontology#Mali">
    <rdf:type rdf:resource="http://www.semanticweb.org/meme-ontology#GeographicRegion"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdfs:label>Mali</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.semanticweb.org/meme-ontology#Unknown">
    <rdf:type rdf:resource="http://www.semanticweb.org/meme-ontology#CanonicalSubjectMatter"/>
    <rdf:type rdf:resource="http://www.semanticweb.org/meme-ontology#MemeFormat"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdfs:label>Unknown</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.semanticweb.org/meme-ontology#variantIndex">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty"/>
    <rdfs:label>variantIndex</rdfs:label>
    <rdfs:domain rdf:resource="http://www.semanticweb.org/meme-ontology#VariantInstance"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.semanticweb.org/meme-ontology#UnknownPeriod">
    <rdf:type rdf:resource="http://www.semanticweb.org/meme-ontology#TimePeriod"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdfs:label>Unknown Period</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.semanticweb.org/meme-ontology#isOriginBookOf">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:label>is Origin Book Of</rdfs:label>
    <rdfs:domain rdf:resource="http://www.semanticweb.org/meme-ontology#OriginBook"/>
    <rdfs:range rdf:resource="http://www.semanticweb.org/meme-ontology#MemeConcept"/>
    <owl:inverseOf rdf:resource="http://www.semanticweb.org/meme-ontology#hasOriginBook"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.semanticweb.org/meme-ontology#CulturalReference">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="en">Cultural Reference</rdfs:label>
    <memo:frbrLevel>Expression Manifestation</memo:frbrLevel>
    <memo:frbrLevel>Expression, Manifestation</memo:frbrLevel>
    <memo:semanticLevel>Iconological</memo:semanticLevel>
    <rdfs:comment xml:lang="en">A cultural entity referenced by a meme — a historical&#13;&#13;&#13;&#13;&#13;&#13;
event, media property, political event, public figure, social phenomenon, or web&#13;&#13;&#13;&#13;&#13;&#13;
culture artefact. Subclasses: HistoricalEvent, MediaProperty, PoliticalEvent,&#13;&#13;&#13;&#13;&#13;&#13;
PublicFigure, SocialPhenomenon, WebCulture.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.semanticweb.org/meme-ontology#OriginPlatform">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="en">Origin Platform</rdfs:label>
    <memo:documentaryLevel>true</memo:documentaryLevel>
    <memo:frbrLevel>Expression</memo:frbrLevel>
    <rdfs:comment xml:lang="en">The online platform where a meme first appeared&#13;&#13;&#13;&#13;&#13;&#13;
or gained traction (e.g. Reddit, Twitter/X, 4chan, TikTok). Classified at the&#13;&#13;&#13;&#13;&#13;&#13;
Expression level with Documentary provenance.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.semanticweb.org/meme-ontology#ParticipatoryMedia">
    <rdf:type rdf:resource="http://www.semanticweb.org/meme-ontology#MemeFormat"/>
