  <rdf:Description rdf:about="http://purl.org/dc/terms/format">
    <rdfs:range rdf:resource="https://purl.org/memo#FileFormat"/>
    <rdfs:domain rdf:resource="https://purl.org/memo#MemeConcept"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:comment>File format of the meme image (JPEG, PNG, GIF, etc.), linked to a FileFormat individual. Uses dcterms:format to align with Dublin Core usage.</rdfs:comment>
    <rdfs:label xml:lang="en">format</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="https://purl.org/memo#hasSubjectMatter">
    <rdfs:domain rdf:nodeID="Nb3fd39c061644180917444d2f076c28e"/>
