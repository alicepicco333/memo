    <rdfs:label>hasTextPresence</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://schema.org/MusicAlbum">
    <rdfs:comment xml:lang="en">Song, album or music video from which the meme derives; subclass of OriginWork (wd:Q386724).</rdfs:comment>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://purl.org/memo#OriginWork"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://purl.org/memo#OriginWork">
    <rdfs:seeAlso rdf:resource="https://www.wikidata.org/wiki/Q386724"/>
    <rdfs:label>OriginWork</rdfs:label>
    <rdfs:comment xml:lang="en">Creative work (film, TV series, game, etc.) from which the meme derives; aligned with Wikidata Q386724.</rdfs:comment>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://purl.org/memo#MemeFormat">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:comment xml:lang="en">The genre or structural format of a meme (e.g. ImageMacro, Copypasta, ViralVideo). Drawn from Know Your Meme's type taxonomy.</rdfs:comment>
    <rdfs:label>MemeFormat</rdfs:label>
    <memo:semanticLevel>Iconographical</memo:semanticLevel>
  </rdf:Description>
  <rdf:Description rdf:about="https://purl.org/memo#TextFormat">
    <rdfs:subClassOf rdf:resource="https://purl.org/memo#MemeFormat"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:comment xml:lang="en">MemeFormat subclass grouping text-based formats: Catchphrase, Copypasta, Slang, Snowclone, Hashtag.</rdfs:comment>
    <rdfs:label>TextFormat</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="https://purl.org/memo#isTimePeriodOf">
    <rdfs:label>isTimePeriodOf</rdfs:label>
    <rdfs:range rdf:resource="https://purl.org/memo#MemeConcept"/>
    <rdfs:domain rdf:resource="https://purl.org/memo#TimePeriod"/>
