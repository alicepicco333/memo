  <rdf:Description rdf:about="https://purl.org/memo#ParticipatoryFormat">
    <rdfs:comment xml:lang="en">MemeFormat subclass grouping participatory formats: ParticipatoryMedia, Dance.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="https://purl.org/memo#MemeFormat"/>
    <rdfs:label>ParticipatoryFormat</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://purl.org/memo#MemeFormat">
    <memo:semanticLevel>Iconographical</memo:semanticLevel>
    <rdfs:comment xml:lang="en">The genre or structural format of a meme (e.g. ImageMacro, Copypasta, ViralVideo). Drawn from Know Your Meme's type taxonomy.</rdfs:comment>
    <rdfs:label>MemeFormat</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://purl.org/memo#hasImageType">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:label>hasImageType</rdfs:label>
    <rdfs:domain rdf:nodeID="N8227561913574b53b1af6f5185885fa4"/>
    <owl:inverseOf rdf:resource="https://purl.org/memo#isImageTypeOf"/>
    <rdfs:range rdf:resource="https://purl.org/memo#ImageType"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://purl.org/memo#PublicFigure">
    <rdfs:label>PublicFigure</rdfs:label>
    <rdfs:comment xml:lang="en">A public figure, celebrity, politician, or historical person referenced by a meme.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://www.wikidata.org/entity/Q96622155"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://purl.org/memo#ColorMode">
    <rdfs:comment xml:lang="en">Whether a meme image uses colour or is monochromatic (Color or Monochrome). Determined by per-pixel colour range analysis.</rdfs:comment>
    <memo:semanticLevel>PreIconographical</memo:semanticLevel>
    <rdfs:label>ColorMode</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
