    <!-- http://www.semanticweb.org/meme-ontology#AnimationStatus -->

    <owl:Class rdf:about="http://www.semanticweb.org/meme-ontology#AnimationStatus">
        <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
        <documentaryLevel>true</documentaryLevel>
        <frbrLevel>Item</frbrLevel>
        <rdfs:comment xml:lang="en">Whether a meme image is static or animated





(GIF/video).</rdfs:comment>
        <rdfs:label>AnimationStatus</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/meme-ontology#CanonicalSubjectMatter -->

    <owl:Class rdf:about="http://www.semanticweb.org/meme-ontology#CanonicalSubjectMatter"/>
    


    <!-- http://www.semanticweb.org/meme-ontology#ColorMode -->

    <owl:Class rdf:about="http://www.semanticweb.org/meme-ontology#ColorMode">
        <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
        <frbrLevel>Manifestation</frbrLevel>
        <semanticLevel>PreIconographical</semanticLevel>
        <rdfs:label>ColorMode</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/meme-ontology#CulturalReference -->

    <owl:Class rdf:about="http://www.semanticweb.org/meme-ontology#CulturalReference">
        <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
        <frbrLevel>Expression Manifestation</frbrLevel>
        <frbrLevel>Expression, Manifestation</frbrLevel>
        <semanticLevel>Iconological</semanticLevel>
        <rdfs:comment xml:lang="en">A cultural entity referenced by a meme — a historical





event, media property, political event, public figure, social phenomenon, or web





culture artefact. Subclasses: HistoricalEvent, MediaProperty, PoliticalEvent,





PublicFigure, SocialPhenomenon, WebCulture.</rdfs:comment>
        <rdfs:label>CulturalReference</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/meme-ontology#FileFormat -->

    <owl:Class rdf:about="http://www.semanticweb.org/meme-ontology#FileFormat">
        <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
        <documentaryLevel>true</documentaryLevel>
        <frbrLevel>Item</frbrLevel>
        <rdfs:comment xml:lang="en">The digital file format of the meme image (JPEG,





PNG, GIF, WebP, BMP).</rdfs:comment>
        <rdfs:label>FileFormat</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/meme-ontology#GeographicRegion -->

    <owl:Class rdf:about="http://www.semanticweb.org/meme-ontology#GeographicRegion">
        <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
        <documentaryLevel>true</documentaryLevel>
        <frbrLevel>Expression</frbrLevel>
        <rdfs:comment xml:lang="en">The country or geographic region of a meme&apos;s





origin.</rdfs:comment>
        <rdfs:label>GeographicRegion</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/meme-ontology#ImageType -->

    <owl:Class rdf:about="http://www.semanticweb.org/meme-ontology#ImageType">
        <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
        <frbrLevel>Manifestation</frbrLevel>
        <semanticLevel>PreIconographical</semanticLevel>
        <rdfs:comment xml:lang="en">The visual medium type of an individual variant





image. Uses the same controlled vocabulary as CanonicalImageType but applied at





the Item (VariantInstance) level.</rdfs:comment>
        <rdfs:label>ImageType</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/meme-ontology#MemeConcept -->

    <owl:Class rdf:about="http://www.semanticweb.org/meme-ontology#MemeConcept"/>
    


    <!-- http://www.semanticweb.org/meme-ontology#MemeFormat -->

    <owl:Class rdf:about="http://www.semanticweb.org/meme-ontology#MemeFormat">
        <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
        <frbrLevel>Expression</frbrLevel>
        <semanticLevel>Iconographical</semanticLevel>
        <rdfs:comment xml:lang="en">The rhetorical or structural format of a meme





(e.g. ImageMacro, Catchphrase, Exploitable, Reaction, ViralVideo). Classifies





memes at the Expression level with Iconographical analysis.</rdfs:comment>
        <rdfs:label>MemeFormat</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/meme-ontology#MemeIdea -->

    <owl:Class rdf:about="http://www.semanticweb.org/meme-ontology#MemeIdea">
        <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
        <frbrLevel>Work</frbrLevel>
        <rdfs:comment xml:lang="en">The abstract Work-level idea underlying a memo:





its core narrative, emotional register, rhetorical function or cultural role,





independent of any specific image or format. 50 enriched individuals from the





D0 sample, with descriptions and cultural reference annotations.</rdfs:comment>
        <rdfs:label>MemeIdea</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/meme-ontology#OriginBoard -->

    <owl:Class rdf:about="http://www.semanticweb.org/meme-ontology#OriginBoard">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/meme-ontology#OriginWork"/>
        <rdfs:label>OriginBoard</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/meme-ontology#OriginBook -->

    <owl:Class rdf:about="http://www.semanticweb.org/meme-ontology#OriginBook">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/meme-ontology#OriginWork"/>
        <rdfs:label>OriginBook</rdfs:label>
    </owl:Class>
    


