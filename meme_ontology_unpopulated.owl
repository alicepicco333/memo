  <rdf:Description rdf:about="https://purl.org/memo#SubjectMatter">
    <rdfs:label>SubjectMatter</rdfs:label>
    <memo:semanticLevel>PreIconographical</memo:semanticLevel>
    <rdfs:seeAlso rdf:resource="https://www.wikidata.org/wiki/Q16334295"/>
    <rdfs:comment xml:lang="en">The primary visual subject category depicted in a meme image (e.g. PersonPresent, AnimalPresent, ObjectOnly). Corresponds to Panofsky's pre-iconographic description level.</rdfs:comment>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://purl.org/memo#isSubjectMatterOf">
