<?xml version="1.0" encoding="utf-8"?>
<rdf:RDF
   xmlns:dcterms="http://purl.org/dc/terms/"
   xmlns:owl="http://www.w3.org/2002/07/owl#"
   xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
   xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
>
  <rdf:Description rdf:about="https://purl.org/memo">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Ontology"/>
    <owl:versionInfo>1.0</owl:versionInfo>
    <dcterms:title xml:lang="en">The Meme Ontology (MEMO)</dcterms:title>
    <dcterms:license rdf:resource="https://creativecommons.org/licenses/by/4.0/"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.wikidata.org/entity/Q11471">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label>TimePeriod</rdfs:label>
    <rdfs:comment xml:lang="en">Chronological period in which the meme originated or peaked, aligned with Wikidata Q11471.</rdfs:comment>
    <rdfs:seeAlso rdf:resource="https://www.wikidata.org/wiki/Q11471"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.wikidata.org/entity/Q16334295">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label>SubjectMatter</rdfs:label>
    <rdfs:comment xml:lang="en">Primary visual subject depicted in a meme image; corresponds to Panofsky's pre-iconographic level, aligned with Wikidata Q16334295.</rdfs:comment>
    <rdfs:seeAlso rdf:resource="https://www.wikidata.org/wiki/Q16334295"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.wikidata.org/entity/Q235557">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label>FileFormat</rdfs:label>
    <rdfs:comment xml:lang="en">Digital file format of the meme image resource, as defined by Wikidata Q235557.</rdfs:comment>
    <rdfs:seeAlso rdf:resource="https://www.wikidata.org/wiki/Q235557"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.wikidata.org/entity/Q3220391">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label>OriginPlatform</rdfs:label>
    <rdfs:comment xml:lang="en">Online platform or service where the meme was first published, aligned with Wikidata Q3220391.</rdfs:comment>
    <rdfs:seeAlso rdf:resource="https://www.wikidata.org/wiki/Q3220391"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.wikidata.org/entity/Q3249551">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label>MemeIdea</rdfs:label>
    <rdfs:comment xml:lang="en">Abstract creative idea underlying a meme template; corresponds to the FRBR Work level, aligned with Wikidata Q3249551.</rdfs:comment>
    <rdfs:seeAlso rdf:resource="https://www.wikidata.org/wiki/Q3249551"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.wikidata.org/entity/Q386724">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label>OriginWork</rdfs:label>
    <rdfs:comment xml:lang="en">Creative work (film, TV series, game, etc.) from which the meme derives, aligned with Wikidata Q386724.</rdfs:comment>
    <rdfs:seeAlso rdf:resource="https://www.wikidata.org/wiki/Q386724"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.wikidata.org/entity/Q82794">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label>GeographicRegion</rdfs:label>
    <rdfs:comment xml:lang="en">Geographic region or country of meme origin, as defined by Wikidata Q82794.</rdfs:comment>
    <rdfs:seeAlso rdf:resource="https://www.wikidata.org/wiki/Q82794"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.wikidata.org/entity/Q96622155">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label>CulturalReference</rdfs:label>
    <rdfs:comment xml:lang="en">Cultural artefact, event, or phenomenon that a meme iconologically references, aligned with Wikidata Q96622155.</rdfs:comment>
    <rdfs:seeAlso rdf:resource="https://www.wikidata.org/wiki/Q96622155"/>
  </rdf:Description>
