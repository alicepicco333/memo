<?xml version="1.0" encoding="utf-8"?>
<rdf:RDF
   xmlns:dc="http://purl.org/dc/elements/1.1/"
   xmlns:dcterms="http://purl.org/dc/terms/"
   xmlns:memo="http://www.semanticweb.org/meme-ontology#"
   xmlns:owl="http://www.w3.org/2002/07/owl#"
   xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
   xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
   xmlns:prov="http://www.w3.org/ns/prov#"
   xmlns:schema="http://schema.org/"
>
  <rdf:Description rdf:about="http://www.semanticweb.org/meme-ontology#">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Ontology"/>
    <rdfs:label xml:lang="en">Meme Ontology (MEMO)</rdfs:label>
    <dc:creator>Meme Ontology Project</dc:creator>
    <dc:description xml:lang="en">The Meme Ontology (MEMO) is an OWL 2 DL ontology for the formal description of internet memes. It models meme templates (MemeConcept), their underlying creative ideas (MemeIdea), and scraped variant images (VariantInstance) using a FRBR-aligned four-level abstraction hierarchy and Panofsky's three levels of semantic analysis. Value classes provide controlled vocabularies for format, platform, image type, transformation extent and dimension, and other classifiers. 5,000 meme concepts, 50 enriched meme ideas and 391 variant instances are included as named individuals.</dc:description>
    <dc:rights xml:lang="en">Released for academic research. Data sourced from
Know Your Meme under fair use.</dc:rights>
    <dc:title xml:lang="en">Meme Ontology (MEMO)</dc:title>
    <dcterms:abstract xml:lang="en">The Meme Ontology (MEMO) is a comprehensive OWL 2 DL ontology for the formal description and analysis of internet memes. It models the FRBR-aligned four-level abstraction hierarchy: meme templates (MemeConcept), creative instantiations (MemeIdea), variant manifestations (VariantInstance), and individual images (Item). Using Panofsky's three-level semantic analysis framework (PreIconographical, Iconographical, Iconological), the ontology provides controlled vocabularies for format classification, platform origin, image characteristics, transformation patterns, and cultural context. The schema encompasses 5,000 meme concepts, 50 enriched ideas, and 391 variant instances from Know Your Meme, enabling computational analysis of meme evolution, cultural adoption patterns, and creative transformation strategies in digital culture.</dcterms:abstract>
    <dcterms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#gYear">2024</dcterms:created>
    <dcterms:title xml:lang="en">Meme Ontology (MEMO)</dcterms:title>
    <rdfs:seeAlso rdf:resource="https://github.com/meme-ontology/meme-ontology"/>
    <owl:name>Meme Ontology (MEMO)</owl:name>
    <owl:versionInfo>1.0</owl:versionInfo>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.semanticweb.org/meme-ontology#AnimationStatus">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label>AnimationStatus</rdfs:label>
    <memo:frbrLevel>Item</memo:frbrLevel>
    <rdfs:comment xml:lang="en">Whether a meme image is static or animated
(GIF/video).</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.semanticweb.org/meme-ontology#ColorMode">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label>ColorMode</rdfs:label>
    <memo:frbrLevel>Manifestation</memo:frbrLevel>
    <memo:semanticLevel>PreIconographical</memo:semanticLevel>
    <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.semanticweb.org/meme-ontology#CulturalReference">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label>CulturalReference</rdfs:label>
    <memo:frbrLevel>Expression Manifestation</memo:frbrLevel>
    <memo:frbrLevel>Expression, Manifestation</memo:frbrLevel>
    <memo:semanticLevel>Iconological</memo:semanticLevel>
    <rdfs:comment xml:lang="en">A cultural entity referenced by a meme — a historical
event, media property, political event, public figure, social phenomenon, or web
culture artefact. Subclasses: HistoricalEvent, MediaProperty, PoliticalEvent,
PublicFigure, SocialPhenomenon, WebCulture.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.semanticweb.org/meme-ontology#FileFormat">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label>FileFormat</rdfs:label>
    <memo:frbrLevel>Item</memo:frbrLevel>
    <rdfs:comment xml:lang="en">The digital file format of the meme image (JPEG,
PNG, GIF, WebP, BMP).</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.semanticweb.org/meme-ontology#GeographicRegion">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label>GeographicRegion</rdfs:label>
    <memo:frbrLevel>Expression</memo:frbrLevel>
    <rdfs:comment xml:lang="en">The country or geographic region of a meme's
origin.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.semanticweb.org/meme-ontology#ImageType">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label>ImageType</rdfs:label>
    <memo:frbrLevel>Manifestation</memo:frbrLevel>
    <memo:semanticLevel>PreIconographical</memo:semanticLevel>
    <rdfs:comment xml:lang="en">The visual medium type of an individual variant
image. Uses the same controlled vocabulary as CanonicalImageType but applied at
the Item (VariantInstance) level.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.semanticweb.org/meme-ontology#MemeFormat">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label>MemeFormat</rdfs:label>
    <memo:frbrLevel>Expression</memo:frbrLevel>
    <memo:semanticLevel>Iconographical</memo:semanticLevel>
    <rdfs:comment xml:lang="en">The rhetorical or structural format of a meme
(e.g. ImageMacro, Catchphrase, Exploitable, Reaction, ViralVideo). Classifies
memes at the Expression level with Iconographical analysis.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.semanticweb.org/meme-ontology#MemeIdea">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label>MemeIdea</rdfs:label>
    <memo:frbrLevel>Work</memo:frbrLevel>
    <rdfs:comment xml:lang="en">The abstract Work-level idea underlying a memo:
its core narrative, emotional register, rhetorical function or cultural role,
independent of any specific image or format. 50 enriched individuals from the
D0 sample, with descriptions and cultural reference annotations.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.semanticweb.org/meme-ontology#OriginPlatform">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label>OriginPlatform</rdfs:label>
    <memo:frbrLevel>Expression</memo:frbrLevel>
    <rdfs:comment xml:lang="en">The online platform where a meme first appeared
or gained traction (e.g. Reddit, Twitter/X, 4chan, TikTok). Classified at the
Expression level with Documentary provenance.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.semanticweb.org/meme-ontology#OriginWork">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label>OriginWork</rdfs:label>
    <memo:frbrLevel>Expression</memo:frbrLevel>
    <rdfs:comment xml:lang="en">The original cultural work (film, TV show, video
game, book, song, etc.) from which a meme derives its source material.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.semanticweb.org/meme-ontology#SubjectMatter">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label>SubjectMatter</rdfs:label>
    <memo:frbrLevel>Manifestation</memo:frbrLevel>
    <memo:semanticLevel>PreIconographical</memo:semanticLevel>
    <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.semanticweb.org/meme-ontology#TextPresence">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label>TextPresence</rdfs:label>
    <memo:frbrLevel>Manifestation</memo:frbrLevel>
    <memo:semanticLevel>PreIconographical</memo:semanticLevel>
    <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.semanticweb.org/meme-ontology#TimePeriod">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label>TimePeriod</rdfs:label>
    <memo:frbrLevel>Expression</memo:frbrLevel>
    <rdfs:comment xml:lang="en">The era in which a meme originated or peaked
(Pre2010, Period2010to2015, Period2016to2020, Period2021toPresent).</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.semanticweb.org/meme-ontology#TransformationDimension">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label>TransformationDimension</rdfs:label>
    <memo:frbrLevel>Manifestation</memo:frbrLevel>
    <rdfs:comment xml:lang="en">The axis along which a variant transforms the
canonical template: CaptionChange, VisualSubstrate, MediumShift, StyleShift,
CompositionShift, CrossoverMerge, LanguageShift, Localization.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.semanticweb.org/meme-ontology#TransformationExtent">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label>TransformationExtent</rdfs:label>
    <memo:frbrLevel>Manifestation</memo:frbrLevel>
    <rdfs:comment xml:lang="en">The degree to which a variant departs from the
canonical template: Minimal (close copy), Moderate, Substantial, or Parody
(radical departure).</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.semanticweb.org/meme-ontology#VariantInstance">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label>VariantInstance</rdfs:label>
    <memo:frbrLevel>Manifestation</memo:frbrLevel>
    <rdfs:comment xml:lang="en">A single scraped variant image — an Item-level
exemplar of a MemeConcept. 391 named individuals with transformation extent and
dimension annotations for 5 fully annotated meme templates.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.semanticweb.org/meme-ontology#conceptualizes">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:label>conceptualizes</rdfs:label>
    <rdfs:domain rdf:resource="http://www.semanticweb.org/meme-ontology#MemeConcept"/>
    <rdfs:range rdf:resource="http://www.semanticweb.org/meme-ontology#MemeIdea"/>
    <owl:inverseOf rdf:resource="http://www.semanticweb.org/meme-ontology#isConceptualizedAs"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.semanticweb.org/meme-ontology#hasAnimationStatus">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:label>hasAnimationStatus</rdfs:label>
    <memo:frbrLevel>Item</memo:frbrLevel>
    <rdfs:domain rdf:resource="http://www.semanticweb.org/meme-ontology#MemeConcept"/>
    <rdfs:range rdf:resource="http://www.semanticweb.org/meme-ontology#AnimationStatus"/>
    <owl:inverseOf rdf:resource="http://www.semanticweb.org/meme-ontology#isAnimationStatusOf"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.semanticweb.org/meme-ontology#hasCanonicalColorMode">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:label>hasCanonicalColorMode</rdfs:label>
    <memo:frbrLevel>Expression</memo:frbrLevel>
    <rdfs:domain rdf:resource="http://www.semanticweb.org/meme-ontology#MemeConcept"/>
    <rdfs:range rdf:resource="http://www.semanticweb.org/meme-ontology#ColorMode"/>
    <owl:inverseOf rdf:resource="http://www.semanticweb.org/meme-ontology#isCanonicalColorModeOf"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.semanticweb.org/meme-ontology#hasCanonicalImageType">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:label>hasCanonicalImageType</rdfs:label>
    <memo:frbrLevel>Expression</memo:frbrLevel>
    <rdfs:comment xml:lang="en">The visual medium of the canonical meme image,
assigned by CLIP-based classification.</rdfs:comment>
    <rdfs:domain rdf:resource="http://www.semanticweb.org/meme-ontology#MemeConcept"/>
    <rdfs:range rdf:resource="http://www.semanticweb.org/meme-ontology#ImageType"/>
    <owl:inverseOf rdf:resource="http://www.semanticweb.org/meme-ontology#isCanonicalImageTypeOf"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.semanticweb.org/meme-ontology#hasCanonicalSubjectMatter">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:label>hasCanonicalSubjectMatter</rdfs:label>
    <memo:frbrLevel>Expression</memo:frbrLevel>
    <rdfs:comment>What is inherently built into the base meme template (Expression level).</rdfs:comment>
    <rdfs:domain rdf:resource="http://www.semanticweb.org/meme-ontology#MemeConcept"/>
    <rdfs:range rdf:resource="http://www.semanticweb.org/meme-ontology#SubjectMatter"/>
    <owl:inverseOf rdf:resource="http://www.semanticweb.org/meme-ontology#isCanonicalSubjectMatterOf"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.semanticweb.org/meme-ontology#hasCanonicalTextPresence">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:label>hasCanonicalTextPresence</rdfs:label>
    <memo:frbrLevel>Expression</memo:frbrLevel>
    <rdfs:domain rdf:resource="http://www.semanticweb.org/meme-ontology#MemeConcept"/>
    <rdfs:range rdf:resource="http://www.semanticweb.org/meme-ontology#TextPresence"/>
    <owl:inverseOf rdf:resource="http://www.semanticweb.org/meme-ontology#isCanonicalTextPresenceOf"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.semanticweb.org/meme-ontology#hasFormat">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:label>hasFormat</rdfs:label>
    <memo:frbrLevel>Expression</memo:frbrLevel>
    <memo:semanticLevel>Iconographical</memo:semanticLevel>
    <rdfs:comment xml:lang="en">Links a MemeConcept to one or more MemeFormat
values describing its rhetorical structure.</rdfs:comment>
    <rdfs:domain rdf:resource="http://www.semanticweb.org/meme-ontology#MemeConcept"/>
    <rdfs:range rdf:resource="http://www.semanticweb.org/meme-ontology#MemeFormat"/>
    <owl:inverseOf rdf:resource="http://www.semanticweb.org/meme-ontology#isFormatOf"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.semanticweb.org/meme-ontology#hasOriginPlatform">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:label>hasOriginPlatform</rdfs:label>
    <rdfs:domain rdf:resource="http://www.semanticweb.org/meme-ontology#MemeConcept"/>
    <rdfs:range rdf:resource="http://www.semanticweb.org/meme-ontology#OriginPlatform"/>
    <owl:inverseOf rdf:resource="http://www.semanticweb.org/meme-ontology#isOriginPlatformOf"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.semanticweb.org/meme-ontology#hasOriginWork">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:label>hasOriginWork</rdfs:label>
    <memo:frbrLevel>Expression</memo:frbrLevel>
    <rdfs:comment xml:lang="en">Links a MemeConcept to the cultural Work it
derives from or references.</rdfs:comment>
    <rdfs:domain rdf:resource="http://www.semanticweb.org/meme-ontology#MemeConcept"/>
    <rdfs:range rdf:resource="http://www.semanticweb.org/meme-ontology#OriginWork"/>
    <owl:inverseOf rdf:resource="http://www.semanticweb.org/meme-ontology#isOriginWorkOf"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.semanticweb.org/meme-ontology#hasReference">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:label>hasReference</rdfs:label>
    <rdfs:domain rdf:resource="http://www.semanticweb.org/meme-ontology#MemeConcept"/>
    <rdfs:range rdf:resource="http://www.semanticweb.org/meme-ontology#CulturalReference"/>
    <owl:inverseOf rdf:resource="http://www.semanticweb.org/meme-ontology#isReferencedIn"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.semanticweb.org/meme-ontology#hasRegion">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:label>hasRegion</rdfs:label>
    <rdfs:comment xml:lang="en">The geographic region of a meme's origin or
primary circulation.</rdfs:comment>
    <rdfs:domain rdf:resource="http://www.semanticweb.org/meme-ontology#MemeConcept"/>
    <rdfs:range rdf:resource="http://www.semanticweb.org/meme-ontology#GeographicRegion"/>
    <owl:inverseOf rdf:resource="http://www.semanticweb.org/meme-ontology#isRegionOf"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.semanticweb.org/meme-ontology#hasTimePeriod">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:label>hasTimePeriod</rdfs:label>
    <rdfs:domain rdf:resource="http://www.semanticweb.org/meme-ontology#MemeConcept"/>
    <rdfs:range rdf:resource="http://www.semanticweb.org/meme-ontology#TimePeriod"/>
    <owl:inverseOf rdf:resource="http://www.semanticweb.org/meme-ontology#isTimePeriodOf"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.semanticweb.org/meme-ontology#hasTransformationDimension">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:label>hasTransformationDimension</rdfs:label>
    <rdfs:domain rdf:resource="http://www.semanticweb.org/meme-ontology#VariantInstance"/>
    <rdfs:range rdf:resource="http://www.semanticweb.org/meme-ontology#TransformationDimension"/>
    <owl:inverseOf rdf:resource="http://www.semanticweb.org/meme-ontology#isTransformationDimensionOf"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.semanticweb.org/meme-ontology#hasTransformationExtent">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:label>hasTransformationExtent</rdfs:label>
    <rdfs:domain rdf:resource="http://www.semanticweb.org/meme-ontology#VariantInstance"/>
    <rdfs:range rdf:resource="http://www.semanticweb.org/meme-ontology#TransformationExtent"/>
    <owl:inverseOf rdf:resource="http://www.semanticweb.org/meme-ontology#isTransformationExtentOf"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.semanticweb.org/meme-ontology#hasVariant">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:label>hasVariant</rdfs:label>
    <rdfs:domain rdf:resource="http://www.semanticweb.org/meme-ontology#MemeConcept"/>
    <rdfs:range rdf:resource="http://www.semanticweb.org/meme-ontology#VariantInstance"/>
    <owl:inverseOf rdf:resource="http://www.semanticweb.org/meme-ontology#isVariantOf"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.semanticweb.org/meme-ontology#hasVariantColorMode">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:label>hasVariantColorMode</rdfs:label>
    <rdfs:comment>The specific color profile applied to a user-created variant.</rdfs:comment>
    <rdfs:domain rdf:resource="http://www.semanticweb.org/meme-ontology#VariantInstance"/>
    <rdfs:range rdf:resource="http://www.semanticweb.org/meme-ontology#ColorMode"/>
    <owl:inverseOf rdf:resource="http://www.semanticweb.org/meme-ontology#isVariantColorModeOf"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.semanticweb.org/meme-ontology#hasVariantImageType">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:label>hasVariantImageType</rdfs:label>
    <rdfs:comment>The specific image type of a user-created variant.</rdfs:comment>
    <rdfs:domain rdf:resource="http://www.semanticweb.org/meme-ontology#VariantInstance"/>
    <rdfs:range rdf:resource="http://www.semanticweb.org/meme-ontology#ImageType"/>
    <owl:inverseOf rdf:resource="http://www.semanticweb.org/meme-ontology#isVariantImageTypeOf"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.semanticweb.org/meme-ontology#hasVariantSubjectMatter">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:label>hasVariantSubjectMatter</rdfs:label>
    <rdfs:comment>What a specific user added or changed when they created their individual variation (Manifestation/Item level).</rdfs:comment>
    <rdfs:domain rdf:resource="http://www.semanticweb.org/meme-ontology#VariantInstance"/>
    <rdfs:range rdf:resource="http://www.semanticweb.org/meme-ontology#SubjectMatter"/>
    <owl:inverseOf rdf:resource="http://www.semanticweb.org/meme-ontology#isVariantSubjectMatterOf"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.semanticweb.org/meme-ontology#hasVariantTextPresence">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:label>hasVariantTextPresence</rdfs:label>
    <rdfs:comment>Whether a user-created variant includes text or not.</rdfs:comment>
    <rdfs:domain rdf:resource="http://www.semanticweb.org/meme-ontology#VariantInstance"/>
    <rdfs:range rdf:resource="http://www.semanticweb.org/meme-ontology#TextPresence"/>
    <owl:inverseOf rdf:resource="http://www.semanticweb.org/meme-ontology#isVariantTextPresenceOf"/>
