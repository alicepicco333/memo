  </rdf:Description>
  <rdf:Description rdf:about="https://purl.org/memo#hasTransformationExtent">
    <rdfs:range rdf:resource="https://purl.org/memo#TransformationExtent"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:label>hasTransformationExtent</rdfs:label>
    <owl:inverseOf rdf:resource="https://purl.org/memo#isTransformationExtentOf"/>
    <rdfs:domain rdf:resource="https://purl.org/memo#VariantInstance"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://purl.org/memo#TransformationExtent">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label>TransformationExtent</rdfs:label>
    <rdfs:comment xml:lang="en">The degree to which a VariantInstance diverges from its source template (e.g. Minimal, Moderate, Major). Enables quantitative analysis of meme mutation.</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.wikidata.org/prop/direct/P2283">
    <rdfs:domain rdf:resource="https://purl.org/memo#MemeConcept"/>
    <rdfs:label>hasFormat</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <owl:inverseOf rdf:resource="https://purl.org/memo#isFormatOf"/>
    <rdfs:range rdf:resource="https://purl.org/memo#MemeFormat"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://purl.org/memo">
    <dc:creator>Alice Picco</dc:creator>
