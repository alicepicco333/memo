    <owl:Class rdf:about="http://www.semanticweb.org/meme-ontology#OriginFilm">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/meme-ontology#OriginWork"/>
        <rdfs:label>OriginFilm</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/meme-ontology#OriginMusic -->

    <owl:Class rdf:about="http://www.semanticweb.org/meme-ontology#OriginMusic">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/meme-ontology#OriginWork"/>
        <rdfs:label>OriginMusic</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/meme-ontology#OriginPerson -->

    <owl:Class rdf:about="http://www.semanticweb.org/meme-ontology#OriginPerson">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/meme-ontology#OriginWork"/>
        <rdfs:label>OriginPerson</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/meme-ontology#OriginPlatform -->

    <owl:Class rdf:about="http://www.semanticweb.org/meme-ontology#OriginPlatform">
        <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
        <documentaryLevel>true</documentaryLevel>
        <frbrLevel>Expression</frbrLevel>
        <rdfs:comment xml:lang="en">The online platform where a meme first appeared





or gained traction (e.g. Reddit, Twitter/X, 4chan, TikTok). Classified at the





Expression level with Documentary provenance.</rdfs:comment>
        <rdfs:label>OriginPlatform</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/meme-ontology#OriginTVShow -->

    <owl:Class rdf:about="http://www.semanticweb.org/meme-ontology#OriginTVShow">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/meme-ontology#OriginWork"/>
        <rdfs:label>OriginTVShow</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/meme-ontology#OriginVideoGame -->

    <owl:Class rdf:about="http://www.semanticweb.org/meme-ontology#OriginVideoGame">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/meme-ontology#OriginWork"/>
        <rdfs:label>OriginVideoGame</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/meme-ontology#OriginWork -->

    <owl:Class rdf:about="http://www.semanticweb.org/meme-ontology#OriginWork">
        <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
        <documentaryLevel>true</documentaryLevel>
        <frbrLevel>Expression</frbrLevel>
        <rdfs:comment xml:lang="en">The original cultural work (film, TV show, video





game, book, song, etc.) from which a meme derives its source material.</rdfs:comment>
        <rdfs:label>OriginWork</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/meme-ontology#SubjectMatter -->

    <owl:Class rdf:about="http://www.semanticweb.org/meme-ontology#SubjectMatter">
        <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
        <frbrLevel>Manifestation</frbrLevel>
        <semanticLevel>PreIconographical</semanticLevel>
        <rdfs:label>SubjectMatter</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/meme-ontology#TextPresence -->

    <owl:Class rdf:about="http://www.semanticweb.org/meme-ontology#TextPresence">
        <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
        <frbrLevel>Manifestation</frbrLevel>
        <semanticLevel>PreIconographical</semanticLevel>
        <rdfs:label>TextPresence</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/meme-ontology#TimePeriod -->

    <owl:Class rdf:about="http://www.semanticweb.org/meme-ontology#TimePeriod">
        <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
        <documentaryLevel>true</documentaryLevel>
        <frbrLevel>Expression</frbrLevel>
        <rdfs:comment xml:lang="en">The era in which a meme originated or peaked





(Pre2010, Period2010to2015, Period2016to2020, Period2021toPresent).</rdfs:comment>
        <rdfs:label>TimePeriod</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/meme-ontology#TransformationDimension -->

    <owl:Class rdf:about="http://www.semanticweb.org/meme-ontology#TransformationDimension">
        <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
        <documentaryLevel>true</documentaryLevel>
        <frbrLevel>Manifestation</frbrLevel>
        <rdfs:comment xml:lang="en">The axis along which a variant transforms the





canonical template: CaptionChange, VisualSubstrate, MediumShift, StyleShift,





CompositionShift, CrossoverMerge, LanguageShift, Localization.</rdfs:comment>
        <rdfs:label>TransformationDimension</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/meme-ontology#TransformationExtent -->

    <owl:Class rdf:about="http://www.semanticweb.org/meme-ontology#TransformationExtent">
        <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
        <documentaryLevel>true</documentaryLevel>
        <frbrLevel>Manifestation</frbrLevel>
        <rdfs:comment xml:lang="en">The degree to which a variant departs from the





canonical template: Minimal (close copy), Moderate, Substantial, or Parody





(radical departure).</rdfs:comment>
        <rdfs:label>TransformationExtent</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/meme-ontology#VariantInstance -->

    <owl:Class rdf:about="http://www.semanticweb.org/meme-ontology#VariantInstance">
        <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
        <frbrLevel>Manifestation</frbrLevel>
        <rdfs:comment xml:lang="en">A single scraped variant image — an Item-level





exemplar of a MemeConcept. 391 named individuals with transformation extent and





dimension annotations for 5 fully annotated meme templates.</rdfs:comment>
        <rdfs:label>VariantInstance</rdfs:label>
    </owl:Class>
    


