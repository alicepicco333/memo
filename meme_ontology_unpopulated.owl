    <!-- http://www.w3.org/2001/XMLSchema#gYear -->

    <rdfs:Datatype rdf:about="http://www.w3.org/2001/XMLSchema#gYear"/>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Object Properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- http://www.semanticweb.org/meme-ontology#conceptualizes -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/meme-ontology#conceptualizes">
        <owl:inverseOf rdf:resource="http://www.semanticweb.org/meme-ontology#isConceptualizedAs"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/meme-ontology#MemeConcept"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/meme-ontology#MemeIdea"/>
        <rdfs:label>conceptualizes</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/meme-ontology#hasAnimationStatus -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/meme-ontology#hasAnimationStatus">
        <owl:inverseOf rdf:resource="http://www.semanticweb.org/meme-ontology#isAnimationStatusOf"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/meme-ontology#MemeConcept"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/meme-ontology#AnimationStatus"/>
        <frbrLevel>Manifestation</frbrLevel>
        <semanticLevel>PreIconographical</semanticLevel>
        <rdfs:label>hasAnimationStatus</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/meme-ontology#hasCanonicalColorMode -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/meme-ontology#hasCanonicalColorMode">
        <owl:inverseOf rdf:resource="http://www.semanticweb.org/meme-ontology#isCanonicalColorModeOf"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/meme-ontology#MemeConcept"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/meme-ontology#ColorMode"/>
        <frbrLevel>Manifestation</frbrLevel>
        <semanticLevel>PreIconographical</semanticLevel>
        <rdfs:label>hasCanonicalColorMode</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/meme-ontology#hasCanonicalImageType -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/meme-ontology#hasCanonicalImageType">
        <owl:inverseOf rdf:resource="http://www.semanticweb.org/meme-ontology#isCanonicalImageTypeOf"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/meme-ontology#MemeConcept"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/meme-ontology#ImageType"/>
        <frbrLevel>Manifestation</frbrLevel>
        <semanticLevel>PreIconographical</semanticLevel>
        <rdfs:comment xml:lang="en">The visual medium of the canonical meme image,





assigned by CLIP-based classification.</rdfs:comment>
        <rdfs:label>hasCanonicalImageType</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/meme-ontology#hasCanonicalSubjectMatter -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/meme-ontology#hasCanonicalSubjectMatter">
        <owl:inverseOf rdf:resource="http://www.semanticweb.org/meme-ontology#isCanonicalSubjectMatterOf"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/meme-ontology#MemeConcept"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/meme-ontology#SubjectMatter"/>
        <frbrLevel>Manifestation</frbrLevel>
        <semanticLevel>PreIconographical</semanticLevel>
        <rdfs:comment>What is inherently built into the base meme template (Expression level).</rdfs:comment>
        <rdfs:label>hasCanonicalSubjectMatter</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/meme-ontology#hasCanonicalTextPresence -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/meme-ontology#hasCanonicalTextPresence">
        <owl:inverseOf rdf:resource="http://www.semanticweb.org/meme-ontology#isCanonicalTextPresenceOf"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/meme-ontology#MemeConcept"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/meme-ontology#TextPresence"/>
        <frbrLevel>Manifestation</frbrLevel>
        <semanticLevel>PreIconographical</semanticLevel>
        <rdfs:label>hasCanonicalTextPresence</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/meme-ontology#hasColorMode -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/meme-ontology#hasColorMode">
        <owl:inverseOf rdf:resource="http://www.semanticweb.org/meme-ontology#isColorModeOf"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/meme-ontology#VariantInstance"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/meme-ontology#ColorMode"/>
        <rdfs:label>hasColorMode</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/meme-ontology#hasFileFormat -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/meme-ontology#hasFileFormat">
        <owl:inverseOf rdf:resource="http://www.semanticweb.org/meme-ontology#isFileFormatOf"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/meme-ontology#MemeConcept"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/meme-ontology#FileFormat"/>
        <frbrLevel>Manifestation</frbrLevel>
        <semanticLevel>PreIconographical</semanticLevel>
        <rdfs:label>hasFileFormat</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/meme-ontology#hasFormat -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/meme-ontology#hasFormat">
        <owl:inverseOf rdf:resource="http://www.semanticweb.org/meme-ontology#isFormatOf"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/meme-ontology#MemeConcept"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/meme-ontology#MemeFormat"/>
        <frbrLevel>Expression</frbrLevel>
        <semanticLevel>Iconographical</semanticLevel>
        <rdfs:comment xml:lang="en">Links a MemeConcept to one or more MemeFormat





values describing its rhetorical structure.</rdfs:comment>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/meme-ontology#hasImageType -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/meme-ontology#hasImageType">
        <owl:inverseOf rdf:resource="http://www.semanticweb.org/meme-ontology#isImageTypeOf"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/meme-ontology#VariantInstance"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/meme-ontology#ImageType"/>
        <rdfs:label>hasImageType</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/meme-ontology#hasOriginBoard -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/meme-ontology#hasOriginBoard">
        <owl:inverseOf rdf:resource="http://www.semanticweb.org/meme-ontology#isOriginBoardOf"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/meme-ontology#MemeConcept"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/meme-ontology#OriginBoard"/>
        <documentaryLevel>true</documentaryLevel>
        <frbrLevel>Expression</frbrLevel>
        <rdfs:comment xml:lang="en">Links a MemeConcept to the specific imageboard





or forum thread where it originated.</rdfs:comment>
        <rdfs:label>hasOriginBoard</rdfs:label>
    </owl:ObjectProperty>
    


