        <rdfs:comment xml:lang="en">Links a MemeConcept to the cultural Work it
derives from or references.</rdfs:comment>
        <rdfs:label>hasOriginWork</rdfs:label>
    </owl:ObjectProperty>
<owl:ObjectProperty rdf:about="http://www.semanticweb.org/meme-ontology#hasReference">
