  <rdf:Description rdf:about="http://www.semanticweb.org/meme-ontology#semanticLevel">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#AnnotationProperty"/>
    <rdfs:label>Semantic Level</rdfs:label>
    <rdfs:label xml:lang="en">semantic level</rdfs:label>
    <rdfs:comment>Records the Panofsky semantic level of the information encoded by this class. Values: PreIconographical, Iconographical, Iconological.</rdfs:comment>
    <rdfs:comment xml:lang="en">Associates a class or property with a Panofsky&#13;
level of iconological analysis: PreIconographical, Iconographical, or&#13;
Iconological.</rdfs:comment>
  </rdf:Description>
