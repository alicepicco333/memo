  <rdf:Description rdf:about="http://www.semanticweb.org/meme-ontology#CulturalReference">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label>Cultural Reference</rdfs:label>
    <rdfs:label>CulturalReference</rdfs:label>
    <rdfs:label xml:lang="en">Cultural Reference</rdfs:label>
    <frbrLevel>Expression Manifestation</frbrLevel>
    <frbrLevel>Expression, Manifestation</frbrLevel>
    <semanticLevel>Iconological</semanticLevel>
    <rdfs:comment>The cultural phenomena encoded by a meme template. At Expression level: template-wide references. At Manifestation level: variant-specific references.</rdfs:comment>
    <rdfs:comment xml:lang="en">A cultural entity referenced by a meme — a historical&#13;
event, media property, political event, public figure, social phenomenon, or web&#13;
culture artefact. Subclasses: HistoricalEvent, MediaProperty, PoliticalEvent,&#13;
PublicFigure, SocialPhenomenon, WebCulture.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
  </rdf:Description>
