<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/meme-ontology#photoURL">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/meme-ontology#VariantInstance"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
