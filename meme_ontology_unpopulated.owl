    <owl:AnnotationProperty rdf:about="http://www.semanticweb.org/meme-ontology#semanticLevel"/>
    


    <!-- http://www.w3.org/2002/07/owl#name -->

    <owl:AnnotationProperty rdf:about="http://www.w3.org/2002/07/owl#name"/>
    


