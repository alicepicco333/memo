    <rdfs:domain rdf:resource="https://purl.org/memo#MemeIdea"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty"/>
    <rdfs:label>conceptDescription</rdfs:label>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://purl.org/memo#views">
    <rdfs:domain rdf:resource="https://purl.org/memo#MemeConcept"/>
    <rdfs:label>views</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://purl.org/memo#SocialPhenomenon">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://purl.org/memo#CulturalReference"/>
    <rdfs:comment xml:lang="en">A social movement, behavioural trend, or cultural practice referenced by a meme.</rdfs:comment>
    <rdfs:label>SocialPhenomenon</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="https://purl.org/memo#hasAnimationStatus">
    <owl:inverseOf rdf:resource="https://purl.org/memo#isAnimationStatusOf"/>
    <rdfs:label>hasAnimationStatus</rdfs:label>
    <rdfs:domain rdf:resource="https://purl.org/memo#MemeConcept"/>
    <rdfs:range rdf:resource="https://purl.org/memo#AnimationStatus"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://purl.org/memo#hasSubjectMatter">
    <owl:inverseOf rdf:resource="https://purl.org/memo#isSubjectMatterOf"/>
