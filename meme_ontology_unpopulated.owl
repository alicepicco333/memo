  <rdf:Description rdf:about="http://www.semanticweb.org/meme-ontology#SubjectMatter">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label>SubjectMatter</rdfs:label>
    <frbrLevel>Manifestation</frbrLevel>
    <semanticLevel>PreIconographical</semanticLevel>
    <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.semanticweb.org/meme-ontology#UnknownPeriod">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label>Unknown Period</rdfs:label>
