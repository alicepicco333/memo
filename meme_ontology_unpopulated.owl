    <documentaryLevel>true</documentaryLevel>
    <frbrLevel>Expression</frbrLevel>
    <rdfs:comment>The social platform where the meme template first emerged. Documentary fact scraped from KnowYourMeme origin field.</rdfs:comment>
    <rdfs:comment xml:lang="en">The online platform where a meme first appeared&#13;
or gained traction (e.g. Reddit, Twitter/X, 4chan, TikTok). Classified at the&#13;
Expression level with Documentary provenance.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.semanticweb.org/meme-ontology#TransformationDimension">
