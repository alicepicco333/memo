  <rdf:Description rdf:about="http://www.semanticweb.org/meme-ontology#MemeFormat">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label>Meme Format</rdfs:label>
    <rdfs:label>MemeFormat</rdfs:label>
    <rdfs:label xml:lang="en">Meme Format</rdfs:label>
    <frbrLevel>Expression</frbrLevel>
    <semanticLevel>Iconographical</semanticLevel>
    <rdfs:comment>The cultural format type of the meme template. Controlled vocabulary derived from KnowYourMeme type field.</rdfs:comment>
    <rdfs:comment xml:lang="en">The rhetorical or structural format of a meme&#13;
(e.g. ImageMacro, Catchphrase, Exploitable, Reaction, ViralVideo). Classifies&#13;
memes at the Expression level with Iconographical analysis.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
  </rdf:Description>
