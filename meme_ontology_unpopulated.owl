>
  <rdf:Description rdf:about="http://www.wikidata.org/prop/direct/P495">
    <rdfs:domain rdf:resource="https://purl.org/memo#MemeConcept"/>
    <owl:inverseOf rdf:resource="https://purl.org/memo#isRegionOf"/>
    <rdfs:label>hasRegion</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:range rdf:resource="https://purl.org/memo#GeographicRegion"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://purl.org/memo#CulturalReference">
    <rdfs:comment xml:lang="en">Cultural artefact, event, or phenomenon that a meme iconologically references; aligned with Wikidata Q96622155.</rdfs:comment>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:seeAlso rdf:resource="https://www.wikidata.org/wiki/Q96622155"/>
    <rdfs:label>CulturalReference</rdfs:label>
    <memo:semanticLevel>Iconological</memo:semanticLevel>
  </rdf:Description>
  <rdf:Description rdf:about="https://purl.org/memo#variantIndex">
    <rdfs:domain rdf:resource="https://purl.org/memo#VariantInstance"/>
    <rdfs:label>variantIndex</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.wikidata.org/prop/direct/P123">
    <rdfs:range rdf:resource="https://purl.org/memo#OriginPlatform"/>
    <rdfs:label>hasOriginPlatform</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <owl:inverseOf rdf:resource="https://purl.org/memo#isOriginPlatformOf"/>
    <rdfs:domain rdf:resource="https://purl.org/memo#MemeConcept"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://purl.org/memo#WebCulture">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label>WebCulture</rdfs:label>
    <rdfs:comment xml:lang="en">A web-native cultural phenomenon, community, or trend referenced by a meme.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="https://purl.org/memo#CulturalReference"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://purl.org/memo#conceptualizes">
    <rdfs:label>conceptualizes</rdfs:label>
    <rdfs:domain rdf:resource="https://purl.org/memo#MemeConcept"/>
    <owl:inverseOf rdf:resource="https://purl.org/memo#isConceptualizedAs"/>
    <rdfs:range rdf:resource="https://purl.org/memo#MemeIdea"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://purl.org/memo#hasImageType">
    <owl:inverseOf rdf:resource="https://purl.org/memo#isImageTypeOf"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:range rdf:resource="https://purl.org/memo#ImageType"/>
    <rdfs:domain rdf:nodeID="N7ffcdc8f12704bf389b69612c39b1d15"/>
    <rdfs:label>hasImageType</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="https://purl.org/memo#isOriginWorkOf">
    <rdfs:range rdf:resource="https://purl.org/memo#MemeConcept"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:domain rdf:resource="https://purl.org/memo#OriginWork"/>
    <rdfs:label>isOriginWorkOf</rdfs:label>
    <owl:inverseOf rdf:resource="https://purl.org/memo#hasOriginWork"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://purl.org/memo#MemeIdea">
    <rdfs:comment xml:lang="en">The abstract creative idea underlying a meme template; the Work level of the FRBR hierarchy. Represents the core concept, emotional register, or rhetorical function of a meme, independent of any specific image or format.</rdfs:comment>
    <rdfs:label>MemeIdea</rdfs:label>
    <rdfs:subClassOf rdf:resource="http://iflastandards.info/ns/fr/frbr/frbrer/C1002"/>
    <memo:frbrLevel>Work</memo:frbrLevel>
    <rdfs:seeAlso rdf:resource="https://www.wikidata.org/wiki/Q3249551"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://purl.org/memo#imageFilePath">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    <rdfs:label>imageFilePath</rdfs:label>
    <rdfs:domain rdf:resource="https://purl.org/memo#MemeConcept"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://purl.org/memo#MediaProperty">
    <rdfs:subClassOf rdf:resource="https://purl.org/memo#CulturalReference"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:comment xml:lang="en">A media franchise, film, TV series, game, or other creative property referenced by a meme.</rdfs:comment>
    <rdfs:label>MediaProperty</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://purl.org/dc/terms/modified">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#AnnotationProperty"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    <rdfs:domain rdf:resource="https://purl.org/memo#MemeConcept"/>
    <rdfs:label>modified</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="https://purl.org/memo#PublicFigure">
    <rdfs:subClassOf rdf:resource="https://purl.org/memo#CulturalReference"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label>PublicFigure</rdfs:label>
    <rdfs:comment xml:lang="en">A public figure, celebrity, politician, or historical person referenced by a meme.</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="https://purl.org/memo#MemeConcept">
    <rdfs:label>MemeConcept</rdfs:label>
    <rdfs:subClassOf rdf:resource="http://iflastandards.info/ns/fr/frbr/frbrer/C1003"/>
    <memo:frbrLevel>Expression</memo:frbrLevel>
    <rdfs:comment xml:lang="en">A meme template or canonical format; the Expression level of the FRBR hierarchy. Represents the stable, recognisable form of a meme as documented on Know Your Meme.</rdfs:comment>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://purl.org/memo#hasReference">
    <rdfs:range rdf:resource="https://purl.org/memo#CulturalReference"/>
    <rdfs:domain rdf:resource="https://purl.org/memo#MemeConcept"/>
    <owl:equivalentProperty rdf:resource="http://www.wikidata.org/prop/direct/P8371"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <owl:inverseOf rdf:resource="https://purl.org/memo#isReferencedIn"/>
    <rdfs:label>hasReference</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="https://purl.org/memo#imageFilename">
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty"/>
    <rdfs:domain rdf:resource="https://purl.org/memo#MemeConcept"/>
    <rdfs:label>imageFilename</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="https://purl.org/memo#captionText">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty"/>
    <rdfs:domain rdf:resource="https://purl.org/memo#VariantInstance"/>
    <rdfs:label>captionText</rdfs:label>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://purl.org/memo#ImageManipulationFormat">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:comment xml:lang="en">MemeFormat subclass grouping image manipulation formats: Exploitable, ImageMacro, Photoshop, Remix.</rdfs:comment>
    <rdfs:label>ImageManipulationFormat</rdfs:label>
    <rdfs:subClassOf rdf:resource="https://purl.org/memo#MemeFormat"/>
  </rdf:Description>
