  </rdf:Description>
  <rdf:Description rdf:about="https://purl.org/memo#HistoricalEvent">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:comment xml:lang="en">A historical event, period, or crisis referenced by a meme.</rdfs:comment>
    <rdfs:label>HistoricalEvent</rdfs:label>
    <rdfs:subClassOf rdf:resource="https://purl.org/memo#CulturalReference"/>
  </rdf:Description>
