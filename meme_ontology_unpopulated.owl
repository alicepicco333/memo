    <rdf:Description rdf:about="http://www.semanticweb.org/meme-ontology#MemeConcept">
        <frbrLevel>Expression</frbrLevel>
        <rdfs:comment xml:lang="en">A canonical internet meme template as indexed
on Know Your Meme. Represents the stable, Expression-level identity of a meme
across all its variants. 5,000 named individuals are included, classified by
image type, format, platform, region and time period.</rdfs:comment>
        <rdfs:comment>The named and documented meme template as recognized by the KnowYourMeme community. Primary individual class of the ontology. 5000 individuals populated from KnowYourMeme entries.</rdfs:comment>
        <rdfs:label>Meme Concept</rdfs:label>
        <rdfs:label xml:lang="en">Meme Concept</rdfs:label>
        <rdfs:label>Meme Template</rdfs:label>
    </rdf:Description>
