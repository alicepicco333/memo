  <rdf:Description rdf:about="https://purl.org/memo#ImageType">
    <rdfs:comment xml:lang="en">The visual medium or rendering technique of a meme image (e.g. Photograph, Drawing, Cartoon). Corresponds to Panofsky's pre-iconographic description.</rdfs:comment>
    <memo:semanticLevel>PreIconographical</memo:semanticLevel>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label>ImageType</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="https://purl.org/memo#TextPresence">
    <rdfs:comment xml:lang="en">Whether visible text is present in a meme image (ContainsText or NoText). Detected automatically via CLIP and EasyOCR.</rdfs:comment>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <memo:semanticLevel>PreIconographical</memo:semanticLevel>
    <rdfs:label>TextPresence</rdfs:label>
  </rdf:Description>
