    </owl:ObjectProperty>
<owl:ObjectProperty rdf:about="http://www.semanticweb.org/meme-ontology#hasOriginComic">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/meme-ontology#MemeConcept"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/meme-ontology#OriginComic"/>
        <rdfs:label>hasOriginComic</rdfs:label>
