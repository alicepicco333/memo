  <rdf:Description rdf:about="https://purl.org/memo#MemeFormat">
    <memo:semanticLevel>Iconographical</memo:semanticLevel>
    <rdfs:label>MemeFormat</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:comment xml:lang="en">The genre or structural format of a meme (e.g. ImageMacro, Copypasta, ViralVideo). Drawn from Know Your Meme's type taxonomy.</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="https://purl.org/memo">
    <dc:creator>Alice Picco</dc:creator>
    <owl:versionInfo>1.0</owl:versionInfo>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Ontology"/>
    <dcterms:title xml:lang="en">The Meme Ontology (MEMO)</dcterms:title>
    <dcterms:license rdf:resource="https://creativecommons.org/licenses/by/4.0/"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="Nc154c89f1cc34a47ad26e5ccf5ab7013">
    <rdf:rest rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#nil"/>
    <rdf:first rdf:resource="https://purl.org/memo#VariantInstance"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://purl.org/memo#CulturalReference">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label>CulturalReference</rdfs:label>
    <rdfs:comment xml:lang="en">Cultural artefact, event, or phenomenon that a meme iconologically references; aligned with Wikidata Q96622155.</rdfs:comment>
    <rdfs:seeAlso rdf:resource="https://www.wikidata.org/wiki/Q96622155"/>
    <memo:semanticLevel>Iconological</memo:semanticLevel>
  </rdf:Description>
  <rdf:Description rdf:about="https://purl.org/memo#VariantInstance">
    <memo:frbrLevel>Manifestation</memo:frbrLevel>
    <rdfs:label>VariantInstance</rdfs:label>
    <rdfs:subClassOf rdf:resource="http://iflastandards.info/ns/fr/frbr/frbrer/C1004"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:comment xml:lang="en">A specific image derived from a meme template; the Manifestation level of the FRBR hierarchy. Represents a single scraped or documented instantiation of a MemeConcept.</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="https://purl.org/memo#hasTransformationDimension">
    <owl:inverseOf rdf:resource="https://purl.org/memo#isTransformationDimensionOf"/>
    <rdfs:label>hasTransformationDimension</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:range rdf:resource="https://purl.org/memo#TransformationDimension"/>
    <rdfs:domain rdf:resource="https://purl.org/memo#VariantInstance"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://purl.org/memo#hasTextPresence">
    <rdfs:label>hasTextPresence</rdfs:label>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty"/>
    <rdfs:domain rdf:resource="https://purl.org/memo#MemeConcept"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://purl.org/memo#hasImageType">
    <rdfs:range rdf:resource="https://purl.org/memo#ImageType"/>
    <owl:inverseOf rdf:resource="https://purl.org/memo#isImageTypeOf"/>
    <rdfs:label>hasImageType</rdfs:label>
