        <rdfs:domain rdf:resource="http://www.semanticweb.org/meme-ontology#MemeConcept"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/meme-ontology#OriginTVShow"/>
        <rdfs:label>hasOriginTVShow</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/meme-ontology#hasOriginVideoGame -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/meme-ontology#hasOriginVideoGame">
        <owl:inverseOf rdf:resource="http://www.semanticweb.org/meme-ontology#isOriginVideoGameOf"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/meme-ontology#MemeConcept"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/meme-ontology#OriginVideoGame"/>
        <rdfs:label>hasOriginVideoGame</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/meme-ontology#hasOriginWork -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/meme-ontology#hasOriginWork">
        <owl:inverseOf rdf:resource="http://www.semanticweb.org/meme-ontology#isOriginWorkOf"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/meme-ontology#MemeConcept"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/meme-ontology#OriginWork"/>
        <frbrLevel>Work</frbrLevel>
        <semanticLevel>Iconological</semanticLevel>
        <rdfs:comment xml:lang="en">Links a MemeConcept to the cultural Work it





derives from or references.</rdfs:comment>
        <rdfs:label>hasOriginWork</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/meme-ontology#hasReference -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/meme-ontology#hasReference">
        <owl:inverseOf rdf:resource="http://www.semanticweb.org/meme-ontology#isReferencedIn"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/meme-ontology#MemeConcept"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/meme-ontology#CulturalReference"/>
        <rdfs:label>hasReference</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/meme-ontology#hasRegion -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/meme-ontology#hasRegion">
        <owl:inverseOf rdf:resource="http://www.semanticweb.org/meme-ontology#isRegionOf"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/meme-ontology#MemeConcept"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/meme-ontology#GeographicRegion"/>
        <documentaryLevel>true</documentaryLevel>
        <rdfs:comment xml:lang="en">The geographic region of a meme&apos;s origin or





primary circulation.</rdfs:comment>
        <rdfs:label>hasRegion</rdfs:label>
    </owl:ObjectProperty>
    


