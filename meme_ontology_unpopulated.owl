<owl:ObjectProperty rdf:about="http://www.semanticweb.org/meme-ontology#hasTransformationDimension">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/meme-ontology#VariantInstance"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/meme-ontology#TransformationDimension"/>
        <rdfs:label>hasTransformationDimension</rdfs:label>
    </owl:ObjectProperty>
<owl:ObjectProperty rdf:about="http://www.semanticweb.org/meme-ontology#hasTransformationExtent">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/meme-ontology#VariantInstance"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/meme-ontology#TransformationExtent"/>
        <rdfs:label>hasTransformationExtent</rdfs:label>
    </owl:ObjectProperty>
<owl:ObjectProperty rdf:about="http://www.semanticweb.org/meme-ontology#isConceptualizedAs">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/meme-ontology#MemeIdea"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/meme-ontology#MemeConcept"/>
