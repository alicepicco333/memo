        <rdfs:domain rdf:resource="http://www.semanticweb.org/meme-ontology#MemeConcept"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/meme-ontology#OriginBook"/>
        <rdfs:label>hasOriginBook</rdfs:label>
    </owl:ObjectProperty>
    


