    <rdfs:label>is Canonical Image Type Of</rdfs:label>
    <rdfs:domain rdf:resource="http://www.semanticweb.org/meme-ontology#CanonicalImageType"/>
    <rdfs:range rdf:resource="http://www.semanticweb.org/meme-ontology#MemeConcept"/>
    <owl:inverseOf rdf:resource="http://www.semanticweb.org/meme-ontology#hasCanonicalImageType"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.semanticweb.org/meme-ontology#TimePeriod">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="en">Time Period</rdfs:label>
    <memo:documentaryLevel>true</memo:documentaryLevel>
    <memo:frbrLevel>Expression</memo:frbrLevel>
    <rdfs:comment xml:lang="en">The era in which a meme originated or peaked&#13;&#13;&#13;&#13;&#13;&#13;
(Pre2010, Period2010to2015, Period2016to2020, Period2021toPresent).</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.semanticweb.org/meme-ontology#Facebook">
    <rdf:type rdf:resource="http://www.semanticweb.org/meme-ontology#OriginPlatform"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdfs:label>Facebook</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.semanticweb.org/meme-ontology#hasCanonicalImageType">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:label xml:lang="en">has canonical image type</rdfs:label>
    <memo:frbrLevel>Manifestation</memo:frbrLevel>
    <memo:semanticLevel>PreIconographical</memo:semanticLevel>
    <rdfs:comment xml:lang="en">The visual medium of the canonical meme image,&#13;&#13;&#13;&#13;&#13;&#13;
assigned by CLIP-based classification.</rdfs:comment>
    <rdfs:domain rdf:resource="http://www.semanticweb.org/meme-ontology#MemeConcept"/>
    <rdfs:range rdf:resource="http://www.semanticweb.org/meme-ontology#CanonicalImageType"/>
    <owl:inverseOf rdf:resource="http://www.semanticweb.org/meme-ontology#isCanonicalImageTypeOf"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.semanticweb.org/meme-ontology#TransformationExtent">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="en">Transformation Extent</rdfs:label>
    <memo:documentaryLevel>true</memo:documentaryLevel>
    <memo:frbrLevel>Manifestation</memo:frbrLevel>
    <rdfs:comment xml:lang="en">The degree to which a variant departs from the&#13;&#13;&#13;&#13;&#13;&#13;
canonical template: Minimal (close copy), Moderate, Substantial, or Parody&#13;&#13;&#13;&#13;&#13;&#13;
(radical departure).</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.semanticweb.org/meme-ontology#">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Ontology"/>
    <rdfs:label xml:lang="en">Meme Ontology (MEMO)</rdfs:label>
    <dc:creator>Meme Ontology Project</dc:creator>
    <dc:description xml:lang="en">The Meme Ontology (MEMO) is an OWL 2 DL ontology for the formal description of internet memes. It models meme templates (MemeConcept), their underlying creative ideas (MemeIdea), and scraped variant images (VariantInstance) using a FRBR-aligned four-level abstraction hierarchy and Panofsky's three levels of semantic analysis. Value classes provide controlled vocabularies for format, platform, image type, transformation extent and dimension, and other classifiers. 5,000 meme concepts, 50 enriched meme ideas and 391 variant instances are included as named individuals.</dc:description>
    <dc:rights xml:lang="en">Released for academic research. Data sourced from&#13;&#13;&#13;&#13;&#13;&#13;
Know Your Meme under fair use.</dc:rights>
    <dc:title xml:lang="en">Meme Ontology (MEMO)</dc:title>
    <dcterms:abstract xml:lang="en">The Meme Ontology (MEMO) is a comprehensive OWL 2 DL ontology for the formal description and analysis of internet memes. It models the FRBR-aligned four-level abstraction hierarchy: meme templates (MemeConcept), creative instantiations (MemeIdea), variant manifestations (VariantInstance), and individual images (Item). Using Panofsky's three-level semantic analysis framework (PreIconographical, Iconographical, Iconological), the ontology provides controlled vocabularies for format classification, platform origin, image characteristics, transformation patterns, and cultural context. The schema encompasses 5,000 meme concepts, 50 enriched ideas, and 391 variant instances from Know Your Meme, enabling computational analysis of meme evolution, cultural adoption patterns, and creative transformation strategies in digital culture.</dcterms:abstract>
    <dcterms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#gYear">2024</dcterms:created>
    <dcterms:title xml:lang="en">Meme Ontology (MEMO)</dcterms:title>
    <rdfs:seeAlso rdf:resource="https://github.com/meme-ontology/meme-ontology"/>
    <owl:name>Meme Ontology (MEMO)</owl:name>
    <owl:versionInfo>1.0</owl:versionInfo>
  </rdf:Description>
