    <rdfs:comment xml:lang="en">Whether a meme image is animated (Animated, i.e. a GIF) or static (Static). Derived from file extension.</rdfs:comment>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://purl.org/memo#variantFilename">
