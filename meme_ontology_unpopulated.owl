  <rdf:Description rdf:about="http://www.semanticweb.org/meme-ontology#CulturalReference">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label>Cultural Reference</rdfs:label>
    <rdfs:label>CulturalReference</rdfs:label>
    <rdfs:label xml:lang="en">Cultural Reference</rdfs:label>
    <frbrLevel>Expression Manifestation</frbrLevel>
    <frbrLevel>Expression, Manifestation</frbrLevel>
    <semanticLevel>Iconological</semanticLevel>
    <rdfs:comment>The cultural phenomena encoded by a meme template. At Expression level: template-wide references. At Manifestation level: variant-specific references.</rdfs:comment>
    <rdfs:comment xml:lang="en">A cultural entity referenced by a meme — a historical&#13;
event, media property, political event, public figure, social phenomenon, or web&#13;
culture artefact. Subclasses: HistoricalEvent, MediaProperty, PoliticalEvent,&#13;
PublicFigure, SocialPhenomenon, WebCulture.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n5114bb5c5c7947f6bce208759874c965b205">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#AllDisjointClasses"/>
    <owl:members rdf:nodeID="n5114bb5c5c7947f6bce208759874c965b206"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.semanticweb.org/meme-ontology#TransformationExtent">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label>Transformation Extent</rdfs:label>
    <rdfs:label>TransformationExtent</rdfs:label>
    <rdfs:label xml:lang="en">Transformation Extent</rdfs:label>
    <documentaryLevel>true</documentaryLevel>
    <frbrLevel>Manifestation</frbrLevel>
    <rdfs:comment>The overall degree of transformation from the canonical Expression. Single-valued.</rdfs:comment>
    <rdfs:comment xml:lang="en">The degree to which a variant departs from the&#13;
canonical template: Minimal (close copy), Moderate, Substantial, or Parody&#13;
(radical departure).</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
  </rdf:Description>
