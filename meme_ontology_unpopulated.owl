<owl:ObjectProperty rdf:about="http://www.semanticweb.org/meme-ontology#hasOriginMusic">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/meme-ontology#MemeConcept"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/meme-ontology#OriginMusic"/>
        <rdfs:label>hasOriginMusic</rdfs:label>
    </owl:ObjectProperty>
<owl:ObjectProperty rdf:about="http://www.semanticweb.org/meme-ontology#hasOriginPerson">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/meme-ontology#MemeConcept"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/meme-ontology#OriginPerson"/>
        <rdfs:label>hasOriginPerson</rdfs:label>
