    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:comment xml:lang="en">MemeFormat subclass grouping character- and narrative-based formats: Character, FanArt, Parody, PopCultureReference, Reaction.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="https://purl.org/memo#MemeFormat"/>
  </rdf:Description>
