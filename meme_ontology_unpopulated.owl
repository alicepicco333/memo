        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:label>imageURL</rdfs:label>
    </owl:DatatypeProperty>
<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/meme-ontology#memeURL">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/meme-ontology#MemeConcept"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:label>memeURL</rdfs:label>
    </owl:DatatypeProperty>
<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/meme-ontology#photoId">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/meme-ontology#VariantInstance"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>Deprecated. Use photoID instead.</rdfs:comment>
        <rdfs:label>photoId</rdfs:label>
        <owl:deprecated rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</owl:deprecated>
