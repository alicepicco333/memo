  <rdf:Description rdf:about="https://schema.org/ComicSeries">
    <rdfs:label>ComicBook</rdfs:label>
    <rdfs:comment xml:lang="en">Comic strip, webcomic or graphic novel from which the meme derives; subclass of memo:OriginWork.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="https://purl.org/memo#OriginWork"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:seeAlso rdf:resource="https://www.wikidata.org/wiki/Q25379"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://purl.org/memo#ImageType">
    <memo:semanticLevel>PreIconographical</memo:semanticLevel>
    <rdfs:comment xml:lang="en">The visual medium or rendering technique of a meme image (e.g. Photograph, Drawing, Cartoon). Corresponds to Panofsky's pre-iconographic description.</rdfs:comment>
    <rdfs:label>ImageType</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://purl.org/memo#variantUploader">
    <rdfs:domain rdf:resource="https://purl.org/memo#VariantInstance"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    <rdfs:label>variantUploader</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="https://purl.org/memo#MemeIdea">
    <rdfs:comment xml:lang="en">The abstract creative idea underlying a meme template; the Work level of the FRBR hierarchy. Represents the core concept, emotional register, or rhetorical function of a meme, independent of any specific image or format.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://iflastandards.info/ns/fr/frbr/frbrer/C1002"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label>MemeIdea</rdfs:label>
    <memo:frbrLevel>Work</memo:frbrLevel>
  </rdf:Description>
  <rdf:Description rdf:about="https://purl.org/memo#AudioFormat">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:comment xml:lang="en">MemeFormat subclass grouping audio-primary formats: Song, SoundEffect.</rdfs:comment>
    <rdfs:label>AudioFormat</rdfs:label>
    <rdfs:subClassOf rdf:resource="https://purl.org/memo#MemeFormat"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://purl.org/memo#isImageTypeOf">
    <rdfs:range rdf:nodeID="N3b308c984372484caa56643bca539f6c"/>
    <rdfs:label>isImageTypeOf</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:domain rdf:resource="https://purl.org/memo#ImageType"/>
    <owl:inverseOf rdf:resource="https://purl.org/memo#hasImageType"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://purl.org/memo#ParticipatoryFormat">
    <rdfs:label>ParticipatoryFormat</rdfs:label>
    <rdfs:subClassOf rdf:resource="https://purl.org/memo#MemeFormat"/>
    <rdfs:comment xml:lang="en">MemeFormat subclass grouping participatory formats: ParticipatoryMedia, Dance, SocialGame.</rdfs:comment>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://purl.org/memo#SubjectMatter">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <memo:semanticLevel>PreIconographical</memo:semanticLevel>
    <rdfs:comment xml:lang="en">The primary visual subject category depicted in a meme image (e.g. PersonPresent, AnimalPresent, ObjectOnly). Corresponds to Panofsky's pre-iconographic description level.</rdfs:comment>
    <rdfs:label>SubjectMatter</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.wikidata.org/entity/Q3220391">
    <rdfs:label xml:lang="en">OnlineService</rdfs:label>
    <rdfs:seeAlso rdf:resource="https://www.wikidata.org/wiki/Q3220391"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://purl.org/memo#VideoFormat">
    <rdfs:label>VideoFormat</rdfs:label>
    <rdfs:subClassOf rdf:resource="https://purl.org/memo#MemeFormat"/>
    <rdfs:comment xml:lang="en">MemeFormat subclass grouping video-based formats: ViralVideo, ViralDebate, LipDub.</rdfs:comment>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://purl.org/memo#WebCulture">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label>WebCulture</rdfs:label>
    <rdfs:subClassOf rdf:resource="https://purl.org/memo#CulturalReference"/>
    <rdfs:comment xml:lang="en">A web-native cultural phenomenon, community, or trend referenced by a meme.</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="https://purl.org/memo#isTransformationDimensionOf">
    <rdfs:label>isTransformationDimensionOf</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:range rdf:resource="https://purl.org/memo#VariantInstance"/>
