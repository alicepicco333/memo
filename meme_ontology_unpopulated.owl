  <rdf:Description rdf:about="https://purl.org/memo#AudioFormat">
    <rdfs:subClassOf rdf:resource="https://purl.org/memo#MemeFormat"/>
    <rdfs:label>AudioFormat</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:comment xml:lang="en">MemeFormat subclass grouping audio-primary formats: Song, SoundEffect.</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="https://schema.org/url">
    <rdfs:label>url</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#AnnotationProperty"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    <rdfs:domain rdf:resource="https://purl.org/memo#MemeConcept"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://schema.org/ComicSeries">
    <rdfs:comment xml:lang="en">Comic strip, webcomic or graphic novel from which the meme derives; subclass of OriginWork (wd:Q386724).</rdfs:comment>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://purl.org/memo#OriginWork"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://purl.org/memo#TimePeriod">
    <rdfs:seeAlso rdf:resource="https://www.wikidata.org/wiki/Q11471"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label>TimePeriod</rdfs:label>
    <rdfs:comment xml:lang="en">Chronological period in which the meme originated or peaked; aligned with Wikidata Q11471.</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="https://purl.org/memo#isReferencedIn">
    <rdfs:domain rdf:resource="https://purl.org/memo#CulturalReference"/>
    <rdfs:label>isReferencedIn</rdfs:label>
    <rdfs:range rdf:resource="https://purl.org/memo#MemeConcept"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <owl:inverseOf rdf:resource="https://purl.org/memo#hasReference"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://schema.org/keywords">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#AnnotationProperty"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    <rdfs:domain rdf:resource="https://purl.org/memo#MemeConcept"/>
    <rdfs:label>keywords</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="https://purl.org/memo#OriginPlatform">
    <rdfs:seeAlso rdf:resource="https://www.wikidata.org/wiki/Q3220391"/>
    <rdfs:label>OriginPlatform</rdfs:label>
    <rdfs:comment xml:lang="en">Online platform or service where the meme was first published; aligned with Wikidata Q3220391.</rdfs:comment>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://schema.org/TVSeries">
    <rdfs:subClassOf rdf:resource="https://purl.org/memo#OriginWork"/>
    <rdfs:comment xml:lang="en">Television or web series from which the meme derives; subclass of OriginWork (wd:Q386724).</rdfs:comment>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
