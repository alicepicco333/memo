    <rdfs:domain rdf:resource="https://purl.org/memo#MemeConcept"/>
    <rdfs:label>hasId</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://purl.org/dc/terms/format">
    <rdfs:range rdf:resource="https://purl.org/memo#FileFormat"/>
    <rdfs:domain rdf:resource="https://purl.org/memo#MemeConcept"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:comment xml:lang="en">File format of the meme image (JPEG, PNG, GIF, etc.), linked to a FileFormat individual (wd:Q235557). Uses dcterms:format rather than a memo: property to align with Dublin Core usage.</rdfs:comment>
    <rdfs:label>format</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.wikidata.org/prop/direct/P527">
    <rdfs:domain rdf:resource="https://purl.org/memo#MemeConcept"/>
    <rdfs:range rdf:resource="https://purl.org/memo#VariantInstance"/>
    <owl:inverseOf rdf:resource="http://www.wikidata.org/prop/direct/P361"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
