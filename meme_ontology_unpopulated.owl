<owl:ObjectProperty rdf:about="http://www.semanticweb.org/meme-ontology#hasSubjectMatter">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/meme-ontology#VariantInstance"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/meme-ontology#SubjectMatter"/>
        <rdfs:label>hasSubjectMatter</rdfs:label>
    </owl:ObjectProperty>
<owl:ObjectProperty rdf:about="http://www.semanticweb.org/meme-ontology#hasTextPresence">
