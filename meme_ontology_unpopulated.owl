  <rdf:Description rdf:about="http://www.semanticweb.org/meme-ontology#isTransformationExtentOf">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:label>is Transformation Extent Of</rdfs:label>
    <rdfs:domain rdf:resource="http://www.semanticweb.org/meme-ontology#TransformationExtent"/>
    <rdfs:range rdf:resource="http://www.semanticweb.org/meme-ontology#VariantInstance"/>
    <owl:inverseOf rdf:resource="http://www.semanticweb.org/meme-ontology#hasTransformationExtent"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.semanticweb.org/meme-ontology#MemeIdea">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="en">Meme Idea</rdfs:label>
    <memo:frbrLevel>Work</memo:frbrLevel>
    <rdfs:comment xml:lang="en">The abstract Work-level idea underlying a memo:&#13;&#13;&#13;&#13;&#13;&#13;
its core narrative, emotional register, rhetorical function or cultural role,&#13;&#13;&#13;&#13;&#13;&#13;
independent of any specific image or format. 50 enriched individuals from the&#13;&#13;&#13;&#13;&#13;&#13;
D0 sample, with descriptions and cultural reference annotations.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.semanticweb.org/meme-ontology#LipDub">
    <rdf:type rdf:resource="http://www.semanticweb.org/meme-ontology#MemeFormat"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdfs:label>Lip Dub</rdfs:label>
    <rdfs:comment>Deprecated. Use LipDub instead.</rdfs:comment>
    <owl:deprecated rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</owl:deprecated>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.semanticweb.org/meme-ontology#isSubjectMatterOf">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:label>is Subject Matter Of</rdfs:label>
    <rdfs:domain rdf:resource="http://www.semanticweb.org/meme-ontology#SubjectMatter"/>
