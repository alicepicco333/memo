  <rdf:Description rdf:about="https://purl.org/memo#isAnimationStatusOf">
    <rdfs:range rdf:resource="https://purl.org/memo#MemeConcept"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:domain rdf:resource="https://purl.org/memo#AnimationStatus"/>
    <owl:inverseOf rdf:resource="https://purl.org/memo#hasAnimationStatus"/>
    <rdfs:label>isAnimationStatusOf</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://purl.org/dc/terms/created">
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#AnnotationProperty"/>
    <rdfs:label>created</rdfs:label>
    <rdfs:domain rdf:resource="https://purl.org/memo#MemeConcept"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://purl.org/memo#PoliticalEvent">
    <rdfs:subClassOf rdf:resource="https://purl.org/memo#CulturalReference"/>
    <rdfs:label>PoliticalEvent</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:comment xml:lang="en">A political event, controversy, or campaign that a meme iconologically references.</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="http://purl.org/dc/terms/description">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#AnnotationProperty"/>
    <rdfs:domain rdf:resource="https://purl.org/memo#MemeConcept"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    <rdfs:label>description</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="https://purl.org/memo#ImageType">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <memo:semanticLevel>PreIconographical</memo:semanticLevel>
    <rdfs:label>ImageType</rdfs:label>
    <rdfs:comment xml:lang="en">The visual medium or rendering technique of a meme image (e.g. Photograph, Drawing, Cartoon). Corresponds to Panofsky's pre-iconographic description.</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="https://purl.org/memo#hasTransformationDimension">
    <rdfs:range rdf:resource="https://purl.org/memo#TransformationDimension"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:label>hasTransformationDimension</rdfs:label>
    <rdfs:domain rdf:resource="https://purl.org/memo#VariantInstance"/>
    <owl:inverseOf rdf:resource="https://purl.org/memo#isTransformationDimensionOf"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.w3.org/ns/prov#wasDerivedFrom">
    <rdfs:comment xml:lang="en">Superproperty of memo:hasOriginWork. Not directly asserted in MEMO — memo:hasOriginWork is used throughout, from which reasoners infer prov:wasDerivedFrom.</rdfs:comment>
    <rdfs:domain rdf:resource="https://purl.org/memo#MemeConcept"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:label>wasDerivedFrom</rdfs:label>
    <rdfs:range rdf:resource="https://purl.org/memo#OriginWork"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://purl.org/memo#HistoricalEvent">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://purl.org/memo#CulturalReference"/>
    <rdfs:comment xml:lang="en">A historical event, period, or crisis referenced by a meme.</rdfs:comment>
    <rdfs:label>HistoricalEvent</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="https://purl.org/memo#VideoFormat">
    <rdfs:subClassOf rdf:resource="https://purl.org/memo#MemeFormat"/>
    <rdfs:comment xml:lang="en">MemeFormat subclass grouping video-based formats: ViralVideo, ViralDebate, LipDub.</rdfs:comment>
    <rdfs:label>VideoFormat</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://schema.org/Movie">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://purl.org/memo#OriginWork"/>
    <rdfs:comment xml:lang="en">Film from which the meme derives; subclass of OriginWork (wd:Q386724).</rdfs:comment>
  </rdf:Description>
