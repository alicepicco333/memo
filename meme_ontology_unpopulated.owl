        <rdfs:range rdf:resource="http://www.semanticweb.org/meme-ontology#TextPresence"/>
        <rdfs:label>hasTextPresence</rdfs:label>
    </owl:ObjectProperty>
<owl:ObjectProperty rdf:about="http://www.semanticweb.org/meme-ontology#hasTimePeriod">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/meme-ontology#MemeConcept"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/meme-ontology#TimePeriod"/>
        <documentaryLevel>true</documentaryLevel>
