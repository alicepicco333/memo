  <rdf:Description rdf:about="http://www.semanticweb.org/meme-ontology#MemeIdea">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label>Meme Idea</rdfs:label>
    <rdfs:label xml:lang="en">Meme Idea</rdfs:label>
    <frbrLevel>Work</frbrLevel>
    <rdfs:comment>The abstract cultural concept underlying a named meme template. Work-level class. Populated manually for D0 subset via conceptDescription data property. Has no visual properties — only the pure abstract idea.</rdfs:comment>
    <rdfs:comment xml:lang="en">The abstract Work-level idea underlying a memo:&#13;
its core narrative, emotional register, rhetorical function or cultural role,&#13;
independent of any specific image or format. 50 enriched individuals from the&#13;
D0 sample, with descriptions and cultural reference annotations.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
  </rdf:Description>
