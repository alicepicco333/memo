    <documentaryLevel>true</documentaryLevel>
    <frbrLevel>Manifestation</frbrLevel>
    <rdfs:comment>The specific aspect of the canonical template that changes in a variant. Multi-valued.</rdfs:comment>
    <rdfs:comment xml:lang="en">The axis along which a variant transforms the&#13;
canonical template: CaptionChange, VisualSubstrate, MediumShift, StyleShift,&#13;
CompositionShift, CrossoverMerge, LanguageShift, Localization.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
  </rdf:Description>
