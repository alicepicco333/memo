<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/meme-ontology#captionText">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/meme-ontology#VariantInstance"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:label>captionText</rdfs:label>
    </owl:DatatypeProperty>
<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/meme-ontology#clipImageTypeScore">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/meme-ontology#MemeConcept"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#float"/>
        <rdfs:comment xml:lang="en">Confidence score (0–1) from the CLIP model for
the assigned CanonicalImageType classification.</rdfs:comment>
        <rdfs:label>clipImageTypeScore</rdfs:label>
    </owl:DatatypeProperty>
<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/meme-ontology#clipPublicFigureScore">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/meme-ontology#MemeConcept"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#float"/>
        <rdfs:comment xml:lang="en">CLIP confidence score (0–1) estimating the
likelihood that the image depicts a recognisable public figure.</rdfs:comment>
        <rdfs:label>clipPublicFigureScore</rdfs:label>
    </owl:DatatypeProperty>
<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/meme-ontology#clipTextScore">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/meme-ontology#MemeConcept"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#float"/>
        <rdfs:comment xml:lang="en">CLIP confidence score (0–1) for the text-presence
classification.</rdfs:comment>
        <rdfs:label>clipTextScore</rdfs:label>
    </owl:DatatypeProperty>
<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/meme-ontology#conceptDescription">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/meme-ontology#MemeIdea"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:label>conceptDescription</rdfs:label>
    </owl:DatatypeProperty>
<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/meme-ontology#description">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/meme-ontology#MemeConcept"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:label>description</rdfs:label>
    </owl:DatatypeProperty>
<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/meme-ontology#hasId">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/meme-ontology#MemeConcept"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
        <rdfs:comment>Deprecated. Use hasID instead.</rdfs:comment>
        <rdfs:comment xml:lang="en">Numeric identifier matching the meme&apos;s position
in the scraped dataset (1–5000).</rdfs:comment>
        <rdfs:label xml:lang="en">has ID</rdfs:label>
        <rdfs:label>hasId</rdfs:label>
        <owl:deprecated rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</owl:deprecated>
    </owl:DatatypeProperty>
<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/meme-ontology#imageFilePath">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/meme-ontology#MemeConcept"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:label>imageFilePath</rdfs:label>
    </owl:DatatypeProperty>
<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/meme-ontology#imageFilename">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/meme-ontology#MemeConcept"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>Deprecated. Use imageFileName instead.</rdfs:comment>
        <rdfs:label>imageFilename</rdfs:label>
        <owl:deprecated rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</owl:deprecated>
    </owl:DatatypeProperty>
<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/meme-ontology#imageURL">
